Part 11: CI/CD Configuration (TOML)

11.1 CI Configuration

```toml
# .maia/ci.toml
[ci]
enabled = true
provider = "github-actions"

[ci.matrix]
os = ["ubuntu-24.04", "ubuntu-26.04", "windows-10", "windows-11", "macos-11", "macos-14", "freebsd-13", "freebsd-14", "openbsd-7.0", "openbsd-7.5", "netbsd-10.0", "netbsd-10.1", "dragonflybsd-6.0", "dragonflybsd-6.4"]
arch = ["x86_64", "arm64", "riscv64"]

[ci.steps.checkout]
command = "git clone $REPO_URL ."

[ci.steps.bootstrap]
command = "koda bootstrap"

[ci.steps.build]
command = "maia build --release"

[ci.steps.test]
command = "koda test --matrix"

[ci.cache]
enabled = true
paths = [".cache/build", "deps"]
key = "${{ runner.os }}-${{ hashFiles('maia.lock') }}"

[ci.notifications.slack]
webhook = "https://hooks.slack.com/services/..."
on = ["failure"]

[ci.notifications.email]
to = ["build@purginglight.com"]
on = ["failure"]
```

