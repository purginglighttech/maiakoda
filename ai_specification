3.3 Editor Implementation (Maia)

3.3.1 Core Editor (Maia)

```pascal
/* editors/mkedit/src/core.maia - Modal editor core */
module Editor.Core

export type EditorMode = enum {
    Normal,
    Insert,
    Visual,
    VisualLine,
    VisualBlock,
    Command,
}

export type Editor = struct {
    mode: EditorMode,
    buffers: own array(Buffer),
    current_buffer: usize,
    windows: own array(Window),
    keymap: own Keymap,
    hooks: own array(Hook),
    extensions: own array(Extension),
}

export type Buffer = struct {
    id: u32,
    path: ?string,
    lines: own array(string),
    modified: bool,
    selections: own array(Selection),
    cursor: Position,
    scroll: Position,
    syntax: ?SyntaxHighlighter,
}

export type Selection = struct {
    anchor: Position,
    cursor: Position,
}

export type Position = struct {
    line: usize,
    column: usize,
}

export type Window = struct {
    buffer_id: u32,
    x: u32,
    y: u32,
    width: u32,
    height: u32,
    top_line: usize,
    left_col: usize,
}

impl Editor {
    /* Create a new editor instance */
    function create(): own Editor
    begin
        var editor := Editor {
            .mode = .Normal,
            .buffers = array(Buffer).create(),
            .current_buffer = 0,
            .windows = array(Window).create(),
            .keymap = Keymap.create(),
            .hooks = array(Hook).create(),
            .extensions = array(Extension).create(),
        }
        
        /* Setup default key bindings */
        editor.setup_default_keymap()
        
        /* Create initial buffer */
        var buffer := Buffer.create()
        editor.buffers.append(buffer)
        
        /* Create initial window */
        var window := Window.create(0, 0, 80, 24, 0, 0)
        editor.windows.append(window)
        
        return editor
    end
    
    /* Run the editor main loop */
    function run(self: *Editor)
    begin
        /* Initialize terminal */
        Terminal.init_raw_mode()
        defer Terminal.restore()
        
        /* Clear screen */
        Terminal.clear()
        
        /* Main event loop */
        loop {
            /* Render current state */
            self.render()
            
            /* Get input */
            var key := Terminal.read_key()
            
            /* Process based on mode */
            match self.mode {
                .Normal => self.handle_normal_mode(key),
                .Insert => self.handle_insert_mode(key),
                .Visual => self.handle_visual_mode(key),
                .Command => self.handle_command_mode(key),
            }
            
            /* Run hooks */
            self.run_hooks(.AfterKeypress)
        }
    end
    
    /* Render the editor */
    function render(self: *Editor)
    begin
        var buffer := self.current_buffer()
        var window := self.current_window()
        
        /* Clear area */
        Terminal.move_cursor(0, 0)
        
        /* Draw buffer content */
        var line_start := window.top_line
        var line_end := min(line_start + window.height, buffer.lines.len())
        
        for i in line_start..line_end - 1 do
            var line := buffer.lines[i]
            var display_line := line
            
            /* Apply syntax highlighting */
            if buffer.syntax != null then
                display_line = buffer.syntax.highlight(line)
            end
            
            /* Handle scrolling */
            if window.left_col > 0 then
                display_line = display_line[window.left_col..]
            end
            
            Terminal.write(display_line)
            
            /* Clear rest of line */
            Terminal.clear_to_end()
            
            /* Move to next line */
            if i < line_end - 1 then
                Terminal.write("\n")
            end
        end
        
        /* Draw status line */
        self.draw_status_line()
        
        /* Draw cursor */
        self.draw_cursor()
    end
    
    /* Handle normal mode key presses */
    function handle_normal_mode(self: *Editor, key: Key)
    begin
        var binding := self.keymap.get(key, .Normal)
        
        match binding {
            "j" => self.move_cursor(.Down),
            "k" => self.move_cursor(.Up),
            "h" => self.move_cursor(.Left),
            "l" => self.move_cursor(.Right),
            "i" => self.mode = .Insert,
            "v" => self.mode = .Visual,
            "V" => self.mode = .VisualLine,
            "dd" => self.delete_line(),
            "yy" => self.yank_line(),
            "p" => self.paste_after(),
            "P" => self.paste_before(),
            "u" => self.undo(),
            "r" => self.redo(),
            ":" => self.enter_command_mode(),
            "/" => self.search_forward(),
            "?" => self.search_backward(),
            "n" => self.search_next(),
            "N" => self.search_prev(),
            "gg" => self.goto_line(0),
            "G" => self.goto_line(self.current_buffer().lines.len() - 1),
            "w" => self.move_word_forward(),
            "b" => self.move_word_backward(),
            "e" => self.move_word_end(),
            "0" => self.move_line_start(),
            "$" => self.move_line_end(),
            "x" => self.delete_char(),
            "X" => self.delete_char_backward(),
            "o" => self.open_line_below(),
            "O" => self.open_line_above(),
            "a" => self.append_after_cursor(),
            "A" => self.append_line_end(),
            "I" => self.insert_line_start(),
            "cw" => self.change_word(),
            "cc" => self.change_line(),
            "dw" => self.delete_word(),
            "diw" => self.delete_inner_word(),
            "ciw" => self.change_inner_word(),
            "yy" => self.yank_line(),
            "yw" => self.yank_word(),
            "p" => self.paste_after(),
            "P" => self.paste_before(),
            ". " => self.repeat_last_command(),
            "Ctrl-f" => self.page_down(),
            "Ctrl-b" => self.page_up(),
            "Ctrl-d" => self.half_page_down(),
            "Ctrl-u" => self.half_page_up(),
            "zz" => self.center_cursor(),
            "zt" => self.cursor_top(),
            "zb" => self.cursor_bottom(),
            "Ctrl-w v" => self.split_vertical(),
            "Ctrl-w s" => self.split_horizontal(),
            "Ctrl-w w" => self.cycle_windows(),
            "Ctrl-w h" => self.focus_window(.Left),
            "Ctrl-w j" => self.focus_window(.Down),
            "Ctrl-w k" => self.focus_window(.Up),
            "Ctrl-w l" => self.focus_window(.Right),
            "Ctrl-w q" => self.close_window(),
            "Ctrl-w o" => self.close_other_windows(),
            "gt" => self.next_tab(),
            "gT" => self.prev_tab(),
            else => {}
        }
    end
    
    /* Handle insert mode key presses */
    function handle_insert_mode(self: *Editor, key: Key)
    begin
        match key {
            .Escape => self.mode = .Normal,
            .Enter => self.insert_newline(),
            .Backspace => self.delete_char_backward(),
            .Delete => self.delete_char_forward(),
            .Tab => self.insert_tab(),
            .Char(c) => self.insert_char(c),
            .Up => self.move_cursor(.Up),
            .Down => self.move_cursor(.Down),
            .Left => self.move_cursor(.Left),
            .Right => self.move_cursor(.Right),
            .Home => self.move_line_start(),
            .End => self.move_line_end(),
            .PageUp => self.page_up(),
            .PageDown => self.page_down(),
            else => {}
        }
    end
    
    /* Handle visual mode key presses */
    function handle_visual_mode(self: *Editor, key: Key)
    begin
        var binding := self.keymap.get(key, .Visual)
        
        match binding {
            "j" => self.extend_selection(.Down),
            "k" => self.extend_selection(.Up),
            "h" => self.extend_selection(.Left),
            "l" => self.extend_selection(.Right),
            "w" => self.extend_word_forward(),
            "b" => self.extend_word_backward(),
            "e" => self.extend_word_end(),
            "0" => self.extend_line_start(),
            "$" => self.extend_line_end(),
            "gg" => self.extend_to_start(),
            "G" => self.extend_to_end(),
            "d" => self.delete_selection(),
            "y" => self.yank_selection(),
            "c" => self.change_selection(),
            "~" => self.swap_case(),
            ">" => self.indent_right(),
            "<" => self.indent_left(),
            "=" => self.format_selection(),
            "U" => self.to_upper(),
            "u" => self.to_lower(),
            "I" => self.insert_at_line_start(),
            "A" => self.append_at_line_end(),
            "J" => self.join_lines(),
            "Escape" => self.mode = .Normal,
            else => {}
        }
    end
    
    /* Extension management */
    function load_extension(self: *Editor, path: string): bool
    begin
        /* Load extension module dynamically */
        var module := Module.load(path)
        if module == null then
            return false
        end
        
        /* Get extension init function */
        var init_fn := module.symbol("extension_init") as fn(editor: *Editor)
        if init_fn == null then
            return false
        end
        
        /* Initialize extension */
        init_fn(self)
        
        return true
    end
    
    /* Register a hook */
    function register_hook(self: *Editor, event: HookEvent, callback: fn())
    begin
        self.hooks.append(Hook {
            .event = event,
            .callback = callback,
        })
    end
}
