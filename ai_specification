Part 4: Phase 1 - Maia Self-Hosted Compiler

4.1 Phase 1 Configuration

```toml
# phases/phase_1.toml
[phase]
name = "Maia Self-Hosted Compiler"
duration_weeks = 8
language = "Maia"
output = "compiler/bin/maia"
requires = "phase_0"

[phase.directories]
src = "compiler/src"
tests = "compiler/tests"

[phase.translation_tasks]
lexer = { from = "bootstrap/src/lexer.zig", to = "compiler/src/lexer.maia" }
parser = { from = "bootstrap/src/parser.zig", to = "compiler/src/parser.maia" }
ast = { from = "bootstrap/src/ast.zig", to = "compiler/src/ast.maia" }
sema = { from = "bootstrap/src/sema.zig", to = "compiler/src/sema.maia" }
ir = { from = "bootstrap/src/ir.zig", to = "compiler/src/ir.maia" }
x86_64_codegen = { from = "bootstrap/src/codegen/x86_64.zig", to = "compiler/src/codegen/x86_64.maia" }
arm64_codegen = { from = "bootstrap/src/codegen/arm64.zig", to = "compiler/src/codegen/arm64.maia" }
riscv64_codegen = { from = "bootstrap/src/codegen/riscv64.zig", to = "compiler/src/codegen/riscv64.maia" }
wasm32_codegen = { from = "bootstrap/src/codegen/wasm32.zig", to = "compiler/src/codegen/wasm32.maia" }
assembler = { from = "bootstrap/src/assembler.zig", to = "compiler/src/assembler.maia" }
linker = { from = "bootstrap/src/linker.zig", to = "compiler/src/linker.maia" }

[phase.bootstrap_process]
step_1 = { action = "compile", input = "compiler/src/main.maia", compiler = "bootstrap/bin/maia", output = "compiler-stage1" }
step_2 = { action = "compile", input = "compiler/src/main.maia", compiler = "compiler-stage1", output = "compiler-stage2" }
step_3 = { action = "verify", condition = "stage1_and_stage2_identical" }
step_4 = { action = "set_default", compiler = "compiler-stage2" }

[phase.success_criteria]
stage1_and_stage2_identical = true
compiles_itself = true
all_bootstrap_tests_pass = true
no_zig_code_remaining = true
performance_improved = true
```

