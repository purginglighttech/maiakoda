Part 14: Complete BNF Grammar

```ebnf
(* Full MaiaKoda Grammar v0.0.1 *)

(* Top Level *)
program         = { module | koda_script }
module          = "module" ident ";" { declaration }
koda_script     = { statement }

(* Declarations *)
declaration     = var_decl | const_decl | func_decl | proc_decl | type_decl
                | actor_decl | extern_decl

var_decl        = "var" ident { "," ident } ":" type [ "=" expr ]
const_decl      = "const" ident ":" type "=" expr
func_decl       = [ "async" ] "function" ident "(" [ params ] ")" ":" type [ ";" ] block
proc_decl       = [ "async" ] "procedure" ident "(" [ params ] ")" [ ";" ] block
type_decl       = "type" ident "=" type

(* Blocks *)
block           = "begin" { statement } "end"

(* Statements *)
statement       = assignment | if_stmt | for_stmt | while_stmt | match_stmt
                | return_stmt | defer_stmt | try_stmt | spawn_stmt
                | safe_block | unsafe_block | expr ";"

assignment      = lvalue assign_op expr
assign_op       = ":=" | "+=" | "-=" | "*=" | "/=" | "%=" | "&=" | "|=" | "^=" | "<<=" | ">>="
lvalue          = ident [ "[" expr "]" ] [ "." ident ]

if_stmt         = "if" expr "then" block { "elsif" expr "then" block } [ "else" block ] "end"
for_stmt        = "for" for_range "do" block "end"
for_range       = ident "in" range_expr | ident "," ident "in" expr
while_stmt      = "while" expr "do" block "end"
match_stmt      = "match" expr "{" { match_case } "}"
match_case      = pattern "=>" block ","

return_stmt     = "return" [ expr ]
defer_stmt      = "defer" expr
try_stmt        = "try" block { "catch" [ pattern ] block } "end"
spawn_stmt      = "spawn" expr

safe_block      = "safe" "do" block "end"
unsafe_block    = "unsafe" "do" block "end"

(* Expressions *)
expr            = logical_expr
logical_expr    = compare_expr { ("and" | "or") compare_expr }
compare_expr    = additive_expr { ("==" | "!=" | "<" | ">" | "<=" | ">=") additive_expr }
additive_expr   = multiplicative_expr { ("+" | "-") multiplicative_expr }
multiplicative_expr = unary_expr { ("*" | "/" | "%" | "//") unary_expr }
unary_expr      = ["not" | "-" | "~" | "&" | "*"] primary_expr

primary_expr    = literal | ident | "(" expr ")" | call_expr | subscript_expr
                | member_expr | await_expr | range_expr | lambda_expr

call_expr       = expr "(" [ expr { "," expr } ] ")"
subscript_expr  = expr "[" expr "]"
member_expr     = expr "." ident
await_expr      = "await" expr
range_expr      = expr ".." expr [ "<" ]
lambda_expr     = "|" [ params ] "|" expr

(* Types *)
type            = primitive_type | composite_type | qualified_type | function_type
primitive_type  = "int8" | "int16" | "int32" | "int64" | "uint8" | "uint16" | "uint32" | "uint64"
                | "f32" | "f64" | "bool" | "string" | "usize" | "isize"
composite_type  = "[" expr "]" type | "[]" type | "array(" type ")"
                | "struct" "{" { ident ":" type "," } "}"
                | "enum" "{" { ident [ "=" expr ] "," } "}"
                | "?" type
qualified_type  = [ "own" | "ref" | "mut" | "rc" | "weak" ] type
                | [ "iso" | "trn" | "val" | "box" | "tag" ] type
function_type   = "function" "(" [ params ] ")" ":" type

(* Patterns *)
pattern         = literal | ident | "_" | "(" pattern { "," pattern } ")"
                | ident ".." ident

(* Parameters *)
params          = param { "," param }
param           = ident ":" type [ "=" expr ]

(* Lexical *)
ident           = letter { letter | digit | "_" }
literal         = integer_literal | float_literal | string_literal | bool_literal | "null"
integer_literal = digit { digit } [ "_" digit { digit } ]
                | "0x" hex_digit { hex_digit }
                | "0o" oct_digit { oct_digit }
                | "0b" bin_digit { bin_digit }
float_literal   = digit { digit } "." digit { digit } [ "e" [ "+" | "-" ] digit { digit } ]
string_literal  = '"' { character } '"' | '"""' { character } '"""'
bool_literal    = "true" | "false"

letter          = "A".."Z" | "a".."z" | "_"
digit           = "0".."9"
hex_digit       = "0".."9" | "A".."F" | "a".."f"
oct_digit       = "0".."7"
bin_digit       = "0" | "1"
```

