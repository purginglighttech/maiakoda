Appendix B: Grammar (EBNF)

```ebnf
program         = { module | statement }
module          = "module" identifier ";" { declaration }
declaration     = variable_decl | constant_decl | function_decl | procedure_decl | type_decl

variable_decl   = "var" identifier { "," identifier } ":" type [ "=" expression ]
constant_decl   = "const" identifier ":" type "=" expression
function_decl   = "function" identifier "(" [ parameters ] ")" ":" type [ ";" ] block
procedure_decl  = "procedure" identifier "(" [ parameters ] ")" [ ";" ] block
type_decl       = "type" identifier "=" type

block           = "begin" { statement } "end"
statement       = assignment | if_statement | for_statement | while_statement | match_statement
                | return_statement | defer_statement | expression ";"

expression      = primary { binary_op primary }
primary         = literal | identifier | "(" expression ")" | function_call

literal         = integer_literal | float_literal | string_literal | boolean_literal | null_literal
```

