2.4.2 Lexer (Maia)

```pascal
/* compiler/src/lexer.maia - Tokenization module */
module Compiler.Lexer

export type TokenKind = enum {
    /* Keywords */
    KW_MODULE, KW_USE, KW_EXPORT,
    KW_VAR, KW_CONST,
    KW_FUNCTION, KW_PROCEDURE,
    KW_TYPE, KW_STRUCT, KW_ENUM,
    KW_BEGIN, KW_END,
    KW_IF, KW_THEN, KW_ELSIF, KW_ELSE,
    KW_FOR, KW_WHILE, KW_DO, KW_LOOP,
    KW_BREAK, KW_CONTINUE,
    KW_RETURN, KW_MATCH,
    KW_AS, KW_NULL, KW_TRUE, KW_FALSE,
    KW_OWN, KW_REF, KW_MUT, KW_RC, KW_WEAK,
    KW_ISO, KW_TRN, KW_VAL, KW_BOX, KW_TAG,
    KW_ACTOR, KW_BEHAVIOR,
    KW_SPAWN, KW_AWAIT, KW_ASYNC,
    KW_DEFER, KW_UNSAFE, KW_SAFE,
    
    /* Operators */
    OP_PLUS, OP_MINUS, OP_STAR, OP_SLASH, OP_PERCENT, OP_DOUBLE_SLASH,
    OP_ASSIGN, OP_COLON_EQUALS,
    OP_PLUS_EQUALS, OP_MINUS_EQUALS, OP_STAR_EQUALS,
    OP_SLASH_EQUALS, OP_PERCENT_EQUALS,
    OP_EQUALS_EQUALS, OP_NOT_EQUALS,
    OP_LESS, OP_GREATER, OP_LESS_EQUALS, OP_GREATER_EQUALS,
    OP_AND, OP_OR, OP_NOT,
    OP_BIT_AND, OP_BIT_OR, OP_BIT_XOR, OP_BIT_NOT,
    OP_SHIFT_LEFT, OP_SHIFT_RIGHT,
    OP_RANGE, OP_ARROW,
    OP_DOT, OP_COMMA, OP_SEMICOLON, OP_COLON,
    OP_LPAREN, OP_RPAREN,
    OP_LBRACKET, OP_RBRACKET,
    OP_LBRACE, OP_RBRACE,
    
    /* Literals */
    LIT_INTEGER, LIT_FLOAT, LIT_STRING, LIT_CHAR,
    
    /* Other */
    IDENTIFIER,
    COMMENT_REGULAR, COMMENT_DOC, COMMENT_DOC_BLOCK,
    WHITESPACE,
    ERROR,
    EOF,
}

export type Token = struct {
    kind: TokenKind,
    start: usize,
    end: usize,
    line: u32,
    column: u32,
}

export type Lexer = struct {
    source: []u8,
    position: usize,
    line: u32,
    column: u32,
}

impl Lexer {
    /* Create a new lexer */
    function create(source: []u8): own Lexer
    begin
        return Lexer {
            .source = source,
            .position = 0,
            .line = 1,
            .column = 1,
        }
    end
    
    /* Tokenize the entire source */
    function tokenize(self: *Lexer): own []Token
    begin
        var tokens := array(Token).create()
        
        while true do
            var tok := self.next_token()
            tokens.append(tok)
            if tok.kind == TokenKind.EOF then
                break
            end
        end
        
        return consume tokens
    end
    
    /* Get the next token */
    function next_token(self: *Lexer): Token
    begin
        self.skip_whitespace()
        
        if self.position >= self.source.len() then
            return Token {
                .kind = TokenKind.EOF,
                .start = self.position,
                .end = self.position,
                .line = self.line,
                .column = self.column,
            }
        end
        
        var c := self.source[self.position]
        var start := self.position
        var line := self.line
        var col := self.column
        
        /* Identifiers and keywords */
        if (c >= 'a' and c <= 'z') or (c >= 'A' and c <= 'Z') or c == '_' then
            return self.read_identifier(start, line, col)
        end
        
        /* Numbers */
        if c >= '0' and c <= '9' then
            return self.read_number(start, line, col)
        end
        
        /* Strings */
        if c == '"' then
            return self.read_string(start, line, col)
        end
        
        /* Characters */
        if c == '\'' then
            return self.read_char(start, line, col)
        end
        
        /* Comments */
        if c == '/' then
            if self.peek() == '*' then
                return self.read_regular_comment(start, line, col)
            end
            if self.peek() == '/' then
                if self.peek_offset(2) == '/' then
                    return self.read_doc_comment_block(start, line, col)
                end
                return self.read_doc_comment(start, line, col)
            end
        end
        
        /* Operators and punctuation */
        return self.read_operator(start, line, col)
    end
    
    /* Read an identifier or keyword */
    function read_identifier(self: *Lexer, start: usize, line: u32, col: u32): Token
    begin
        while self.position < self.source.len() do
            var c := self.source[self.position]
            var is_alnum := (c >= 'a' and c <= 'z') or
                           (c >= 'A' and c <= 'Z') or
                           (c >= '0' and c <= '9') or
                           c == '_'
            if !is_alnum then
                break
            end
            self.position += 1
            self.column += 1
        end
        
        var text := self.source[start..self.position]
        var kind := self.keyword_to_kind(text) ?? TokenKind.IDENTIFIER
        
        return Token {
            .kind = kind,
            .start = start,
            .end = self.position,
            .line = line,
            .column = col,
        }
    end
    
    /* Read a numeric literal */
    function read_number(self: *Lexer, start: usize, line: u32, col: u32): Token
    begin
        var is_float := false
        
        while self.position < self.source.len() do
            var c := self.source[self.position]
            if c >= '0' and c <= '9' then
                self.position += 1
                self.column += 1
            elseif c == '.' and !is_float then
                is_float = true
                self.position += 1
                self.column += 1
            else
                break
            end
        end
        
        var kind := if is_float then TokenKind.LIT_FLOAT else TokenKind.LIT_INTEGER
        
        return Token {
            .kind = kind,
            .start = start,
            .end = self.position,
            .line = line,
            .column = col,
        }
    end
    
    /* Read a string literal */
    function read_string(self: *Lexer, start: usize, line: u32, col: u32): Token
    begin
        self.position += 1  /* Skip opening " */
        self.column += 1
        
        while self.position < self.source.len() do
            var c := self.source[self.position]
            if c == '"' then
                self.position += 1
                self.column += 1
                break
            end
            if c == '\\' then
                self.position += 2
                self.column += 2
            else
                if c == '\n' then
                    self.line += 1
                    self.column = 1
                else
                    self.column += 1
                end
                self.position += 1
            end
        end
        
        return Token {
            .kind = TokenKind.LIT_STRING,
            .start = start,
            .end = self.position,
            .line = line,
            .column = col,
        }
    end
    
    /* Read a character literal */
    function read_char(self: *Lexer, start: usize, line: u32, col: u32): Token
    begin
        self.position += 1  /* Skip opening ' */
        self.column += 1
        
        if self.position < self.source.len() then
            if self.source[self.position] == '\\' then
                self.position += 2
                self.column += 2
            else
                self.position += 1
                self.column += 1
            end
        end
        
        if self.position < self.source.len() and self.source[self.position] == '\'' then
            self.position += 1
            self.column += 1
        end
        
        return Token {
            .kind = TokenKind.LIT_CHAR,
            .start = start,
            .end = self.position,
            .line = line,
            .column = col,
        }
    end
    
    /* Read a regular comment /* ... */ */
    function read_regular_comment(self: *Lexer, start: usize, line: u32, col: u32): Token
    begin
        self.position += 2  /* Skip /* */
        var depth: u32 = 1
        
        while depth > 0 and self.position < self.source.len() do
            if self.position + 1 < self.source.len() and
               self.source[self.position] == '/' and
               self.source[self.position + 1] == '*' then
                depth += 1
                self.position += 2
            elseif self.position + 1 < self.source.len() and
                   self.source[self.position] == '*' and
                   self.source[self.position + 1] == '/' then
                depth -= 1
                self.position += 2
            else
                if self.source[self.position] == '\n' then
                    self.line += 1
                    self.column = 1
                else
                    self.column += 1
                end
                self.position += 1
            end
        end
        
        return Token {
            .kind = TokenKind.COMMENT_REGULAR,
            .start = start,
            .end = self.position,
            .line = line,
            .column = col,
        }
    end
    
    /* Read a documentation comment /// ... */
    function read_doc_comment(self: *Lexer, start: usize, line: u32, col: u32): Token
    begin
        self.position += 3  /* Skip /// */
        
        while self.position < self.source.len() do
            var c := self.source[self.position]
            if c == '\n' then
                break
            end
            self.position += 1
            self.column += 1
        end
        
        return Token {
            .kind = TokenKind.COMMENT_DOC,
            .start = start,
            .end = self.position,
            .line = line,
            .column = col,
        }
    end
    
    /* Read a block documentation comment */
    function read_doc_comment_block(self: *Lexer, start: usize, line: u32, col: u32): Token
    begin
        self.position += 3  /* Skip /// */
        
        /* Read first line */
        while self.position < self.source.len() do
            var c := self.source[self.position]
            if c == '\n' then
                self.position += 1
                self.line += 1
                self.column = 1
                break
            end
            self.position += 1
            self.column += 1
        end
        
        /* Read subsequent lines starting with /// */
        while self.position + 2 < self.source.len() and
              self.source[self.position] == '/' and
              self.source[self.position + 1] == '/' and
              self.source[self.position + 2] == '/' do
            self.position += 3
            self.column += 3
            
            while self.position < self.source.len() do
                var c := self.source[self.position]
                if c == '\n' then
                    self.position += 1
                    self.line += 1
                    self.column = 1
                    break
                end
                self.position += 1
                self.column += 1
            end
        end
        
        return Token {
            .kind = TokenKind.COMMENT_DOC_BLOCK,
            .start = start,
            .end = self.position,
            .line = line,
            .column = col,
        }
    end
    
    /* Read an operator or punctuation */
    function read_operator(self: *Lexer, start: usize, line: u32, col: u32): Token
    begin
        var c := self.source[self.position]
        self.position += 1
        self.column += 1
        
        /* Two-character operators */
        if self.position < self.source.len() then
            var next := self.source[self.position]
            var two_char := [c, next]
            
            var kind := self.two_char_to_kind(two_char)
            if kind != null then
                self.position += 1
                self.column += 1
                return Token {
                    .kind = kind,
                    .start = start,
                    .end = self.position,
                    .line = line,
                    .column = col,
                }
            end
        end
        
        /* Single-character operators */
        var kind := self.single_char_to_kind(c) ?? TokenKind.ERROR
        
        return Token {
            .kind = kind,
            .start = start,
            .end = self.position,
            .line = line,
            .column = col,
        }
    end
    
    /* Skip whitespace characters */
    function skip_whitespace(self: *Lexer)
    begin
        while self.position < self.source.len() do
            var c := self.source[self.position]
            if c == ' ' or c == '\t' then
                self.position += 1
                self.column += 1
            elseif c == '\n' then
                self.position += 1
                self.line += 1
                self.column = 1
            else
                break
            end
        end
    end
    
    /* Peek at the next character */
    function peek(self: *Lexer): u8
    begin
        if self.position + 1 < self.source.len() then
            return self.source[self.position + 1]
        end
        return 0
    end
    
    /* Peek at a character with offset */
    function peek_offset(self: *Lexer, offset: usize): u8
    begin
        if self.position + offset < self.source.len() then
            return self.source[self.position + offset]
        end
        return 0
    end
    
    /* Convert keyword text to TokenKind */
    function keyword_to_kind(self: *Lexer, text: []u8): ?TokenKind
    begin
        match text {
            "module" => return TokenKind.KW_MODULE,
            "use" => return TokenKind.KW_USE,
            "export" => return TokenKind.KW_EXPORT,
            "var" => return TokenKind.KW_VAR,
            "const" => return TokenKind.KW_CONST,
            "function" => return TokenKind.KW_FUNCTION,
            "procedure" => return TokenKind.KW_PROCEDURE,
            "type" => return TokenKind.KW_TYPE,
            "struct" => return TokenKind.KW_STRUCT,
            "enum" => return TokenKind.KW_ENUM,
            "begin" => return TokenKind.KW_BEGIN,
            "end" => return TokenKind.KW_END,
            "if" => return TokenKind.KW_IF,
            "then" => return TokenKind.KW_THEN,
            "elsif" => return TokenKind.KW_ELSIF,
            "else" => return TokenKind.KW_ELSE,
            "for" => return TokenKind.KW_FOR,
            "while" => return TokenKind.KW_WHILE,
            "do" => return TokenKind.KW_DO,
            "loop" => return TokenKind.KW_LOOP,
            "break" => return TokenKind.KW_BREAK,
            "continue" => return TokenKind.KW_CONTINUE,
            "return" => return TokenKind.KW_RETURN,
            "match" => return TokenKind.KW_MATCH,
            "as" => return TokenKind.KW_AS,
            "null" => return TokenKind.KW_NULL,
            "true" => return TokenKind.KW_TRUE,
            "false" => return TokenKind.KW_FALSE,
            "own" => return TokenKind.KW_OWN,
            "ref" => return TokenKind.KW_REF,
            "mut" => return TokenKind.KW_MUT,
            "rc" => return TokenKind.KW_RC,
            "weak" => return TokenKind.KW_WEAK,
            "iso" => return TokenKind.KW_ISO,
            "trn" => return TokenKind.KW_TRN,
            "val" => return TokenKind.KW_VAL,
            "box" => return TokenKind.KW_BOX,
            "tag" => return TokenKind.KW_TAG,
            "actor" => return TokenKind.KW_ACTOR,
            "behavior" => return TokenKind.KW_BEHAVIOR,
            "spawn" => return TokenKind.KW_SPAWN,
            "await" => return TokenKind.KW_AWAIT,
            "async" => return TokenKind.KW_ASYNC,
            "defer" => return TokenKind.KW_DEFER,
            "unsafe" => return TokenKind.KW_UNSAFE,
            "safe" => return TokenKind.KW_SAFE,
            else => return null,
        }
    end
    
    /* Convert single character to TokenKind */
    function single_char_to_kind(self: *Lexer, c: u8): ?TokenKind
    begin
        match c {
            '+' => return TokenKind.OP_PLUS,
            '-' => return TokenKind.OP_MINUS,
            '*' => return TokenKind.OP_STAR,
            '/' => return TokenKind.OP_SLASH,
            '%' => return TokenKind.OP_PERCENT,
            '=' => return TokenKind.OP_ASSIGN,
            '<' => return TokenKind.OP_LESS,
            '>' => return TokenKind.OP_GREATER,
            '&' => return TokenKind.OP_BIT_AND,
            '|' => return TokenKind.OP_BIT_OR,
            '^' => return TokenKind.OP_BIT_XOR,
            '~' => return TokenKind.OP_BIT_NOT,
            '.' => return TokenKind.OP_DOT,
            ',' => return TokenKind.OP_COMMA,
            ';' => return TokenKind.OP_SEMICOLON,
            ':' => return TokenKind.OP_COLON,
            '(' => return TokenKind.OP_LPAREN,
            ')' => return TokenKind.OP_RPAREN,
            '[' => return TokenKind.OP_LBRACKET,
            ']' => return TokenKind.OP_RBRACKET,
            '{' => return TokenKind.OP_LBRACE,
            '}' => return TokenKind.OP_RBRACE,
            else => return null,
        }
    end
    
    /* Convert two characters to TokenKind */
    function two_char_to_kind(self: *Lexer, chars: [2]u8): ?TokenKind
    begin
        if chars[0] == ':' and chars[1] == '=' then
            return TokenKind.OP_COLON_EQUALS
        elseif chars[0] == '+' and chars[1] == '=' then
            return TokenKind.OP_PLUS_EQUALS
        elseif chars[0] == '-' and chars[1] == '=' then
            return TokenKind.OP_MINUS_EQUALS
        elseif chars[0] == '*' and chars[1] == '=' then
            return TokenKind.OP_STAR_EQUALS
        elseif chars[0] == '/' and chars[1] == '=' then
            return TokenKind.OP_SLASH_EQUALS
        elseif chars[0] == '%' and chars[1] == '=' then
            return TokenKind.OP_PERCENT_EQUALS
        elseif chars[0] == '=' and chars[1] == '=' then
            return TokenKind.OP_EQUALS_EQUALS
        elseif chars[0] == '!' and chars[1] == '=' then
            return TokenKind.OP_NOT_EQUALS
        elseif chars[0] == '<' and chars[1] == '=' then
            return TokenKind.OP_LESS_EQUALS
        elseif chars[0] == '>' and chars[1] == '=' then
            return TokenKind.OP_GREATER_EQUALS
        elseif chars[0] == '&' and chars[1] == '&' then
            return TokenKind.OP_AND
        elseif chars[0] == '|' and chars[1] == '|' then
            return TokenKind.OP_OR
        elseif chars[0] == '<' and chars[1] == '<' then
            return TokenKind.OP_SHIFT_LEFT
        elseif chars[0] == '>' and chars[1] == '>' then
            return TokenKind.OP_SHIFT_RIGHT
        elseif chars[0] == '.' and chars[1] == '.' then
            return TokenKind.OP_RANGE
        elseif chars[0] == '-' and chars[1] == '>' then
            return TokenKind.OP_ARROW
        else
            return null
        end
    end
}
