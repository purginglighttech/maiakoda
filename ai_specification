1.4 Bootstrap Compiler Implementation Details

1.4.1 Main Entry Point (Zig)

```zig
// bootstrap/src/main.zig
const std = @import("std");
const lexer = @import("lexer.zig");
const parser = @import("parser.zig");
const sema = @import("sema.zig");
const codegen = @import("codegen/x86_64.zig");

pub fn main() !void {
    var gpa = std.heap.GeneralPurposeAllocator(.{}){};
    defer _ = gpa.deinit();
    const allocator = gpa.allocator();

    // Parse command line arguments
    var args = std.process.args();
    _ = args.skip(); // skip program name
    const input_file = args.next() orelse {
        std.debug.print("Usage: maia <file.maia>\n", .{});
        return error.MissingInput;
    };

    // Read source file
    const source = try std.fs.cwd().readFileAlloc(allocator, input_file, std.math.maxInt(usize));
    defer allocator.free(source);

    // Lexical analysis
    var lex = lexer.Lexer.init(source);
    var tokens = try lex.tokenize(allocator);
    defer tokens.deinit();

    // Parse
    var pars = parser.Parser.init(tokens.items);
    const ast = try pars.parse(allocator);
    defer ast.deinit();

    // Semantic analysis
    var sem = sema.Analyzer.init(allocator);
    try sem.analyze(ast);

    // Code generation
    var output = std.ArrayList(u8).init(allocator);
    defer output.deinit();

    var gen = codegen.Generator.init(allocator, &output);
    try gen.generate(ast);

    // Write output
    const output_file = try std.fs.cwd().createFile("a.out", .{});
    defer output_file.close();
    try output_file.writeAll(output.items);
}
```

