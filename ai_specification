4.3 Documentation Reader Implementation (Koda)

```koda
# bin/mkdocs.koda - TUI documentation reader
import Koda.Terminal
import Koda.Markdown
import Koda.FS
import Koda.Search

# Main documentation reader application
function main(args: []string)
begin
    var docs_path := args[1] ?? "./docs"
    
    # Initialize terminal
    Terminal.init_raw_mode()
    defer Terminal.restore()
    
    # Load documentation index
    var index := load_documentation_index(docs_path)
    if index == null then
        writeln(stderr, "Error: No documentation found in ", docs_path)
        exit(1)
    end
    
    # Create documentation reader
    var reader := DocReader.create(index)
    
    # Run the reader
    reader.run()
end

# Documentation reader
type DocReader = struct {
    index: DocIndex,
    current_page: Page,
    history: array(string),
    history_position: usize,
    search_results: array(SearchResult),
    search_query: string,
    keybindings: Keymap,
}

impl DocReader {
    function create(index: DocIndex): own DocReader
    begin
        var reader := DocReader {
            .index = index,
            .current_page = index.pages[0],
            .history = array(string).create(),
            .history_position = -1,
            .search_results = array(SearchResult).create(),
            .search_query = "",
            .keybindings = Keymap.create(),
        }
        
        reader.setup_keybindings()
        
        return reader
    end
    
    function run(self: *DocReader)
    begin
        Terminal.clear()
        
        loop {
            # Render current page
            self.render()
            
            # Get input
            var key := Terminal.read_key()
            
            # Handle input
            var action := self.keybindings.get(key)
            
            match action {
                "quit" => break,
                "next_page" => self.next_page(),
                "prev_page" => self.prev_page(),
                "scroll_down" => self.scroll(10),
                "scroll_up" => self.scroll(-10),
                "page_down" => self.page_down(),
                "page_up" => self.page_up(),
                "top" => self.go_to_top(),
                "bottom" => self.go_to_bottom(),
                "search" => self.start_search(),
                "next_search" => self.next_search_result(),
                "prev_search" => self.prev_search_result(),
                "history_back" => self.history_back(),
                "history_forward" => self.history_forward(),
                "table_of_contents" => self.show_toc(),
                "help" => self.show_help(),
                else => {}
            }
        end
    end
    
    function render(self: *DocReader)
    begin
        Terminal.clear()
        
        # Get terminal dimensions
        var width := Terminal.width()
        var height := Terminal.height()
        
        # Render header
        self.render_header(width)
        
        # Render content area
        var content_height := height - 3
        var content := self.current_page.render_markdown(width, self.scroll_offset)
        Terminal.write_at(0, 1, content)
        
        # Clear remaining lines
        for i in content.len() + 1..content_height - 1 do
            Terminal.write_at(0, i, " " * width)
        end
        
        # Render footer
        self.render_footer(width)
        
        # Render search bar if active
        if self.search_active then
            self.render_search_bar(width)
        end
    end
    
    function render_header(self: *DocReader, width: i32)
    begin
        var title := "📚 " ++ self.index.title ++ " - " ++ self.current_page.title
        var line := "─" * (width - title.len() - 2)
        
        Terminal.set_attribute(.Bold)
        Terminal.write_at(0, 0, title)
        Terminal.write_at(title.len() + 1, 0, line)
        Terminal.reset_attributes()
    end
    
    function render_footer(self: *DocReader, width: i32)
    begin
        var height := Terminal.height()
        var status := "Page " ++ (self.current_page.index + 1).to_string() ++ 
                      " of " ++ self.index.pages.len().to_string()
        var help := "[q]uit [h]istory [s]earch [?]help"
        var space := width - status.len() - help.len() - 2
        
        Terminal.write_at(0, height - 1, status)
        Terminal.write_at(status.len() + 1 + space, height - 1, help)
    end
    
    function render_search_bar(self: *DocReader, width: i32)
    begin
        var height := Terminal.height()
        var prompt := "🔍 Search: "
        var input_line := prompt ++ self.search_query
        
        Terminal.set_attribute(.Reverse)
        Terminal.write_at(0, height - 2, input_line + " " * (width - input_line.len()))
        Terminal.reset_attributes()
        
        # Position cursor at end of query
        Terminal.move_cursor(prompt.len() + self.search_query.len(), height - 2)
    end
    
    function load_documentation_index(path: string): ?DocIndex
    begin
        # Look for mkdocs.toml or README.md
        var config_path := path ++ "/mkdocs.toml"
        
        if FS.exists(config_path) then
            var config := TOML.parse_file(config_path)
            return DocIndex.from_config(config)
        else
            # Auto-discover markdown files
            var files := FS.glob(path ++ "/**/*.md")
            var pages := array(Page).create()
            
            for file in files do
                var content := FS.read_file(file)
                var title := extract_title(content)
                
                pages.append(Page {
                    .path = file,
                    .title = title,
                    .content = content,
                })
            end
            
            return DocIndex {
                .title = FS.basename(path),
                .pages = pages,
            }
        end
    end
}

# Markdown to terminal renderer
type MarkdownRenderer = struct {
    width: i32,
    scroll: i32,
}

impl MarkdownRenderer {
    function render(self: *MarkdownRenderer, markdown: string): string
    begin
        var tokens := Markdown.parse(markdown)
        var output := ""
        var indent := 0
        
        for token in tokens do
            match token.type {
                .Heading1 => {
                    output += "\n" + "=" * self.width + "\n"
                    output += self.center_text(token.text) + "\n"
                    output += "=" * self.width + "\n\n"
                }
                .Heading2 => {
                    output += "\n" + "─" * self.width + "\n"
                    output += self.center_text(token.text) + "\n"
                    output += "─" * self.width + "\n\n"
                }
                .Heading3 => {
                    output += "\n🔹 " ++ token.text ++ "\n\n"
                }
                .Paragraph => {
                    output += self.wrap_text(token.text, self.width) + "\n\n"
                }
                .CodeBlock => {
                    output += "┌" + "─" * (self.width - 2) + "┐\n"
                    
                    var lines := token.text.split("\n")
                    for line in lines do
                        output += "│ " + line + " " * (self.width - line.len() - 3) + "│\n"
                    end
                    
                    output += "└" + "─" * (self.width - 2) + "┘\n\n"
                }
                .InlineCode => {
                    output += "`" + token.text + "`"
                }
                .Link => {
                    output += "\x1b[34m" + token.text + "\x1b[0m"  # Blue color
                }
                .List => {
                    for item in token.items do
                        output += "• " + item + "\n"
                    end
                    output += "\n"
                }
                .Table => {
                    output += self.render_table(token, self.width) + "\n"
                }
                .Blockquote => {
                    for line in token.text.split("\n") do
                        output += "│ " + line + "\n"
                    end
                    output += "\n"
                }
                else => {
                    output += token.text
                }
            }
        end
        
        return output
    end
    
    function wrap_text(self: *MarkdownRenderer, text: string, width: i32): string
    begin
        var words := text.split(" ")
        var lines := array(string).create()
        var current_line := ""
        
        for word in words do
            if current_line.len() + word.len() + 1 <= width then
                if current_line.len() > 0 then
                    current_line += " "
                end
                current_line += word
            else
                lines.append(current_line)
                current_line := word
            end
        end
        
        if current_line.len() > 0 then
            lines.append(current_line)
        end
        
        return lines.join("\n")
    end
    
    function center_text(self: *MarkdownRenderer, text: string): string
    begin
        var padding := (self.width - text.len()) / 2
        return " " * padding + text
    end
    
    function render_table(self: *MarkdownRenderer, token: TableToken, width: i32): string
    begin
        var output := ""
        
        # Calculate column widths
        var col_widths := array(i32).create()
        for i in 0..token.headers.len() - 1 do
            var max_width := token.headers[i].len()
            for row in token.rows do
                if row[i].len() > max_width then
                    max_width = row[i].len()
                end
            end
            col_widths.append(max_width + 2)
        end
        
        # Render header
        for i in 0..token.headers.len() - 1 do
            output += "│ " + token.headers[i] + " " * (col_widths[i] - token.headers[i].len() - 1)
        end
        output += "│\n"
        
        # Render separator
        for i in 0..token.headers.len() - 1 do
            output += "├" + "─" * col_widths[i]
        end
        output += "┤\n"
        
        # Render rows
        for row in token.rows do
            for i in 0..row.len() - 1 do
                output += "│ " + row[i] + " " * (col_widths[i] - row[i].len() - 1)
            end
            output += "│\n"
        end
        
        return output
    end
}

# Search functionality
function search_documentation(index: DocIndex, query: string): []SearchResult
begin
    var results := array(SearchResult).create()
    var terms := query.to_lower().split(" ")
    
    for page in index.pages do
        var score := 0
        var content := page.content.to_lower()
        
        for term in terms do
            if page.title.to_lower().contains(term) then
                score += 10
            end
            
            var count := content.count(term)
            score += count
        end
        
        if score > 0 then
            results.append(SearchResult {
                .page = page,
                .score = score,
                .excerpt = extract_excerpt(content, terms[0]),
            })
        end
    end
    
    # Sort by score descending
    results.sort(|a, b| b.score - a.score)
    
    return results
end
