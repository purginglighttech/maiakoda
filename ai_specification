2.4 Grammar (Maia)

```ebnf
(* Core syntax *)
program         = { module }
module          = "module" ident ";" { declaration }

declaration     = var_decl | const_decl | func_decl | proc_decl | type_decl

var_decl        = "var" ident { "," ident } ":" type [ "=" expr ]
const_decl      = "const" ident ":" type "=" expr
func_decl       = [ "async" ] "function" ident "(" [ params ] ")" ":" type [ ";" ] block
proc_decl       = [ "async" ] "procedure" ident "(" [ params ] ")" [ ";" ] block
type_decl       = "type" ident "=" type

block           = "begin" { statement } "end"

statement       = assignment | if_stmt | for_stmt | while_stmt | match_stmt
                | return_stmt | defer_stmt | expr ";"

assignment      = ident [ "[" expr "]" ] assign_op expr
assign_op       = ":=" | "+=" | "-=" | "*=" | "/=" | "%="

if_stmt         = "if" expr "then" block { "elsif" expr "then" block } [ "else" block ] "end"

for_stmt        = "for" ident "in" range "do" block "end"
                | "for" ident "," ident "in" expr "do" block "end"

while_stmt      = "while" expr "do" block "end"

match_stmt      = "match" expr "{" { match_case } "}"
match_case      = pattern "=>" block ","

return_stmt     = "return" [ expr ]

defer_stmt      = "defer" expr

(* Ownership *)
type            = primitive_type | composite_type | qualified_type
qualified_type  = [ "own" | "ref" | "mut" | "rc" | "weak" ] type

(* Concurrency *)
actor_decl      = "actor" ident "{" { behavior_decl | field_decl } "}"
behavior_decl   = "behavior" ident "(" [ params ] ")" block
channel_decl    = "channel(" type ")"
spawn_stmt      = "spawn" expr
await_expr      = "await" expr

(* Safety *)
safe_block      = "safe" "do" block "end"
unsafe_block    = "unsafe" "do" block "end"

(* FFI *)
extern_decl     = "extern" string_literal function_decl
link_attr       = "@link(" string_literal [ "," "static:" bool ] ")"
export_attr     = "@export(" string_literal [ "," "name:" string_literal ] ")"

(* Comptime *)
comptime_attr   = "@comptime"
comptime_func   = "@comptime" function_decl
comptime_if     = "if" "@comptime(" expr ")" then block "else" block "end"
```

