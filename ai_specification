3.3.2 Extension System

```pascal
/* editors/mkedit/src/extensions.maia - Extension system */
module Editor.Extensions

export type Extension = struct {
    name: string,
    version: string,
    author: string,
    description: string,
    commands: own array(Command),
    keymaps: own array(KeymapEntry),
    hooks: own array(Hook),
}

export type Command = struct {
    name: string,
    description: string,
    execute: fn(args: []string),
}

export type KeymapEntry = struct {
    mode: EditorMode,
    key: string,
    action: string,
}

/* Maia syntax highlighting extension */
export function maia_syntax_extension_init(editor: *Editor)
begin
    var ext := Extension {
        .name = "maia-syntax",
        .version = "1.0.0",
        .author = "Purging Light Technologies",
        .description = "Maia language syntax highlighting",
        .commands = array(Command).create(),
        .keymaps = array(KeymapEntry).create(),
        .hooks = array(Hook).create(),
    }
    
    /* Register syntax highlighter */
    var highlighter := MaiaSyntaxHighlighter.create()
    editor.register_syntax_highlighter("maia", highlighter)
    
    /* Register file type detection */
    editor.register_file_type("*.maia", "maia")
    
    editor.register_extension(ext)
end

/* LSP client extension */
export function lsp_extension_init(editor: *Editor)
begin
    var ext := Extension {
        .name = "lsp-client",
        .version = "1.0.0",
        .author = "Purging Light Technologies",
        .description = "Language Server Protocol client",
        .commands = array(Command).create(),
