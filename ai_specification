1.4.3 Parser Implementation (Zig)

```zig
// bootstrap/src/parser.zig
const std = @import("std");
const lexer = @import("lexer.zig");

pub const ASTNode = union(enum) {
    Program: struct {
        modules: []Module,
        statements: []Statement,
    },
    Module: struct {
        name: []const u8,
        declarations: []Declaration,
    },
    Declaration: union(enum) {
        Variable: VariableDecl,
        Constant: ConstantDecl,
        Function: FunctionDecl,
        Procedure: ProcedureDecl,
        Type: TypeDecl,
        Actor: ActorDecl,
    },
    VariableDecl: struct {
        name: []const u8,
        type: ?Type,
        init: ?Expression,
        mutability: Mutability,
        ownership: Ownership,
    },
    ConstantDecl: struct {
        name: []const u8,
        type: Type,
        value: Expression,
    },
    FunctionDecl: struct {
        name: []const u8,
        parameters: []Parameter,
        return_type: ?Type,
        body: Block,
        is_async: bool,
        is_comptime: bool,
        doc_comment: ?[]const u8,
    },
    // ... additional AST node definitions
};

pub const Parser = struct {
    tokens: []lexer.Token,
    position: usize,
    
    pub fn init(tokens: []lexer.Token) Parser {
        return Parser{
            .tokens = tokens,
            .position = 0,
        };
    }
    
    pub fn parse(self: *Parser, allocator: std.mem.Allocator) !ASTNode {
        var program = ASTNode.Program{
            .modules = try allocator.alloc(ASTNode.Module, 0),
            .statements = try allocator.alloc(ASTNode.Statement, 0),
        };
        
        while (!self.isAtEnd()) {
            self.skipWhitespaceAndDocs();
            if (self.isAtEnd()) break;
            
            if (self.peek().kind == lexer.TokenKind.KW_MODULE) {
                const module = try self.parseModule(allocator);
                // Add to program.modules
            } else {
                const decl = try self.parseDeclaration(allocator);
                // Add to program.statements
            }
        }
        
        return ASTNode{ .Program = program };
    }
    
    fn parseModule(self: *Parser, allocator: std.mem.Allocator) !ASTNode.Module {
        self.expect(lexer.TokenKind.KW_MODULE);
        const name_token = self.expect(lexer.TokenKind.IDENTIFIER);
        const name = name_token.text(self.tokens);
        
        var declarations = std.ArrayList(ASTNode.Declaration).init(allocator);
        
        while (!self.isAtEnd()) {
            self.skipWhitespaceAndDocs();
            if (self.peek().kind == lexer.TokenKind.KW_EXPORT or
                self.peek().kind == lexer.TokenKind.KW_VAR or
                self.peek().kind == lexer.TokenKind.KW_CONST or
                self.peek().kind == lexer.TokenKind.KW_FUNCTION or
                self.peek().kind == lexer.TokenKind.KW_PROCEDURE or
                self.peek().kind == lexer.TokenKind.KW_TYPE or
                self.peek().kind == lexer.TokenKind.KW_ACTOR) {
                const decl = try self.parseDeclaration(allocator);
                try declarations.append(decl);
            } else {
                break;
            }
        }
        
        return ASTNode.Module{
            .name = name,
            .declarations = try declarations.toOwnedSlice(),
        };
    }
    
    fn parseDeclaration(self: *Parser, allocator: std.mem.Allocator) !ASTNode.Declaration {
        const doc_comment = self.captureDocComment();
        
        switch (self.peek().kind) {
            lexer.TokenKind.KW_VAR => return self.parseVariableDecl(allocator, doc_comment),
            lexer.TokenKind.KW_CONST => return self.parseConstantDecl(allocator, doc_comment),
            lexer.TokenKind.KW_FUNCTION => return self.parseFunctionDecl(allocator, doc_comment),
            lexer.TokenKind.KW_PROCEDURE => return self.parseProcedureDecl(allocator, doc_comment),
            lexer.TokenKind.KW_TYPE => return self.parseTypeDecl(allocator, doc_comment),
            lexer.TokenKind.KW_ACTOR => return self.parseActorDecl(allocator, doc_comment),
            else => return error.UnexpectedToken,
        }
    }
    
    fn parseVariableDecl(self: *Parser, allocator: std.mem.Allocator, doc_comment: ?[]const u8) !ASTNode.Declaration {
        self.expect(lexer.TokenKind.KW_VAR);
        const name_token = self.expect(lexer.TokenKind.IDENTIFIER);
        const name = name_token.text(self.tokens);
        
        var var_type: ?Type = null;
        var init: ?Expression = null;
        
        if (self.peek().kind == lexer.TokenKind.OP_COLON) {
            self.advance();
            var_type = try self.parseType(allocator);
        }
        
        if (self.peek().kind == lexer.TokenKind.OP_COLON_EQUALS or
            self.peek().kind == lexer.TokenKind.OP_ASSIGN) {
            self.advance();
            init = try self.parseExpression(allocator);
        }
        
        self.expect(lexer.TokenKind.OP_SEMICOLON);
        
        return ASTNode.Declaration{
            .Variable = ASTNode.VariableDecl{
                .name = name,
                .type = var_type,
                .init = init,
                .mutability = .Immutable,
                .ownership = .Own,
            },
        };
    }
    
    fn parseFunctionDecl(self: *Parser, allocator: std.mem.Allocator, doc_comment: ?[]const u8) !ASTNode.Declaration {
        var is_async = false;
        var is_comptime = false;
        
        // Check for async keyword
        if (self.peek().kind == lexer.TokenKind.KW_ASYNC) {
            is_async = true;
            self.advance();
        }
        
        // Check for comptime attribute
        if (self.peek().kind == lexer.TokenKind.KW_COMPTIME) {
            is_comptime = true;
            self.advance();
        }
        
        self.expect(lexer.TokenKind.KW_FUNCTION);
        const name_token = self.expect(lexer.TokenKind.IDENTIFIER);
        const name = name_token.text(self.tokens);
        
        self.expect(lexer.TokenKind.OP_LPAREN);
        var params = std.ArrayList(ASTNode.Parameter).init(allocator);
        
        if (self.peek().kind != lexer.TokenKind.OP_RPAREN) {
            while (true) {
                const param = try self.parseParameter(allocator);
                try params.append(param);
                if (self.peek().kind != lexer.TokenKind.OP_COMMA) break;
                self.advance();
            }
        }
        
        self.expect(lexer.TokenKind.OP_RPAREN);
        
        var return_type: ?Type = null;
        if (self.peek().kind == lexer.TokenKind.OP_COLON) {
            self.advance();
            return_type = try self.parseType(allocator);
        }
        
        self.expect(lexer.TokenKind.KW_BEGIN);
        const body = try self.parseBlock(allocator);
        self.expect(lexer.TokenKind.KW_END);
        
        return ASTNode.Declaration{
            .Function = ASTNode.FunctionDecl{
                .name = name,
                .parameters = try params.toOwnedSlice(),
                .return_type = return_type,
                .body = body,
                .is_async = is_async,
                .is_comptime = is_comptime,
                .doc_comment = doc_comment,
            },
        };
    }
    
    fn parseBlock(self: *Parser, allocator: std.mem.Allocator) !ASTNode.Block {
        var statements = std.ArrayList(ASTNode.Statement).init(allocator);
        
        while (!self.isAtEnd()) {
            self.skipWhitespace();
            if (self.peek().kind == lexer.TokenKind.KW_END or
                self.peek().kind == lexer.TokenKind.KW_ELSIF or
                self.peek().kind == lexer.TokenKind.KW_ELSE) {
                break;
            }
            const stmt = try self.parseStatement(allocator);
            try statements.append(stmt);
        }
        
        return ASTNode.Block{
            .statements = try statements.toOwnedSlice(),
        };
    }
    
    fn parseExpression(self: *Parser, allocator: std.mem.Allocator) !Expression {
        return self.parseLogicalOr(allocator);
    }
    
    fn parseLogicalOr(self: *Parser, allocator: std.mem.Allocator) !Expression {
        var left = try self.parseLogicalAnd(allocator);
        
        while (self.peek().kind == lexer.TokenKind.OP_OR) {
            self.advance();
            const right = try self.parseLogicalAnd(allocator);
            left = Expression{
                .Binary = BinaryExpr{
                    .left = Box.create(left),
                    .op = .Or,
                    .right = Box.create(right),
                },
            };
        }
        
        return left;
    }
    
    // Additional parsing methods...
    
    fn expect(self: *Parser, kind: lexer.TokenKind) lexer.Token {
        const tok = self.peek();
        if (tok.kind != kind) {
            @panic("Expected token");
        }
        self.advance();
        return tok;
    }
    
    fn peek(self: *Parser) lexer.Token {
        return self.tokens[self.position];
    }
    
    fn advance(self: *Parser) void {
        if (self.position < self.tokens.len) {
            self.position += 1;
        }
    }
    
    fn isAtEnd(self: *Parser) bool {
        return self.position >= self.tokens.len or
               self.peek().kind == lexer.TokenKind.EOF;
    }
    
    fn skipWhitespace(self: *Parser) void {
        while (!self.isAtEnd()) {
            const tok = self.peek();
            if (tok.kind != lexer.TokenKind.WHITESPACE and
                tok.kind != lexer.TokenKind.COMMENT_REGULAR) {
                break;
            }
            self.advance();
        }
    }
    
    fn skipWhitespaceAndDocs(self: *Parser) void {
        while (!self.isAtEnd()) {
            const tok = self.peek();
            if (tok.kind == lexer.TokenKind.WHITESPACE or
                tok.kind == lexer.TokenKind.COMMENT_REGULAR) {
                self.advance();
            } else {
                break;
            }
        }
    }
    
    fn captureDocComment(self: *Parser) ?[]const u8 {
        const tok = self.peek();
        if (tok.kind == lexer.TokenKind.COMMENT_DOC or
            tok.kind == lexer.TokenKind.COMMENT_DOC_BLOCK) {
            self.advance();
            return tok.text(self.tokens);
        }
        return null;
    }
};
