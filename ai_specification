Part 2: Phase 0 - Maia Bootstrap Compiler (Zig)

2.1 Phase 0 Configuration

```toml
# phases/phase_0.toml
[phase]
name = "Maia Bootstrap Compiler"
duration_weeks = 6
language = "Zig"
output = "bootstrap/bin/maia"

[phase.directories]
src = "bootstrap/src"
tests = "bootstrap/tests"
lib = "bootstrap/lib"

[phase.components.lexer]
file = "bootstrap/src/lexer.zig"
tests = "bootstrap/tests/lexer_tests.zig"
depends_on = []

[phase.components.parser]
file = "bootstrap/src/parser.zig"
tests = "bootstrap/tests/parser_tests.zig"
depends_on = ["lexer"]

[phase.components.semantic_analyzer]
file = "bootstrap/src/sema.zig"
tests = "bootstrap/tests/sema_tests.zig"
