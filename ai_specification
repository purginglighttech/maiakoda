Part 11: Code Examples for AI Training

11.1 Maia Examples

```pascal
// Example 1: Hello World
module Main;

procedure main()
begin
    writeln("Hello, Maia!")
end

// Example 2: Ownership and Borrowing
module Ownership;

procedure example()
begin
    var a: own string := "hello"
    var b: ref string := &a
    var c: mut string := &mut a
    
    writeln(b)  // immutable borrow
    c := "world"  // mutable borrow
    // a is now "world"
end

// Example 3: Actor Concurrency
actor Counter {
    var _count: iso int32 := 0
    
    behavior increment()
    begin
        _count += 1
    end
    
    function get(): val int32
    begin
        return _count as val
    end
}

procedure main()
begin
    var c: tag Counter := Counter.create()
    spawn c.increment()
    spawn c.increment()
    wait()
    writeln(c.get())  // 2
end

// Example 4: Async/Await
async function fetch(url: string): string
begin
    var resp := await http.get(url)
    return resp.body
end

async procedure main()
begin
    var data := await fetch("https://api.example.com")
    writeln(data)
end

// Example 5: FFI to C
@link("c")
extern function printf(format: *u8, ...): int32

procedure main()
begin
    var msg := "Hello from Maia!\n"
    printf(msg)
end
```

