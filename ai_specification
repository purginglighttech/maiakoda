2.4 Self-Hosted Compiler Implementation (MaiaKoda)

2.4.1 Main Entry Point (Maia)

```pascal
/* compiler/src/main.maia
   Self-hosted MaiaKoda compiler entry point
*/

module Main

use System.Args
use System.FS
use System.Memory
use Compiler.Lexer
use Compiler.Parser
use Compiler.Sema
use Compiler.CodeGen

/* 
   Main compiler entry point
   @param argc Number of command line arguments
   @param argv Array of argument strings
   @param envp Environment variables
   @return Exit code (0 = success)
*/
procedure main(argc: i32, argv: **u8, envp: **u8): i32
begin
    /* Parse command line arguments */
    var args := Args.parse(argc, argv)
    
    if args.help then
        print_help()
        return 0
    end
    
    if args.version then
        print_version()
        return 0
    end
    
    /* Validate input file */
    if args.input_file == null then
        writeln(stderr, "Error: No input file specified")
        print_usage()
        return 1
    end
    
    /* Read source file */
    var source := FS.read_file(args.input_file)
    if source == null then
        writeln(stderr, "Error: Cannot read file: ", args.input_file)
        return 1
    end
    defer Memory.free(source)
    
    /* Run compiler phases */
    var lexer := Lexer.create(source)
    var tokens := lexer.tokenize()
    defer tokens.destroy()
    
    var parser := Parser.create(tokens)
    var ast := parser.parse()
    defer ast.destroy()
    
    var sema := Sema.create(ast)
    if !sema.analyze() then
        sema.print_errors()
        return 1
    end
    
    var codegen := CodeGen.create(ast, args.target, args.optimization)
    var output := codegen.generate()
    
    /* Write output file */
    var out_path := args.output_file ?? "a.out"
    var result := FS.write_file(out_path, output)
    
    if !result then
        writeln(stderr, "Error: Cannot write output file: ", out_path)
        return 1
    end
    
    return 0
end

/* Print compiler usage information */
procedure print_usage()
begin
    writeln("Usage: maia [options] <input.maia>")
    writeln()
    writeln("Options:")
    writeln("  -o <file>    Output file name")
    writeln("  --target     Target triple (x86_64, arm64, riscv64, wasm32)")
    writeln("  --opt        Optimization level (debug, release, size)")
    writeln("  --safety     Safety level (full, release, os, none)")
    writeln("  --help       Print this help message")
    writeln("  --version    Print version information")
end

/* Print compiler version */
procedure print_version()
begin
    writeln("MaiaKoda Compiler v1.0.0")
    writeln("Copyright (c) 2026 Purging Light Technologies")
    writeln("License: MIT")
end
