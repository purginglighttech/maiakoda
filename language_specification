Part 18: Complete Source Example

18.1 Maia Example

```pascal
/* math.maia
   This module provides basic mathematical functions
*/

module Math

/// Adds two integers together.
/// @param a The first number
/// @param b The second number
/// @return The sum of a and b
/// @example
/// var result := Math.add(5, 3)  /* result = 8 */
export function add(a: int32, b: int32): int32

///
/// Subtracts one integer from another.
/// 
/// @param a The number to subtract from
/// @param b The number to subtract
/// @return The difference a - b
/// @since 1.0.0
///
export function subtract(a: int32, b: int32): int32

/// The mathematical constant Pi
export const PI: f64 = 3.141592653589793

/* Implementation */
function add(a: int32, b: int32): int32
begin
    return a + b
end

function subtract(a: int32, b: int32): int32
begin
    return a - b
end

/// Main entry point
procedure main()
begin
    var sum := add(10, 20)
    var diff := subtract(100, 45)
    
    writeln("Sum: ", sum)
    writeln("Difference: ", diff)
end
```

18.2 Koda Example

```koda
/* webserver.koda - Simple web server */
import Koda.Web

/// Main web server application
procedure main()
begin
    var app := Web.Server.create()
    
    /// Handle root endpoint
    app.get("/", |req| {
        return "Hello, World!"
    })
    
    /// Handle JSON API
    app.get("/api/status", |req| {
        return {
            status = "ok",
            version = "1.0.0",
            timestamp = Time.now(),
        }
    })
    
    writeln("Server running on http://localhost:8080")
    app.listen(8080)
end
```

