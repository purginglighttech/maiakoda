// bootstrap/src/lexer.zig
const std = @import("std");

pub const TokenKind = enum {
    // Keywords
    KW_MODULE,
    KW_USE,
    KW_EXPORT,
    KW_VAR,
    KW_CONST,
    KW_FUNCTION,
    KW_PROCEDURE,
    KW_TYPE,
    KW_STRUCT,
    KW_ENUM,
    KW_BEGIN,
    KW_END,
    KW_IF,
    KW_THEN,
    KW_ELSIF,
    KW_ELSE,
    KW_FOR,
    KW_WHILE,
    KW_DO,
    KW_LOOP,
    KW_BREAK,
    KW_CONTINUE,
    KW_RETURN,
    KW_MATCH,
    KW_AS,
    KW_NULL,
    KW_TRUE,
    KW_FALSE,
    KW_OWN,
    KW_REF,
    KW_MUT,
    KW_RC,
    KW_WEAK,
    KW_ISO,
    KW_TRN,
    KW_VAL,
    KW_BOX,
    KW_TAG,
    KW_ACTOR,
    KW_BEHAVIOR,
    KW_SPAWN,
    KW_AWAIT,
    KW_ASYNC,
    KW_DEFER,
    KW_UNSAFE,
    KW_SAFE,
    
    // Operators
    OP_PLUS,
    OP_MINUS,
    OP_STAR,
    OP_SLASH,
    OP_PERCENT,
    OP_DOUBLE_SLASH,
    OP_ASSIGN,
    OP_COLON_EQUALS,
    OP_PLUS_EQUALS,
    OP_MINUS_EQUALS,
    OP_STAR_EQUALS,
    OP_SLASH_EQUALS,
    OP_PERCENT_EQUALS,
    OP_EQUALS_EQUALS,
    OP_NOT_EQUALS,
    OP_LESS,
    OP_GREATER,
    OP_LESS_EQUALS,
    OP_GREATER_EQUALS,
    OP_AND,
    OP_OR,
    OP_NOT,
    OP_BIT_AND,
    OP_BIT_OR,
    OP_BIT_XOR,
    OP_BIT_NOT,
    OP_SHIFT_LEFT,
    OP_SHIFT_RIGHT,
    OP_RANGE,
    OP_ARROW,
    OP_DOT,
    OP_COMMA,
    OP_SEMICOLON,
    OP_COLON,
    OP_LPAREN,
    OP_RPAREN,
    OP_LBRACKET,
    OP_RBRACKET,
    OP_LBRACE,
    OP_RBRACE,
    
    // Literals
    LIT_INTEGER,
    LIT_FLOAT,
    LIT_STRING,
    LIT_CHAR,
    
    // Other
    IDENTIFIER,
    COMMENT_REGULAR,
    COMMENT_DOC,
    COMMENT_DOC_BLOCK,
    WHITESPACE,
    ERROR,
    EOF,
};

pub const Token = struct {
    kind: TokenKind,
    start: usize,
    end: usize,
    line: u32,
    column: u32,
};

pub const Lexer = struct {
    source: []const u8,
    position: usize,
    line: u32,
    column: u32,
    
    pub fn init(source: []const u8) Lexer {
        return Lexer{
            .source = source,
            .position = 0,
            .line = 1,
            .column = 1,
        };
    }
    
    pub fn tokenize(self: *Lexer, allocator: std.mem.Allocator) !std.ArrayList(Token) {
        var tokens = std.ArrayList(Token).init(allocator);
        
        while (true) {
            const tok = self.nextToken() catch |err| {
                std.debug.print("Lexical error at line {}, column {}\n", .{self.line, self.column});
                return err;
            };
            try tokens.append(tok);
            if (tok.kind == TokenKind.EOF) break;
        }
        
        return tokens;
    }
    
    fn nextToken(self: *Lexer) !Token {
        self.skipWhitespace();
        
        if (self.position >= self.source.len) {
            return Token{
                .kind = TokenKind.EOF,
                .start = self.position,
                .end = self.position,
                .line = self.line,
                .column = self.column,
            };
        }
        
        const c = self.source[self.position];
        const start = self.position;
        const line = self.line;
        const col = self.column;
        
        // Identifiers and keywords
        if (std.ascii.isAlphabetic(c) or c == '_') {
            return self.readIdentifier(start, line, col);
        }
        
        // Numbers
        if (std.ascii.isDigit(c)) {
            return self.readNumber(start, line, col);
        }
        
        // Strings
        if (c == '"') {
            return self.readString(start, line, col);
        }
        
        // Characters
        if (c == '\'') {
            return self.readChar(start, line, col);
        }
        
        // Comments
        if (c == '/') {
            if (self.peek() == '*') {
                return self.readRegularComment(start, line, col);
            }
            if (self.peek() == '/') {
                if (self.peekOffset(2) == '/') {
                    return self.readDocCommentBlock(start, line, col);
                }
                return self.readDocComment(start, line, col);
            }
        }
        
        // Operators and punctuation
        return self.readOperator(start, line, col);
    }
    
    fn readIdentifier(self: *Lexer, start: usize, line: u32, col: u32) !Token {
        while (self.position < self.source.len) {
            const c = self.source[self.position];
            if (!std.ascii.isAlphanumeric(c) and c != '_') break;
            self.position += 1;
            self.column += 1;
        }
        
        const text = self.source[start..self.position];
        const kind = keywordMap.get(text) orelse TokenKind.IDENTIFIER;
        
        return Token{
            .kind = kind,
            .start = start,
            .end = self.position,
            .line = line,
            .column = col,
        };
    }
    
    fn readRegularComment(self: *Lexer, start: usize, line: u32, col: u32) !Token {
        self.position += 2; // skip /*
        var depth: u32 = 1;
        
        while (depth > 0 and self.position < self.source.len) {
            if (self.position + 1 < self.source.len and
                self.source[self.position] == '/' and
                self.source[self.position + 1] == '*') {
                depth += 1;
                self.position += 2;
            } else if (self.position + 1 < self.source.len and
                       self.source[self.position] == '*' and
                       self.source[self.position + 1] == '/') {
                depth -= 1;
                self.position += 2;
            } else {
                if (self.source[self.position] == '\n') {
                    self.line += 1;
                    self.column = 1;
                } else {
                    self.column += 1;
                }
                self.position += 1;
            }
        }
        
        return Token{
            .kind = TokenKind.COMMENT_REGULAR,
            .start = start,
            .end = self.position,
            .line = line,
            .column = col,
        };
    }
    
    fn readDocComment(self: *Lexer, start: usize, line: u32, col: u32) !Token {
        self.position += 3; // skip ///
        
        while (self.position < self.source.len) {
            const c = self.source[self.position];
            if (c == '\n') break;
            self.position += 1;
            self.column += 1;
        }
        
        return Token{
            .kind = TokenKind.COMMENT_DOC,
            .start = start,
            .end = self.position,
            .line = line,
            .column = col,
        };
    }
    
    fn readDocCommentBlock(self: *Lexer, start: usize, line: u32, col: u32) !Token {
        self.position += 3; // skip ///
        
        // Read first line
        while (self.position < self.source.len) {
            const c = self.source[self.position];
            if (c == '\n') {
                self.position += 1;
                self.line += 1;
                self.column = 1;
                break;
            }
            self.position += 1;
            self.column += 1;
        }
        
        // Read subsequent lines starting with ///
        while (self.position + 2 < self.source.len and
               self.source[self.position] == '/' and
               self.source[self.position + 1] == '/' and
               self.source[self.position + 2] == '/') {
            self.position += 3;
            self.column += 3;
            
            while (self.position < self.source.len) {
                const c = self.source[self.position];
                if (c == '\n') {
                    self.position += 1;
                    self.line += 1;
                    self.column = 1;
                    break;
                }
                self.position += 1;
                self.column += 1;
            }
        }
        
        return Token{
            .kind = TokenKind.COMMENT_DOC_BLOCK,
            .start = start,
            .end = self.position,
            .line = line,
            .column = col,
        };
    }
    
    fn readNumber(self: *Lexer, start: usize, line: u32, col: u32) !Token {
        var is_float = false;
        
        while (self.position < self.source.len) {
            const c = self.source[self.position];
            if (std.ascii.isDigit(c)) {
                self.position += 1;
                self.column += 1;
            } else if (c == '.' and !is_float) {
                is_float = true;
                self.position += 1;
                self.column += 1;
            } else {
                break;
            }
        }
        
        const kind = if (is_float) TokenKind.LIT_FLOAT else TokenKind.LIT_INTEGER;
        
        return Token{
            .kind = kind,
            .start = start,
            .end = self.position,
            .line = line,
            .column = col,
        };
    }
    
    fn readString(self: *Lexer, start: usize, line: u32, col: u32) !Token {
        self.position += 1; // skip opening "
        self.column += 1;
        
        while (self.position < self.source.len) {
            const c = self.source[self.position];
            if (c == '"') {
                self.position += 1;
                self.column += 1;
                break;
            }
            if (c == '\\') {
                self.position += 2;
                self.column += 2;
            } else {
                if (c == '\n') {
                    self.line += 1;
                    self.column = 1;
                } else {
                    self.column += 1;
                }
                self.position += 1;
            }
        }
        
        return Token{
            .kind = TokenKind.LIT_STRING,
            .start = start,
            .end = self.position,
            .line = line,
            .column = col,
        };
    }
    
    fn readChar(self: *Lexer, start: usize, line: u32, col: u32) !Token {
        self.position += 1; // skip opening '
        self.column += 1;
        
        if (self.position < self.source.len) {
            if (self.source[self.position] == '\\') {
                self.position += 2;
                self.column += 2;
            } else {
                self.position += 1;
                self.column += 1;
            }
        }
        
        if (self.position < self.source.len and self.source[self.position] == '\'') {
            self.position += 1;
            self.column += 1;
        }
        
        return Token{
            .kind = TokenKind.LIT_CHAR,
            .start = start,
            .end = self.position,
            .line = line,
            .column = col,
        };
    }
    
    fn readOperator(self: *Lexer, start: usize, line: u32, col: u32) !Token {
        const c = self.source[self.position];
        self.position += 1;
        self.column += 1;
        
        // Two-character operators
        if (self.position < self.source.len) {
            const next = self.source[self.position];
            const twoChar = [2]u8{ c, next };
            
            const twoCharKind = twoCharMap.get(twoChar);
            if (twoCharKind) |kind| {
                self.position += 1;
                self.column += 1;
                return Token{
                    .kind = kind,
                    .start = start,
                    .end = self.position,
                    .line = line,
                    .column = col,
                };
            }
        }
        
        // Single-character operators
        const kind = singleCharMap.get(c) orelse TokenKind.ERROR;
        
        return Token{
            .kind = kind,
            .start = start,
            .end = self.position,
            .line = line,
            .column = col,
        };
    }
    
    fn skipWhitespace(self: *Lexer) void {
        while (self.position < self.source.len) {
            const c = self.source[self.position];
            switch (c) {
                ' ', '\t' => {
                    self.position += 1;
                    self.column += 1;
                },
                '\n' => {
                    self.position += 1;
                    self.line += 1;
                    self.column = 1;
                },
                else => break,
            }
        }
    }
    
    fn peek(self: *Lexer) u8 {
        if (self.position + 1 < self.source.len) {
            return self.source[self.position + 1];
        }
        return 0;
    }
    
    fn peekOffset(self: *Lexer, offset: usize) u8 {
        if (self.position + offset < self.source.len) {
            return self.source[self.position + offset];
        }
        return 0;
    }
};

