/// Maia self-hosted compiler — lexer.
/// Produces a flat token stream from UTF-8 source text.
/// Block comments /* … */ may be nested.  Doc comments use /// syntax.

module Lexer

/* ── Token kind constants ────────────────────────────────────────────────────── */
/* Encoded as int32 so the bootstrap compiler can pattern-match on them. */

const TK_INT_LIT:    int32 = 0
const TK_FLOAT_LIT:  int32 = 1
const TK_STRING_LIT: int32 = 2
const TK_IDENT:      int32 = 3

/* Keywords */
const TK_MODULE:    int32 = 10
const TK_USE:       int32 = 11
const TK_EXPORT:    int32 = 12
const TK_VAR:       int32 = 13
const TK_CONST:     int32 = 14
const TK_FUNCTION:  int32 = 15
const TK_PROCEDURE: int32 = 16
const TK_TYPE:      int32 = 17
const TK_STRUCT:    int32 = 18
const TK_ENUM:      int32 = 19
const TK_BEGIN:     int32 = 20
const TK_END:       int32 = 21
const TK_IF:        int32 = 22
const TK_THEN:      int32 = 23
const TK_ELSIF:     int32 = 24
const TK_ELSE:      int32 = 25
const TK_FOR:       int32 = 26
const TK_WHILE:     int32 = 27
const TK_DO:        int32 = 28
const TK_LOOP:      int32 = 29
const TK_BREAK:     int32 = 30
const TK_CONTINUE:  int32 = 31
const TK_RETURN:    int32 = 32
const TK_MATCH:     int32 = 33
const TK_AS:        int32 = 34
const TK_NULL:      int32 = 35
const TK_TRUE:      int32 = 36
const TK_FALSE:     int32 = 37
const TK_OWN:       int32 = 38
const TK_REF:       int32 = 39
const TK_MUT:       int32 = 40
const TK_RC:        int32 = 41
const TK_WEAK:      int32 = 42
const TK_ISO:       int32 = 43
const TK_TRN:       int32 = 44
const TK_VAL:       int32 = 45
const TK_BOX:       int32 = 46
const TK_TAG:       int32 = 47
const TK_ACTOR:     int32 = 48
const TK_BEHAVIOR:  int32 = 49
const TK_SPAWN:     int32 = 50
const TK_AWAIT:     int32 = 51
const TK_ASYNC:     int32 = 52
const TK_DEFER:     int32 = 53
const TK_UNSAFE:    int32 = 54
const TK_SAFE:      int32 = 55
const TK_CONSUME:   int32 = 56
const TK_EXTERN:    int32 = 57
const TK_INLINE:    int32 = 58
const TK_PACKAGE:   int32 = 59
const TK_IN:        int32 = 60
const TK_WAIT:      int32 = 61
const TK_COMPTIME:  int32 = 62
const TK_AND:       int32 = 63
const TK_OR:        int32 = 64
const TK_NOT:       int32 = 65

/* Arithmetic operators */
const TK_PLUS:       int32 = 70
const TK_MINUS:      int32 = 71
const TK_STAR:       int32 = 72
const TK_SLASH:      int32 = 73
const TK_PERCENT:    int32 = 74
const TK_SLASH_SLASH:int32 = 75

/* Comparison operators */
const TK_EQ_EQ:  int32 = 80
const TK_BANG_EQ:int32 = 81
const TK_LT:     int32 = 82
const TK_GT:     int32 = 83
const TK_LT_EQ:  int32 = 84
const TK_GT_EQ:  int32 = 85

/* Bitwise operators */
const TK_AMP:   int32 = 90
const TK_PIPE:  int32 = 91
const TK_CARET: int32 = 92
const TK_TILDE: int32 = 93
const TK_LT_LT: int32 = 94
const TK_GT_GT: int32 = 95

/* Assignment operators */
const TK_COLON_EQ:  int32 = 100
const TK_PLUS_EQ:   int32 = 101
const TK_MINUS_EQ:  int32 = 102
const TK_STAR_EQ:   int32 = 103
const TK_SLASH_EQ:  int32 = 104
const TK_PERCENT_EQ:int32 = 105
const TK_AMP_EQ:    int32 = 106
const TK_PIPE_EQ:   int32 = 107
const TK_CARET_EQ:  int32 = 108
const TK_LT_LT_EQ:  int32 = 109
const TK_GT_GT_EQ:  int32 = 110

/* Range */
const TK_DOT_DOT:    int32 = 115
const TK_DOT_DOT_LT: int32 = 116

/* Misc */
const TK_EQ:               int32 = 120
const TK_BANG:             int32 = 121
const TK_QUESTION:         int32 = 122
const TK_QUESTION_QUESTION:int32 = 123
const TK_AT:               int32 = 124
const TK_ARROW:            int32 = 125
const TK_FAT_ARROW:        int32 = 126
const TK_DOT:              int32 = 127
const TK_DOT_DOT_DOT:      int32 = 128

/* Delimiters */
const TK_LPAREN:   int32 = 130
const TK_RPAREN:   int32 = 131
const TK_LBRACKET: int32 = 132
const TK_RBRACKET: int32 = 133
const TK_LBRACE:   int32 = 134
const TK_RBRACE:   int32 = 135
const TK_COMMA:    int32 = 136
const TK_SEMICOLON:int32 = 137
const TK_COLON:    int32 = 138

/* Synthetic */
const TK_DOC_COMMENT: int32 = 140
const TK_EOF:         int32 = 141
const TK_INVALID:     int32 = 142

/* ── Token ───────────────────────────────────────────────────────────────────── */

type Token = struct {
    kind:  int32,
    start: uint32,
    tok_end: uint32,
    line:  uint32,
    col:   uint32,
}

/* ── Token array (growable) ──────────────────────────────────────────────────── */

type TokenArray = struct {
    ptr:  uint64,  /* pointer to Token[] (8 bytes each — we pack kind+start+end+line+col as 5 × int32) */
    len:  uint32,
    cap:  uint32,
}

const TOKEN_BYTES: uint32 = 20  /* 5 × 4-byte fields per token */

extern function maia_mmap(len: uint64): uint64
extern function maia_exit(code: int32)
extern function store32(addr: uint64, v: int32)
extern function load32(addr: uint64): int32

function token_array_new(): TokenArray begin
    const initial_cap: uint32 = 256
    var ptr := maia_mmap((initial_cap as uint64) * TOKEN_BYTES as uint64)
    return TokenArray { .ptr = ptr, .len = 0, .cap = initial_cap }
end

procedure token_array_push(arr: mut TokenArray, tok: Token) begin
    if arr.len == arr.cap then
        const new_cap := arr.cap * 2
        var new_ptr := maia_mmap((new_cap as uint64) * TOKEN_BYTES as uint64)
        /* copy old data (no memcpy in bootstrap — use write loop) */
        var i: uint32 := 0
        while i < arr.len do
            var src_base := arr.ptr + (i as uint64) * TOKEN_BYTES as uint64
            var dst_base := new_ptr  + (i as uint64) * TOKEN_BYTES as uint64
            store32(dst_base,      load32(src_base))
            store32(dst_base + 4,  load32(src_base + 4))
            store32(dst_base + 8,  load32(src_base + 8))
            store32(dst_base + 12, load32(src_base + 12))
            store32(dst_base + 16, load32(src_base + 16))
            i := i + 1
        end
        arr.ptr := new_ptr
        arr.cap := new_cap
    end
    /* Store token fields at arr.ptr + arr.len * TOKEN_BYTES */
    var base := arr.ptr + (arr.len as uint64) * TOKEN_BYTES as uint64
    store32(base,      tok.kind)
    store32(base + 4,  tok.start as int32)
    store32(base + 8,  tok.tok_end as int32)
    store32(base + 12, tok.line as int32)
    store32(base + 16, tok.col as int32)
    arr.len := arr.len + 1
end

/* ── Keyword table ───────────────────────────────────────────────────────────── */
/* Returns the keyword TK_* constant for the given identifier slice, or TK_IDENT. */

function kw_lookup(src: uint64, start: uint32, end_: uint32): int32 begin
    /* Compare byte-by-byte via pointer arithmetic. */
    /* src is a pointer (uint64) to the source bytes. */
    var len := end_ - start
    if len == 2 then
        /* "do", "if", "as", "in", "or" */
        var c0 := src_byte(src, start + 0)
        var c1 := src_byte(src, start + 1)
        if c0 == 100 and c1 == 111 then return TK_DO end  /* "do" */
        if c0 == 105 and c1 == 102 then return TK_IF end  /* "if" */
        if c0 == 97  and c1 == 115 then return TK_AS end  /* "as" */
        if c0 == 105 and c1 == 110 then return TK_IN end  /* "in" */
        if c0 == 111 and c1 == 114 then return TK_OR end  /* "or" */
        if c0 == 114 and c1 == 99  then return TK_RC end  /* "rc" */
        return TK_IDENT
    end
    if len == 3 then
        var c0 := src_byte(src, start + 0)
        var c1 := src_byte(src, start + 1)
        var c2 := src_byte(src, start + 2)
        if c0 == 118 and c1 == 97  and c2 == 114  then return TK_VAR end  /* "var" */
        if c0 == 102 and c1 == 111 and c2 == 114  then return TK_FOR end  /* "for" */
        if c0 == 110 and c1 == 111 and c2 == 116  then return TK_NOT end  /* "not" */
        if c0 == 111 and c1 == 119 and c2 == 110  then return TK_OWN end  /* "own" */
        if c0 == 114 and c1 == 101 and c2 == 102  then return TK_REF end  /* "ref" */
        if c0 == 109 and c1 == 117 and c2 == 116  then return TK_MUT end  /* "mut" */
        if c0 == 105 and c1 == 115 and c2 == 111  then return TK_ISO end  /* "iso" */
        if c0 == 116 and c1 == 114 and c2 == 110  then return TK_TRN end  /* "trn" */
        if c0 == 118 and c1 == 97  and c2 == 108  then return TK_VAL end  /* "val" */
        if c0 == 98  and c1 == 111 and c2 == 120  then return TK_BOX end  /* "box" */
        if c0 == 116 and c1 == 97  and c2 == 103  then return TK_TAG end  /* "tag" */
        if c0 == 117 and c1 == 115 and c2 == 101  then return TK_USE end  /* "use" */
        if c0 == 101 and c1 == 110 and c2 == 100  then return TK_END end  /* "end" */
        return TK_IDENT
    end
    if len == 4 then
        var c0 := src_byte(src, start + 0)
        var c1 := src_byte(src, start + 1)
        var c2 := src_byte(src, start + 2)
        var c3 := src_byte(src, start + 3)
        if c0 == 116 and c1 == 104 and c2 == 101 and c3 == 110 then return TK_THEN end  /* "then" */
        if c0 == 101 and c1 == 108 and c2 == 115 and c3 == 101 then return TK_ELSE end  /* "else" */
        if c0 == 108 and c1 == 111 and c2 == 111 and c3 == 112 then return TK_LOOP end  /* "loop" */
        if c0 == 110 and c1 == 117 and c2 == 108 and c3 == 108 then return TK_NULL end  /* "null" */
        if c0 == 116 and c1 == 114 and c2 == 117 and c3 == 101 then return TK_TRUE end  /* "true" */
        if c0 == 119 and c1 == 97  and c2 == 105 and c3 == 116 then return TK_WAIT end  /* "wait" */
        if c0 == 101 and c1 == 110 and c2 == 117 and c3 == 109 then return TK_ENUM end  /* "enum" */
        if c0 == 116 and c1 == 121 and c2 == 112 and c3 == 101 then return TK_TYPE end  /* "type" */
        if c0 == 119 and c1 == 101 and c2 == 97  and c3 == 107 then return TK_WEAK end  /* "weak" */
        if c0 == 119 and c1 == 97  and c2 == 105 and c3 == 116 then return TK_WAIT end  /* "wait" */
        return TK_IDENT
    end
    if len == 5 then
        var c0 := src_byte(src, start + 0)
        var c1 := src_byte(src, start + 1)
        var c2 := src_byte(src, start + 2)
        var c3 := src_byte(src, start + 3)
        var c4 := src_byte(src, start + 4)
        if c0 == 98  and c1 == 101 and c2 == 103 and c3 == 105 and c4 == 110 then return TK_BEGIN end  /* "begin" */
        if c0 == 119 and c1 == 104 and c2 == 105 and c3 == 108 and c4 == 101 then return TK_WHILE end  /* "while" */
        if c0 == 98  and c1 == 114 and c2 == 101 and c3 == 97  and c4 == 107 then return TK_BREAK end  /* "break" */
        if c0 == 109 and c1 == 97  and c2 == 116 and c3 == 99  and c4 == 104 then return TK_MATCH end  /* "match" */
        if c0 == 115 and c1 == 112 and c2 == 97  and c3 == 119 and c4 == 110 then return TK_SPAWN end  /* "spawn" */
        if c0 == 97  and c1 == 119 and c2 == 97  and c3 == 105 and c4 == 116 then return TK_AWAIT end  /* "await" */
        if c0 == 97  and c1 == 115 and c2 == 121 and c3 == 110 and c4 == 99  then return TK_ASYNC end  /* "async" */
        if c0 == 100 and c1 == 101 and c2 == 102 and c3 == 101 and c4 == 114 then return TK_DEFER end  /* "defer" */
        if c0 == 117 and c1 == 110 and c2 == 115 and c3 == 97  and c4 == 102 then return TK_UNSAFE end  /* ... need 6 chars for "unsafe" */
        if c0 == 99  and c1 == 111 and c2 == 110 and c3 == 115 and c4 == 116 then return TK_CONST end  /* "const" */
        if c0 == 97  and c1 == 99  and c2 == 116 and c3 == 111 and c4 == 114 then return TK_ACTOR end  /* "actor" */
        if c0 == 102 and c1 == 97  and c2 == 108 and c3 == 115 and c4 == 101 then return TK_FALSE end  /* "false" */
        return TK_IDENT
    end
    if len == 6 then
        var c0 := src_byte(src, start + 0)
        var c1 := src_byte(src, start + 1)
        var c2 := src_byte(src, start + 2)
        var c3 := src_byte(src, start + 3)
        var c4 := src_byte(src, start + 4)
        var c5 := src_byte(src, start + 5)
        if c0 == 109 and c1 == 111 and c2 == 100 and c3 == 117 and c4 == 108 and c5 == 101 then return TK_MODULE end  /* "module" */
        if c0 == 114 and c1 == 101 and c2 == 116 and c3 == 117 and c4 == 114 and c5 == 110 then return TK_RETURN end  /* "return" */
        if c0 == 115 and c1 == 116 and c2 == 114 and c3 == 117 and c4 == 99  and c5 == 116 then return TK_STRUCT end  /* "struct" */
        if c0 == 101 and c1 == 120 and c2 == 116 and c3 == 101 and c4 == 114 and c5 == 110 then return TK_EXTERN end  /* "extern" */
        if c0 == 105 and c1 == 110 and c2 == 108 and c3 == 105 and c4 == 110 and c5 == 101 then return TK_INLINE end  /* "inline" */
        if c0 == 117 and c1 == 110 and c2 == 115 and c3 == 97  and c4 == 102 and c5 == 101 then return TK_UNSAFE end  /* "unsafe" */
        if c0 == 101 and c1 == 120 and c2 == 112 and c3 == 111 and c4 == 114 and c5 == 116 then return TK_EXPORT end  /* "export" */
        if c0 == 115 and c1 == 112 and c2 == 97  and c3 == 119 and c4 == 110 then return TK_SPAWN end
        return TK_IDENT
    end
    if len == 7 then
        var c0 := src_byte(src, start + 0)
        if c0 == 101 then
            /* "elsif" is 5 chars, check "package" and others */
            var c1 := src_byte(src, start + 1)
            if c1 == 108 then
                /* "elsif" — check */
                var c2 := src_byte(src, start + 2)
                var c3 := src_byte(src, start + 3)
                var c4 := src_byte(src, start + 4)
                if c2 == 115 and c3 == 105 and c4 == 102 then
                    var c5 := src_byte(src, start + 5)
                    if c5 == 115 then return TK_ELSIF end  /* ... wait "elsif" is 5 chars */
                end
            end
        end
        /* "package" */
        var p0 := src_byte(src, start)
        if p0 == 112 then
            /* "package" = p(112) a(97) c(99) k(107) a(97) g(103) e(101) */
            if src_byte(src, start+1) == 97  and src_byte(src, start+2) == 99 and
               src_byte(src, start+3) == 107 and src_byte(src, start+4) == 97 and
               src_byte(src, start+5) == 103 and src_byte(src, start+6) == 101 then
                return TK_PACKAGE
            end
        end
        /* "consume" */
        if p0 == 99 then
            if src_byte(src, start+1) == 111 and src_byte(src, start+2) == 110 and
               src_byte(src, start+3) == 115 and src_byte(src, start+4) == 117 and
               src_byte(src, start+5) == 109 and src_byte(src, start+6) == 101 then
                return TK_CONSUME
            end
        end
        return TK_IDENT
    end
    if len == 5 then
        var c0 := src_byte(src, start)
        /* "elsif" = e(101) l(108) s(115) i(105) f(102) */
        if c0 == 101 and src_byte(src, start+1) == 108 and src_byte(src, start+2) == 115 and
           src_byte(src, start+3) == 105 and src_byte(src, start+4) == 102 then
            return TK_ELSIF
        end
    end
    if len == 8 then
        var c0 := src_byte(src, start)
        /* "function" = f(102) u(117) n(110) c(99) t(116) i(105) o(111) n(110) */
        if c0 == 102 and src_byte(src, start+1) == 117 and src_byte(src, start+2) == 110 and
           src_byte(src, start+3) == 99 and src_byte(src, start+4) == 116 and
           src_byte(src, start+5) == 105 and src_byte(src, start+6) == 111 and
           src_byte(src, start+7) == 110 then
            return TK_FUNCTION
        end
        /* "behavior" = b(98) e(101) h(104) a(97) v(118) i(105) o(111) r(114) */
        if c0 == 98 and src_byte(src, start+1) == 101 and src_byte(src, start+2) == 104 and
           src_byte(src, start+3) == 97 and src_byte(src, start+4) == 118 and
           src_byte(src, start+5) == 105 and src_byte(src, start+6) == 111 and
           src_byte(src, start+7) == 114 then
            return TK_BEHAVIOR
        end
        /* "continue" = c(99) o(111) n(110) t(116) i(105) n(110) u(117) e(101) */
        if c0 == 99 and src_byte(src, start+1) == 111 and src_byte(src, start+2) == 110 and
           src_byte(src, start+3) == 116 and src_byte(src, start+4) == 105 and
           src_byte(src, start+5) == 110 and src_byte(src, start+6) == 117 and
           src_byte(src, start+7) == 101 then
            return TK_CONTINUE
        end
        /* "comptime" = c(99) o(111) m(109) p(112) t(116) i(105) m(109) e(101) */
        if c0 == 99 and src_byte(src, start+1) == 111 and src_byte(src, start+2) == 109 and
           src_byte(src, start+3) == 112 and src_byte(src, start+4) == 116 and
           src_byte(src, start+5) == 105 and src_byte(src, start+6) == 109 and
           src_byte(src, start+7) == 101 then
            return TK_COMPTIME
        end
    end
    if len == 9 then
        var c0 := src_byte(src, start)
        /* "procedure" = p(112) r(114) o(111) c(99) e(101) d(100) u(117) r(114) e(101) */
        if c0 == 112 and src_byte(src, start+1) == 114 and src_byte(src, start+2) == 111 and
           src_byte(src, start+3) == 99 and src_byte(src, start+4) == 101 and
           src_byte(src, start+5) == 100 and src_byte(src, start+6) == 117 and
           src_byte(src, start+7) == 114 and src_byte(src, start+8) == 101 then
            return TK_PROCEDURE
        end
    end
    return TK_IDENT
end

/* Load a single byte from a source buffer pointer + offset. */
/* src is a uint64 holding the mmap'd file address. */
function src_byte(src: uint64, offset: uint32): int32 begin
    var addr := src + offset as uint64
    return load_byte(addr)
end

/* Platform primitive: load one byte from memory address. */
/* Implemented as a compiler intrinsic / inline by the self-hosted compiler; */
/* the bootstrap uses pointer-indexed load IR. */
extern function load_byte(addr: uint64): int32

/* ── Lexer state ─────────────────────────────────────────────────────────────── */

type Lexer = struct {
    src:        uint64,  /* pointer to source bytes */
    src_len:    uint32,
    pos:        uint32,
    line:       uint32,
    line_start: uint32,
}

function lexer_new(src: uint64, src_len: uint32): Lexer begin
    return Lexer {
        .src        = src,
        .src_len    = src_len,
        .pos        = 0,
        .line       = 1,
        .line_start = 0,
    }
end

/* Tokenize the entire source into a TokenArray. */
function lexer_tokenize(lex: mut Lexer): TokenArray begin
    var arr := token_array_new()
    loop
        var tok := lexer_next(lex)
        token_array_push(arr, tok)
        if tok.kind == TK_EOF then
            break
        end
    end
    return arr
end

/* ── Single-token scanner ────────────────────────────────────────────────────── */

function lexer_next(lex: mut Lexer): Token begin
    lexer_skip_whitespace(lex)

    var start := lex.pos
    var line  := lex.line
    var col   := start - lex.line_start + 1

    if lex.pos >= lex.src_len then
        return Token { .kind = TK_EOF, .start = start, .tok_end = start, .line = line, .col = col }
    end

    var c := src_byte(lex.src, lex.pos)
    lex.pos := lex.pos + 1

    var kind: int32 := TK_INVALID

    if c == 40 then kind := TK_LPAREN   end  /* ( */
    if c == 41 then kind := TK_RPAREN   end  /* ) */
    if c == 91 then kind := TK_LBRACKET end  /* [ */
    if c == 93 then kind := TK_RBRACKET end  /* ] */
    if c == 123 then kind := TK_LBRACE  end  /* { */
    if c == 125 then kind := TK_RBRACE  end  /* } */
    if c == 44 then kind := TK_COMMA    end  /* , */
    if c == 59 then kind := TK_SEMICOLON end  /* ; */
    if c == 126 then kind := TK_TILDE   end  /* ~ */
    if c == 64 then kind := TK_AT       end  /* @ */

    if kind != TK_INVALID then
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* Dot family: . .. ... ..< */
    if c == 46 then  /* '.' */
        if lexer_peek(lex) == 46 then  /* '..' */
            lex.pos := lex.pos + 1
            if lexer_peek(lex) == 46 then  /* '...' */
                lex.pos := lex.pos + 1
                kind := TK_DOT_DOT_DOT
            elsif lexer_peek(lex) == 60 then  /* '..<' */
                lex.pos := lex.pos + 1
                kind := TK_DOT_DOT_LT
            else
                kind := TK_DOT_DOT
            end
        else
            kind := TK_DOT
        end
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* Colon: : := */
    if c == 58 then  /* ':' */
        if lexer_peek(lex) == 61 then  /* '=' */
            lex.pos := lex.pos + 1
            kind := TK_COLON_EQ
        else
            kind := TK_COLON
        end
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* Equals: = == => */
    if c == 61 then  /* '=' */
        if lexer_peek(lex) == 61 then
            lex.pos := lex.pos + 1
            kind := TK_EQ_EQ
        elsif lexer_peek(lex) == 62 then  /* '>' */
            lex.pos := lex.pos + 1
            kind := TK_FAT_ARROW
        else
            kind := TK_EQ
        end
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* Bang: ! != */
    if c == 33 then
        if lexer_peek(lex) == 61 then
            lex.pos := lex.pos + 1
            kind := TK_BANG_EQ
        else
            kind := TK_BANG
        end
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* Less than: < <= << <<= */
    if c == 60 then
        if lexer_peek(lex) == 60 then
            lex.pos := lex.pos + 1
            if lexer_peek(lex) == 61 then
                lex.pos := lex.pos + 1
                kind := TK_LT_LT_EQ
            else
                kind := TK_LT_LT
            end
        elsif lexer_peek(lex) == 61 then
            lex.pos := lex.pos + 1
            kind := TK_LT_EQ
        else
            kind := TK_LT
        end
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* Greater than: > >= >> >>= */
    if c == 62 then
        if lexer_peek(lex) == 62 then
            lex.pos := lex.pos + 1
            if lexer_peek(lex) == 61 then
                lex.pos := lex.pos + 1
                kind := TK_GT_GT_EQ
            else
                kind := TK_GT_GT
            end
        elsif lexer_peek(lex) == 61 then
            lex.pos := lex.pos + 1
            kind := TK_GT_EQ
        else
            kind := TK_GT
        end
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* Plus: + += */
    if c == 43 then
        if lexer_peek(lex) == 61 then
            lex.pos := lex.pos + 1
            kind := TK_PLUS_EQ
        else
            kind := TK_PLUS
        end
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* Minus: - -= -> */
    if c == 45 then
        if lexer_peek(lex) == 62 then
            lex.pos := lex.pos + 1
            kind := TK_ARROW
        elsif lexer_peek(lex) == 61 then
            lex.pos := lex.pos + 1
            kind := TK_MINUS_EQ
        else
            kind := TK_MINUS
        end
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* Star: * *= */
    if c == 42 then
        if lexer_peek(lex) == 61 then
            lex.pos := lex.pos + 1
            kind := TK_STAR_EQ
        else
            kind := TK_STAR
        end
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* Percent: % %= */
    if c == 37 then
        if lexer_peek(lex) == 61 then
            lex.pos := lex.pos + 1
            kind := TK_PERCENT_EQ
        else
            kind := TK_PERCENT
        end
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* Amp: & &= */
    if c == 38 then
        if lexer_peek(lex) == 61 then
            lex.pos := lex.pos + 1
            kind := TK_AMP_EQ
        else
            kind := TK_AMP
        end
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* Pipe: | |= */
    if c == 124 then
        if lexer_peek(lex) == 61 then
            lex.pos := lex.pos + 1
            kind := TK_PIPE_EQ
        else
            kind := TK_PIPE
        end
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* Caret: ^ ^= */
    if c == 94 then
        if lexer_peek(lex) == 61 then
            lex.pos := lex.pos + 1
            kind := TK_CARET_EQ
        else
            kind := TK_CARET
        end
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* Question: ? ?? */
    if c == 63 then
        if lexer_peek(lex) == 63 then
            lex.pos := lex.pos + 1
            kind := TK_QUESTION_QUESTION
        else
            kind := TK_QUESTION
        end
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* Slash: / /= (int-div) (doc-comment) (block-comment) */
    if c == 47 then
        if lexer_peek(lex) == 47 then
            lex.pos := lex.pos + 1
            if lexer_peek(lex) == 47 then
                /* Doc comment /// */
                lex.pos := lex.pos + 1
                while lex.pos < lex.src_len and src_byte(lex.src, lex.pos) != 10 do
                    lex.pos := lex.pos + 1
                end
                kind := TK_DOC_COMMENT
            else
                /* Integer division // */
                kind := TK_SLASH_SLASH
            end
        elsif lexer_peek(lex) == 42 then
            /* Block comment /* ... */ */
            lex.pos := lex.pos + 1
            lexer_eat_block_comment(lex)
            return lexer_next(lex)  /* tail-recurse past comment */
        elsif lexer_peek(lex) == 61 then
            lex.pos := lex.pos + 1
            kind := TK_SLASH_EQ
        else
            kind := TK_SLASH
        end
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* String literals: " and """ */
    if c == 34 then
        lexer_eat_string(lex)
        return Token { .kind = TK_STRING_LIT, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    /* Number literals */
    if c >= 48 and c <= 57 then
        lex.pos := lex.pos - 1
        var is_float := lexer_scan_number(lex)
        if is_float then
            return Token { .kind = TK_FLOAT_LIT, .start = start, .tok_end = lex.pos, .line = line, .col = col }
        else
            return Token { .kind = TK_INT_LIT, .start = start, .tok_end = lex.pos, .line = line, .col = col }
        end
    end

    /* Identifiers and keywords */
    var is_alpha := (c >= 65 and c <= 90) or (c >= 97 and c <= 122) or c == 95
    if is_alpha then
        lex.pos := lex.pos - 1
        var id_start := lex.pos
        while lex.pos < lex.src_len and is_ident_char(src_byte(lex.src, lex.pos)) do
            lex.pos := lex.pos + 1
        end
        kind := kw_lookup(lex.src, id_start, lex.pos)
        return Token { .kind = kind, .start = start, .tok_end = lex.pos, .line = line, .col = col }
    end

    return Token { .kind = TK_INVALID, .start = start, .tok_end = lex.pos, .line = line, .col = col }
end

/* ── Helpers ─────────────────────────────────────────────────────────────────── */

function lexer_peek(lex: ref Lexer): int32 begin
    if lex.pos < lex.src_len then
        return src_byte(lex.src, lex.pos)
    end
    return 0
end

procedure lexer_skip_whitespace(lex: mut Lexer) begin
    while lex.pos < lex.src_len do
        var c := src_byte(lex.src, lex.pos)
        if c == 32 or c == 9 or c == 13 or c == 10 then
            if c == 10 then
                lex.line := lex.line + 1
                lex.line_start := lex.pos + 1
            end
            lex.pos := lex.pos + 1
        elsif c == 47 and lex.pos + 1 < lex.src_len and src_byte(lex.src, lex.pos + 1) == 42 then
            /* Block comment (c=47='/', next=42='*') */
            lex.pos := lex.pos + 2
            lexer_eat_block_comment(lex)
        else
            break
        end
    end
end

procedure lexer_eat_block_comment(lex: mut Lexer) begin
    var depth: int32 := 1
    while lex.pos < lex.src_len do
        var c := src_byte(lex.src, lex.pos)
        lex.pos := lex.pos + 1
        if c == 10 then
            lex.line := lex.line + 1
            lex.line_start := lex.pos
        end
        if c == 47 and lex.pos < lex.src_len and src_byte(lex.src, lex.pos) == 42 then
            lex.pos := lex.pos + 1
            depth := depth + 1
        elsif c == 42 and lex.pos < lex.src_len and src_byte(lex.src, lex.pos) == 47 then
            lex.pos := lex.pos + 1
            depth := depth - 1
            if depth == 0 then
                break
            end
        end
    end
end

procedure lexer_eat_string(lex: mut Lexer) begin
    /* Check for triple-quoted string */
    if lex.pos + 1 < lex.src_len and
       src_byte(lex.src, lex.pos) == 34 and src_byte(lex.src, lex.pos + 1) == 34 then
        lex.pos := lex.pos + 2
        /* Eat until triple-quote (34,34,34) */
        while lex.pos + 2 < lex.src_len do
            if src_byte(lex.src, lex.pos)   == 34 and
               src_byte(lex.src, lex.pos+1) == 34 and
               src_byte(lex.src, lex.pos+2) == 34 then
                lex.pos := lex.pos + 3
                break
            end
            if src_byte(lex.src, lex.pos) == 10 then
                lex.line := lex.line + 1
                lex.line_start := lex.pos + 1
            end
            lex.pos := lex.pos + 1
        end
    else
        /* Single-quoted string */
        while lex.pos < lex.src_len do
            var c := src_byte(lex.src, lex.pos)
            lex.pos := lex.pos + 1
            if c == 34 then break end
            if c == 92 then
                /* Escape sequence */
                if lex.pos < lex.src_len then
                    lex.pos := lex.pos + 1
                end
            end
        end
    end
end

function lexer_scan_number(lex: mut Lexer): bool begin
    /* Check prefix */
    if src_byte(lex.src, lex.pos) == 48 and lex.pos + 1 < lex.src_len then
        var next := src_byte(lex.src, lex.pos + 1)
        if next == 120 or next == 88 then
            /* 0x hex */
            lex.pos := lex.pos + 2
            while lex.pos < lex.src_len and is_hex_char(src_byte(lex.src, lex.pos)) do
                lex.pos := lex.pos + 1
            end
            return false
        end
        if next == 111 or next == 79 then
            /* 0o octal */
            lex.pos := lex.pos + 2
            while lex.pos < lex.src_len do
                var c := src_byte(lex.src, lex.pos)
                if c >= 48 and c <= 55 or c == 95 then
                    lex.pos := lex.pos + 1
                else
                    break
                end
            end
            return false
        end
        if next == 98 or next == 66 then
            /* 0b binary */
            lex.pos := lex.pos + 2
            while lex.pos < lex.src_len do
                var c := src_byte(lex.src, lex.pos)
                if c == 48 or c == 49 or c == 95 then
                    lex.pos := lex.pos + 1
                else
                    break
                end
            end
            return false
        end
    end
    /* Decimal */
    while lex.pos < lex.src_len do
        var c := src_byte(lex.src, lex.pos)
        if (c >= 48 and c <= 57) or c == 95 then
            lex.pos := lex.pos + 1
        else
            break
        end
    end
    var is_float: bool := false
    /* Fractional part */
    if lex.pos < lex.src_len and src_byte(lex.src, lex.pos) == 46 and
       lex.pos + 1 < lex.src_len and src_byte(lex.src, lex.pos + 1) != 46 then
        is_float := true
        lex.pos := lex.pos + 1
        while lex.pos < lex.src_len and src_byte(lex.src, lex.pos) >= 48 and src_byte(lex.src, lex.pos) <= 57 do
            lex.pos := lex.pos + 1
        end
    end
    /* Exponent */
    if lex.pos < lex.src_len then
        var c := src_byte(lex.src, lex.pos)
        if c == 101 or c == 69 then
            is_float := true
            lex.pos := lex.pos + 1
            if lex.pos < lex.src_len then
                var s := src_byte(lex.src, lex.pos)
                if s == 43 or s == 45 then lex.pos := lex.pos + 1 end
            end
            while lex.pos < lex.src_len and src_byte(lex.src, lex.pos) >= 48 and src_byte(lex.src, lex.pos) <= 57 do
                lex.pos := lex.pos + 1
            end
        end
    end
    return is_float
end

function is_ident_char(c: int32): bool begin
    return (c >= 65 and c <= 90) or (c >= 97 and c <= 122) or (c >= 48 and c <= 57) or c == 95
end

function is_hex_char(c: int32): bool begin
    return (c >= 48 and c <= 57) or (c >= 65 and c <= 70) or (c >= 97 and c <= 102) or c == 95
end
/// Maia self-hosted compiler — AST node definitions.
/// All nodes are stored in a flat arena; pointers are uint64 (arena offsets).

module AST

use Lexer

/* ── Span ────────────────────────────────────────────────────────────────────── */

type Span = struct {
    start: uint32,
    end_:  uint32,
    line:  uint32,
    col:   uint32,
}

/* ── Ownership qualifiers ────────────────────────────────────────────────────── */

const OWN_NONE: int32 = 0
const OWN_OWN:  int32 = 1
const OWN_REF:  int32 = 2
const OWN_MUT:  int32 = 3
const OWN_RC:   int32 = 4
const OWN_WEAK: int32 = 5
const OWN_ISO:  int32 = 6
const OWN_TRN:  int32 = 7
const OWN_VAL:  int32 = 8
const OWN_BOX:  int32 = 9
const OWN_TAG:  int32 = 10

/* ── Binary operators ────────────────────────────────────────────────────────── */

const BINOP_ADD:        int32 = 0
const BINOP_SUB:        int32 = 1
const BINOP_MUL:        int32 = 2
const BINOP_DIV:        int32 = 3
const BINOP_MOD:        int32 = 4
const BINOP_INT_DIV:    int32 = 5
const BINOP_EQ:         int32 = 6
const BINOP_NE:         int32 = 7
const BINOP_LT:         int32 = 8
const BINOP_GT:         int32 = 9
const BINOP_LE:         int32 = 10
const BINOP_GE:         int32 = 11
const BINOP_AND:        int32 = 12
const BINOP_OR:         int32 = 13
const BINOP_BIT_AND:    int32 = 14
const BINOP_BIT_OR:     int32 = 15
const BINOP_BIT_XOR:    int32 = 16
const BINOP_SHL:        int32 = 17
const BINOP_SHR:        int32 = 18
const BINOP_RANGE:      int32 = 19
const BINOP_RANGE_EXCL: int32 = 20
const BINOP_PIPELINE:   int32 = 21
const BINOP_ASSIGN:     int32 = 22
const BINOP_ADD_ASSIGN: int32 = 23
const BINOP_SUB_ASSIGN: int32 = 24
const BINOP_MUL_ASSIGN: int32 = 25
const BINOP_DIV_ASSIGN: int32 = 26
const BINOP_MOD_ASSIGN: int32 = 27
const BINOP_AND_ASSIGN: int32 = 28
const BINOP_OR_ASSIGN:  int32 = 29
const BINOP_XOR_ASSIGN: int32 = 30
const BINOP_SHL_ASSIGN: int32 = 31
const BINOP_SHR_ASSIGN: int32 = 32

/* ── Unary operators ─────────────────────────────────────────────────────────── */

const UNOP_NEG:     int32 = 0
const UNOP_NOT:     int32 = 1
const UNOP_BIT_NOT: int32 = 2
const UNOP_ADDR_OF: int32 = 3
const UNOP_DEREF:   int32 = 4

/* ── Node kinds ──────────────────────────────────────────────────────────────── */
/* All AST nodes are tagged-union style, discriminated by a kind int32. */
/* Each node is a fixed-size struct in an arena; child nodes are stored as */
/* arena-relative uint64 offsets. */

/* Expression kinds */
const EXPR_INT_LIT:       int32 = 0
const EXPR_FLOAT_LIT:     int32 = 1
const EXPR_STRING_LIT:    int32 = 2
const EXPR_BOOL_LIT:      int32 = 3
const EXPR_NULL_LIT:      int32 = 4
const EXPR_IDENT:         int32 = 5
const EXPR_BINARY:        int32 = 6
const EXPR_UNARY:         int32 = 7
const EXPR_CAST:          int32 = 8
const EXPR_CALL:          int32 = 9
const EXPR_METHOD_CALL:   int32 = 10
const EXPR_FIELD:         int32 = 11
const EXPR_INDEX:         int32 = 12
const EXPR_SLICE_EXPR:    int32 = 13
const EXPR_STRUCT_LIT:    int32 = 14
const EXPR_ARRAY_LIT:     int32 = 15
const EXPR_CLOSURE:       int32 = 16
const EXPR_CONSUME:       int32 = 17
const EXPR_AWAIT:         int32 = 18
const EXPR_SPAWN:         int32 = 19
const EXPR_BUILTIN_CALL:  int32 = 20
const EXPR_OPTION_CAPTURE:int32 = 21
const EXPR_DEFAULT:       int32 = 22
const EXPR_GROUPED:       int32 = 23

/* Statement kinds */
const STMT_VAR_DECL:    int32 = 30
const STMT_CONST_DECL:  int32 = 31
const STMT_ASSIGN:      int32 = 32
const STMT_EXPR:        int32 = 33
const STMT_BLOCK:       int32 = 34
const STMT_IF:          int32 = 35
const STMT_WHILE:       int32 = 36
const STMT_FOR:         int32 = 37
const STMT_LOOP:        int32 = 38
const STMT_BREAK:       int32 = 39
const STMT_CONTINUE:    int32 = 40
const STMT_RETURN:      int32 = 41
const STMT_MATCH:       int32 = 42
const STMT_DEFER:       int32 = 43
const STMT_SAFE:        int32 = 44
const STMT_UNSAFE:      int32 = 45

/* Declaration kinds */
const DECL_MODULE:  int32 = 50
const DECL_USE:     int32 = 51
const DECL_FUNC:    int32 = 52
const DECL_PROC:    int32 = 53
const DECL_TYPE:    int32 = 54
const DECL_CONST:   int32 = 55
const DECL_VAR:     int32 = 56
const DECL_ACTOR:   int32 = 57
const DECL_EXTERN:  int32 = 58

/* Type expression kinds */
const TYPE_NAMED:    int32 = 60
const TYPE_OPTIONAL: int32 = 61
const TYPE_POINTER:  int32 = 62
const TYPE_ARRAY:    int32 = 63
const TYPE_SLICE:    int32 = 64
const TYPE_GENERIC:  int32 = 65
const TYPE_OWNED:    int32 = 66
const TYPE_FUNC:     int32 = 67
const TYPE_UNIT:     int32 = 68

/* ── Arena-based node storage ────────────────────────────────────────────────── */
/* Every AST node is a small fixed-size struct allocated from the arena. */
/* Pointers between nodes are expressed as uint64 arena-base offsets. */
/* */
/* The "Node" header (present at the start of every node allocation): */
/*   kind:  int32   — EXPR_*, STMT_*, DECL_*, TYPE_* constant */
/*   _pad:  int32   — alignment padding */
/*   span_start: uint32 */
/*   span_end:   uint32 */
/*   span_line:  uint32 */
/*   span_col:   uint32 */
/* */
/* This header is 24 bytes.  Specific fields follow immediately after. */

const NODE_HDR_BYTES: uint32 = 24

/* ── AST Arena ──────────────────────────────────────────────────────────────── */

type AstArena = struct {
    base: uint64,
    pos:  uint64,
    cap:  uint64,
}

extern function maia_mmap(len: uint64): uint64

function ast_arena_new(cap: uint64): AstArena begin
    var base := maia_mmap(cap)
    return AstArena { .base = base, .pos = 0, .cap = cap }
end

function ast_alloc(arena: mut AstArena, nbytes: uint32): uint64 begin
    /* 8-byte align */
    var aligned := ((arena.pos + 7) / 8) * 8
    arena.pos := aligned + nbytes as uint64
    return arena.base + aligned
end

/* ── Node write helpers ──────────────────────────────────────────────────────── */
/* Low-level: write a 32-bit int to a memory address. */
extern function store32(addr: uint64, v: int32)
extern function store64(addr: uint64, v: uint64)
extern function load32(addr: uint64): int32
extern function load64(addr: uint64): uint64

procedure node_set_kind(node: uint64, kind: int32) begin
    store32(node, kind)
end

procedure node_set_span(node: uint64, s: Span) begin
    store32(node + 8,  s.start as int32)
    store32(node + 12, s.end_ as int32)
    store32(node + 16, s.line as int32)
    store32(node + 20, s.col as int32)
end

function node_kind(node: uint64): int32 begin
    return load32(node)
end

function node_span_start(node: uint64): uint32 begin
    return load32(node + 8) as uint32
end

function node_span_line(node: uint64): uint32 begin
    return load32(node + 16) as uint32
end

function node_span_col(node: uint64): uint32 begin
    return load32(node + 20) as uint32
end

/* ── Module ──────────────────────────────────────────────────────────────────── */

type Module = struct {
    name:       uint64,  /* pointer to name string (0 = anonymous) */
    name_len:   uint32,
    decls:      uint64,  /* pointer to array of node pointers (uint64[]) */
    decl_count: uint32,
    src:        uint64,
    src_len:    uint32,
}
/// Maia self-hosted compiler — recursive-descent parser.
/// Converts a token stream into AST nodes allocated in an AstArena.

module Parser

use Lexer
use AST

extern function maia_mmap(len: uint64): uint64
extern function store32(addr: uint64, v: int32)
extern function store64(addr: uint64, v: uint64)
extern function load32(addr: uint64): int32
extern function load64(addr: uint64): uint64
extern function maia_exit(code: int32)

/* ── Parser state ────────────────────────────────────────────────────────────── */

type Parser = struct {
    tokens:      uint64,  /* pointer to Token array (each token = 20 bytes) */
    tok_count:   uint32,
    pos:         uint32,
    src:         uint64,
    src_len:     uint32,
    arena:       AstArena,
    /* Diagnostic list: pairs of (line, col, message_ptr, message_len) */
    diag_ptr:    uint64,
    diag_count:  uint32,
}

const TOKEN_STRIDE: uint32 = 20  /* 5 × int32 fields */

/* ── Token accessors ─────────────────────────────────────────────────────────── */

function parser_tok_kind(p: ref Parser, idx: uint32): int32 begin
    var base := p.tokens + (idx as uint64) * TOKEN_STRIDE as uint64
    return load32(base)
end

function parser_tok_start(p: ref Parser, idx: uint32): uint32 begin
    var base := p.tokens + (idx as uint64) * TOKEN_STRIDE as uint64
    return load32(base + 4) as uint32
end

function parser_tok_end(p: ref Parser, idx: uint32): uint32 begin
    var base := p.tokens + (idx as uint64) * TOKEN_STRIDE as uint64
    return load32(base + 8) as uint32
end

function parser_tok_line(p: ref Parser, idx: uint32): uint32 begin
    var base := p.tokens + (idx as uint64) * TOKEN_STRIDE as uint64
    return load32(base + 12) as uint32
end

function parser_tok_col(p: ref Parser, idx: uint32): uint32 begin
    var base := p.tokens + (idx as uint64) * TOKEN_STRIDE as uint64
    return load32(base + 16) as uint32
end

function parser_new(tokens: uint64, tok_count: uint32, src: uint64, src_len: uint32): Parser begin
    var arena := ast_arena_new(4096 * 1024)  /* 4 MB arena */
    return Parser {
        .tokens     = tokens,
        .tok_count  = tok_count,
        .pos        = 0,
        .src        = src,
        .src_len    = src_len,
        .arena      = arena,
        .diag_ptr   = maia_mmap(65536),
        .diag_count = 0,
    }
end

/* ── Cursor helpers ──────────────────────────────────────────────────────────── */

function parser_check(p: ref Parser, kind: int32): bool begin
    if p.pos >= p.tok_count then return false end
    return parser_tok_kind(p, p.pos) == kind
end

function parser_peek(p: ref Parser): int32 begin
    if p.pos >= p.tok_count then return TK_EOF end
    return parser_tok_kind(p, p.pos)
end

function parser_peek2(p: ref Parser): int32 begin
    if p.pos + 1 >= p.tok_count then return TK_EOF end
    return parser_tok_kind(p, p.pos + 1)
end

procedure parser_advance(p: mut Parser) begin
    if p.pos < p.tok_count then p.pos := p.pos + 1 end
end

function parser_current_span(p: ref Parser): Span begin
    if p.pos >= p.tok_count then
        return Span { .start = 0, .end_ = 0, .line = 0, .col = 0 }
    end
    return Span {
        .start = parser_tok_start(p, p.pos),
        .end_  = parser_tok_end(p, p.pos),
        .line  = parser_tok_line(p, p.pos),
        .col   = parser_tok_col(p, p.pos),
    }
end

function parser_expect(p: mut Parser, kind: int32): Span begin
    var span := parser_current_span(p)
    if not parser_check(p, kind) then
        parser_error(p, "unexpected token", span)
        return span
    end
    parser_advance(p)
    return span
end

procedure parser_try_consume(p: mut Parser, kind: int32) begin
    if parser_check(p, kind) then parser_advance(p) end
end

procedure parser_error(p: mut Parser, msg: string, span: Span) begin
    /* Record diagnostic (simplified: just count errors) */
    p.diag_count := p.diag_count + 1
end

function parser_at_end(p: ref Parser): bool begin
    return p.pos >= p.tok_count or parser_tok_kind(p, p.pos) == TK_EOF
end

/* Panic-mode recovery: skip to the next declaration boundary */
procedure parser_synchronize(p: mut Parser) begin
    while not parser_at_end(p) do
        var k := parser_peek(p)
        if k == TK_FUNCTION or k == TK_PROCEDURE or k == TK_TYPE or
           k == TK_CONST or k == TK_VAR or k == TK_MODULE or k == TK_USE or
           k == TK_EXTERN or k == TK_ACTOR then
            break
        end
        parser_advance(p)
    end
end

/* ── Top-level parser ────────────────────────────────────────────────────────── */

function parse_module(p: mut Parser): Module begin
    /* Optional module declaration */
    var mod_name: uint64 := 0
    var mod_name_len: uint32 := 0

    if parser_check(p, TK_MODULE) then
        parser_advance(p)
        if parser_check(p, TK_IDENT) then
            mod_name     := p.src + parser_tok_start(p, p.pos) as uint64
            mod_name_len := parser_tok_end(p, p.pos) - parser_tok_start(p, p.pos)
            parser_advance(p)
        end
        parser_try_consume(p, TK_SEMICOLON)
    end

    /* Collect top-level declarations into a growable pointer array */
    const DECL_CAP: uint32 = 1024
    var decl_arr := maia_mmap((DECL_CAP as uint64) * 8)
    var decl_count: uint32 := 0

    while not parser_at_end(p) do
        var d := parse_decl(p)
        if d != 0 then
            store64(decl_arr + (decl_count as uint64) * 8, d)
            decl_count := decl_count + 1
        else
            parser_synchronize(p)
        end
    end

    return Module {
        .name       = mod_name,
        .name_len   = mod_name_len,
        .decls      = decl_arr,
        .decl_count = decl_count,
        .src        = p.src,
        .src_len    = p.src_len,
    }
end

/* ── Declaration parsing ─────────────────────────────────────────────────────── */

function parse_decl(p: mut Parser): uint64 begin
    /* Export level */
    var export_level: int32 := 0
    if parser_check(p, TK_EXPORT) then
        parser_advance(p)
        if parser_check(p, TK_LPAREN) then
            parser_advance(p)
            parser_advance(p)  /* qualifier ident */
            parser_try_consume(p, TK_RPAREN)
        end
        export_level := 1
    end

    /* Async/inline modifiers */
    var is_async: bool := false
    var is_inline: bool := false
    if parser_check(p, TK_ASYNC) then
        is_async := true
        parser_advance(p)
    end
    if parser_check(p, TK_INLINE) then
        is_inline := true
        parser_advance(p)
    end
    if parser_check(p, TK_ASYNC) and not is_async then
        is_async := true
        parser_advance(p)
    end

    var k := parser_peek(p)
    var span := parser_current_span(p)

    if k == TK_MODULE then return parse_module_decl(p, span) end
    if k == TK_USE then return parse_use_decl(p, span) end
    if k == TK_FUNCTION then return parse_func_decl(p, span, export_level, is_async, false) end
    if k == TK_PROCEDURE then return parse_proc_decl(p, span, export_level, is_async) end
    if k == TK_TYPE then return parse_type_decl(p, span, export_level) end
    if k == TK_CONST then return parse_const_decl(p, span, export_level) end
    if k == TK_VAR then return parse_var_decl_top(p, span, export_level) end
    if k == TK_ACTOR then return parse_actor_decl(p, span, export_level) end
    if k == TK_EXTERN then return parse_extern_decl(p, span) end

    /* Unrecognized — return 0 to trigger recovery */
    return 0
end

function parse_module_decl(p: mut Parser, span: Span): uint64 begin
    parser_advance(p)  /* consume 'module' */
    var name_start: uint32 := 0
    var name_len: uint32 := 0
    if parser_check(p, TK_IDENT) then
        name_start := parser_tok_start(p, p.pos)
        name_len   := parser_tok_end(p, p.pos) - name_start
        parser_advance(p)
    end
    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
    node_set_kind(node, DECL_MODULE)
    node_set_span(node, span)
    store32(node + NODE_HDR_BYTES, name_start as int32)
    store32(node + NODE_HDR_BYTES + 4, name_len as int32)
    return node
end

function parse_use_decl(p: mut Parser, span: Span): uint64 begin
    parser_advance(p)  /* 'use' */
    /* Parse path: Ident (.Ident)* [.{items} | as alias | .*] */
    const PATH_CAP: uint32 = 16
    var path_arr := maia_mmap((PATH_CAP as uint64) * 8)
    var path_count: uint32 := 0

    while parser_check(p, TK_IDENT) do
        var seg := p.src + parser_tok_start(p, p.pos) as uint64
        store64(path_arr + (path_count as uint64) * 8, seg)
        path_count := path_count + 1
        parser_advance(p)
        if parser_check(p, TK_DOT) and parser_peek2(p) != TK_LBRACE then
            parser_advance(p)
        else
            break
        end
    end

    var items: uint64 := 0
    var item_count: uint32 := 0
    var alias: uint64 := 0

    if parser_check(p, TK_DOT) then
        parser_advance(p)
        if parser_check(p, TK_LBRACE) then
            parser_advance(p)
            items := maia_mmap((PATH_CAP as uint64) * 8)
            while not parser_check(p, TK_RBRACE) and not parser_at_end(p) do
                if parser_check(p, TK_IDENT) then
                    store64(items + (item_count as uint64) * 8,
                            p.src + parser_tok_start(p, p.pos) as uint64)
                    item_count := item_count + 1
                    parser_advance(p)
                end
                if parser_check(p, TK_COMMA) then parser_advance(p) end
            end
            parser_try_consume(p, TK_RBRACE)
        elsif parser_check(p, TK_STAR) then
            parser_advance(p)
        end
    elsif parser_check(p, TK_AS) then
        parser_advance(p)
        if parser_check(p, TK_IDENT) then
            alias := p.src + parser_tok_start(p, p.pos) as uint64
            parser_advance(p)
        end
    end

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 40)
    node_set_kind(node, DECL_USE)
    node_set_span(node, span)
    store64(node + NODE_HDR_BYTES,      path_arr)
    store32(node + NODE_HDR_BYTES + 8,  path_count as int32)
    store64(node + NODE_HDR_BYTES + 16, items)
    store32(node + NODE_HDR_BYTES + 24, item_count as int32)
    store64(node + NODE_HDR_BYTES + 32, alias)
    return node
end

/* ── Function / procedure declarations ──────────────────────────────────────── */

function parse_func_decl(p: mut Parser, span: Span, export_level: int32, is_async: bool, is_comptime: bool): uint64 begin
    parser_advance(p)  /* 'function' */
    var name_start := parser_tok_start(p, p.pos)
    var name_len   := parser_tok_end(p, p.pos) - name_start
    parser_advance(p)

    /* Generic type parameters [T, U] */
    if parser_check(p, TK_LBRACKET) then
        parser_advance(p)
        while not parser_check(p, TK_RBRACKET) and not parser_at_end(p) do
            parser_advance(p)
            if parser_check(p, TK_COMMA) then parser_advance(p) end
        end
        parser_try_consume(p, TK_RBRACKET)
    end

    var params := parse_param_list(p)
    var param_count: uint32 := load32(params) as uint32

    var ret_ty: uint64 := 0
    if parser_check(p, TK_COLON) then
        parser_advance(p)
        ret_ty := parse_type_expr(p)
    end

    var body: uint64 := 0
    if parser_check(p, TK_BEGIN) then
        body := parse_block_stmt(p)
    end

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 64)
    node_set_kind(node, DECL_FUNC)
    node_set_span(node, span)
    store32(node + NODE_HDR_BYTES,      name_start as int32)
    store32(node + NODE_HDR_BYTES + 4,  name_len as int32)
    store64(node + NODE_HDR_BYTES + 8,  params)
    store32(node + NODE_HDR_BYTES + 16, param_count as int32)
    store64(node + NODE_HDR_BYTES + 24, ret_ty)
    store64(node + NODE_HDR_BYTES + 32, body)
    store32(node + NODE_HDR_BYTES + 40, if is_async then 1 else 0 end)
    store32(node + NODE_HDR_BYTES + 44, export_level)
    return node
end

function parse_proc_decl(p: mut Parser, span: Span, export_level: int32, is_async: bool): uint64 begin
    parser_advance(p)  /* 'procedure' */
    var name_start := parser_tok_start(p, p.pos)
    var name_len   := parser_tok_end(p, p.pos) - name_start
    parser_advance(p)

    var params := parse_param_list(p)
    var param_count: uint32 := load32(params) as uint32

    var body: uint64 := 0
    if parser_check(p, TK_BEGIN) then
        body := parse_block_stmt(p)
    end

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 56)
    node_set_kind(node, DECL_PROC)
    node_set_span(node, span)
    store32(node + NODE_HDR_BYTES,      name_start as int32)
    store32(node + NODE_HDR_BYTES + 4,  name_len as int32)
    store64(node + NODE_HDR_BYTES + 8,  params)
    store32(node + NODE_HDR_BYTES + 16, param_count as int32)
    store64(node + NODE_HDR_BYTES + 24, body)
    store32(node + NODE_HDR_BYTES + 32, if is_async then 1 else 0 end)
    store32(node + NODE_HDR_BYTES + 36, export_level)
    return node
end

/* Parse (param, param, …) and return a pointer to [count: int32, param*[]] */
function parse_param_list(p: mut Parser): uint64 begin
    var params := maia_mmap(256)  /* room for 256 params at 8 bytes each */
    var count: uint32 := 0
    parser_expect(p, TK_LPAREN)

    while not parser_check(p, TK_RPAREN) and not parser_at_end(p) do
        var param := parse_param(p)
        if param != 0 then
            store64(params + 8 + (count as uint64) * 8, param)
            count := count + 1
        end
        if parser_check(p, TK_COMMA) then parser_advance(p) end
    end

    parser_try_consume(p, TK_RPAREN)
    store32(params, count as int32)
    return params
end

function parse_param(p: mut Parser): uint64 begin
    var span := parser_current_span(p)
    /* ownership qualifier (opt) */
    var ownership: int32 := OWN_NONE
    if parser_check(p, TK_OWN)  then ownership := OWN_OWN;  parser_advance(p) end
    if parser_check(p, TK_REF)  then ownership := OWN_REF;  parser_advance(p) end
    if parser_check(p, TK_MUT)  then ownership := OWN_MUT;  parser_advance(p) end
    if parser_check(p, TK_RC)   then ownership := OWN_RC;   parser_advance(p) end
    if parser_check(p, TK_WEAK) then ownership := OWN_WEAK; parser_advance(p) end
    if parser_check(p, TK_ISO)  then ownership := OWN_ISO;  parser_advance(p) end
    if parser_check(p, TK_TRN)  then ownership := OWN_TRN;  parser_advance(p) end
    if parser_check(p, TK_VAL)  then ownership := OWN_VAL;  parser_advance(p) end
    if parser_check(p, TK_BOX)  then ownership := OWN_BOX;  parser_advance(p) end
    if parser_check(p, TK_TAG)  then ownership := OWN_TAG;  parser_advance(p) end

    var name_start := parser_tok_start(p, p.pos)
    var name_len   := parser_tok_end(p, p.pos) - name_start
    parser_advance(p)

    var ty: uint64 := 0
    if parser_check(p, TK_COLON) then
        parser_advance(p)
        ty := parse_type_expr(p)
    end

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 32)
    node_set_kind(node, 0)  /* PARAM kind not in decl enum; use 0 */
    node_set_span(node, span)
    store32(node + NODE_HDR_BYTES,      name_start as int32)
    store32(node + NODE_HDR_BYTES + 4,  name_len as int32)
    store64(node + NODE_HDR_BYTES + 8,  ty)
    store32(node + NODE_HDR_BYTES + 16, ownership)
    return node
end

/* ── Type declarations ───────────────────────────────────────────────────────── */

function parse_type_decl(p: mut Parser, span: Span, export_level: int32): uint64 begin
    parser_advance(p)  /* 'type' */
    var name_start := parser_tok_start(p, p.pos)
    var name_len   := parser_tok_end(p, p.pos) - name_start
    parser_advance(p)

    /* Generic params */
    if parser_check(p, TK_LBRACKET) then
        parser_advance(p)
        while not parser_check(p, TK_RBRACKET) and not parser_at_end(p) do
            parser_advance(p)
            if parser_check(p, TK_COMMA) then parser_advance(p) end
        end
        parser_try_consume(p, TK_RBRACKET)
    end

    parser_expect(p, TK_EQ)

    var def: uint64 := 0
    var def_kind: int32 := 0

    if parser_check(p, TK_STRUCT) then
        parser_advance(p)
        def := parse_struct_def(p)
        def_kind := 0
    elsif parser_check(p, TK_ENUM) then
        parser_advance(p)
        def := parse_enum_def(p)
        def_kind := 1
    else
        def := parse_type_expr(p)
        def_kind := 2
    end

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 32)
    node_set_kind(node, DECL_TYPE)
    node_set_span(node, span)
    store32(node + NODE_HDR_BYTES,      name_start as int32)
    store32(node + NODE_HDR_BYTES + 4,  name_len as int32)
    store64(node + NODE_HDR_BYTES + 8,  def)
    store32(node + NODE_HDR_BYTES + 16, def_kind)
    store32(node + NODE_HDR_BYTES + 20, export_level)
    return node
end

function parse_struct_def(p: mut Parser): uint64 begin
    var span := parser_current_span(p)
    parser_expect(p, TK_LBRACE)

    var fields := maia_mmap(512)
    var field_count: uint32 := 0
    var methods := maia_mmap(512)
    var method_count: uint32 := 0

    while not parser_check(p, TK_RBRACE) and not parser_at_end(p) do
        var k := parser_peek(p)
        if k == TK_FUNCTION or k == TK_PROCEDURE then
            var ms := parser_current_span(p)
            var is_async: bool := false
            var method := parse_func_decl(p, ms, 0, is_async, false)
            if k == TK_PROCEDURE then
                method := parse_proc_decl(p, ms, 0, is_async)
            end
            store64(methods + (method_count as uint64) * 8, method)
            method_count := method_count + 1
        else
            var field := parse_struct_field(p)
            if field != 0 then
                store64(fields + (field_count as uint64) * 8, field)
                field_count := field_count + 1
                parser_try_consume(p, TK_COMMA)
            end
        end
    end
    parser_try_consume(p, TK_RBRACE)

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 32)
    node_set_kind(node, 0)
    node_set_span(node, span)
    store64(node + NODE_HDR_BYTES,      fields)
    store32(node + NODE_HDR_BYTES + 8,  field_count as int32)
    store64(node + NODE_HDR_BYTES + 16, methods)
    store32(node + NODE_HDR_BYTES + 24, method_count as int32)
    return node
end

function parse_struct_field(p: mut Parser): uint64 begin
    var span := parser_current_span(p)
    var ownership: int32 := OWN_NONE
    if parser_check(p, TK_MUT)  then ownership := OWN_MUT;  parser_advance(p) end
    if parser_check(p, TK_OWN)  then ownership := OWN_OWN;  parser_advance(p) end
    if parser_check(p, TK_REF)  then ownership := OWN_REF;  parser_advance(p) end

    if not parser_check(p, TK_IDENT) then return 0 end
    var name_start := parser_tok_start(p, p.pos)
    var name_len   := parser_tok_end(p, p.pos) - name_start
    parser_advance(p)
    parser_expect(p, TK_COLON)
    var ty := parse_type_expr(p)

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 24)
    node_set_kind(node, 0)
    node_set_span(node, span)
    store32(node + NODE_HDR_BYTES,      name_start as int32)
    store32(node + NODE_HDR_BYTES + 4,  name_len as int32)
    store64(node + NODE_HDR_BYTES + 8,  ty)
    store32(node + NODE_HDR_BYTES + 16, ownership)
    return node
end

function parse_enum_def(p: mut Parser): uint64 begin
    var span := parser_current_span(p)
    parser_expect(p, TK_LBRACE)

    var variants := maia_mmap(512)
    var variant_count: uint32 := 0

    while not parser_check(p, TK_RBRACE) and not parser_at_end(p) do
        if parser_check(p, TK_IDENT) then
            var vs := parser_current_span(p)
            var vname_start := parser_tok_start(p, p.pos)
            var vname_len   := parser_tok_end(p, p.pos) - vname_start
            parser_advance(p)
            var value: int64 := 0 as int64
            var has_value: bool := false
            if parser_check(p, TK_EQ) then
                parser_advance(p)
                var val_node := parse_expr(p)
                has_value := true
    val_node
            end
            var vnode := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
            node_set_kind(vnode, 0)
            node_set_span(vnode, vs)
            store32(vnode + NODE_HDR_BYTES,     vname_start as int32)
            store32(vnode + NODE_HDR_BYTES + 4,  vname_len as int32)
            store64(variants + (variant_count as uint64) * 8, vnode)
            variant_count := variant_count + 1
            parser_try_consume(p, TK_COMMA)
        else
            parser_advance(p)
        end
    end
    parser_try_consume(p, TK_RBRACE)

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
    node_set_kind(node, 1)
    node_set_span(node, span)
    store64(node + NODE_HDR_BYTES,     variants)
    store32(node + NODE_HDR_BYTES + 8, variant_count as int32)
    return node
end

/* ── const / var declarations ────────────────────────────────────────────────── */

function parse_const_decl(p: mut Parser, span: Span, export_level: int32): uint64 begin
    parser_advance(p)  /* 'const' */
    var name_start := parser_tok_start(p, p.pos)
    var name_len   := parser_tok_end(p, p.pos) - name_start
    parser_advance(p)
    var ty: uint64 := 0
    if parser_check(p, TK_COLON) then
        parser_advance(p)
        ty := parse_type_expr(p)
    end
    parser_expect(p, TK_EQ)
    var value := parse_expr(p)

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 40)
    node_set_kind(node, DECL_CONST)
    node_set_span(node, span)
    store32(node + NODE_HDR_BYTES,      name_start as int32)
    store32(node + NODE_HDR_BYTES + 4,  name_len as int32)
    store64(node + NODE_HDR_BYTES + 8,  ty)
    store64(node + NODE_HDR_BYTES + 16, value)
    store32(node + NODE_HDR_BYTES + 24, export_level)
    return node
end

function parse_var_decl_top(p: mut Parser, span: Span, export_level: int32): uint64 begin
    parser_advance(p)  /* 'var' */
    var ownership: int32 := OWN_NONE
    if parser_check(p, TK_MUT)  then ownership := OWN_MUT;  parser_advance(p) end
    if parser_check(p, TK_OWN)  then ownership := OWN_OWN;  parser_advance(p) end

    var name_start := parser_tok_start(p, p.pos)
    var name_len   := parser_tok_end(p, p.pos) - name_start
    parser_advance(p)
    var ty: uint64 := 0
    if parser_check(p, TK_COLON) then
        parser_advance(p)
        ty := parse_type_expr(p)
    end
    var init: uint64 := 0
    if parser_check(p, TK_EQ) or parser_check(p, TK_COLON_EQ) then
        parser_advance(p)
        init := parse_expr(p)
    end

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 48)
    node_set_kind(node, DECL_VAR)
    node_set_span(node, span)
    store32(node + NODE_HDR_BYTES,      name_start as int32)
    store32(node + NODE_HDR_BYTES + 4,  name_len as int32)
    store64(node + NODE_HDR_BYTES + 8,  ty)
    store64(node + NODE_HDR_BYTES + 16, init)
    store32(node + NODE_HDR_BYTES + 24, ownership)
    store32(node + NODE_HDR_BYTES + 28, export_level)
    return node
end

/* ── Actor / extern declarations ─────────────────────────────────────────────── */

function parse_actor_decl(p: mut Parser, span: Span, export_level: int32): uint64 begin
    parser_advance(p)  /* 'actor' */
    var name_start := parser_tok_start(p, p.pos)
    var name_len   := parser_tok_end(p, p.pos) - name_start
    parser_advance(p)

    /* Skip body between { } */
    if parser_check(p, TK_LBRACE) then
        var depth: int32 := 1
        parser_advance(p)
        while depth > 0 and not parser_at_end(p) do
            var k := parser_peek(p)
            if k == TK_LBRACE then depth := depth + 1 end
            if k == TK_RBRACE then depth := depth - 1 end
            parser_advance(p)
        end
    end

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
    node_set_kind(node, DECL_ACTOR)
    node_set_span(node, span)
    store32(node + NODE_HDR_BYTES,     name_start as int32)
    store32(node + NODE_HDR_BYTES + 4, name_len as int32)
    return node
end

function parse_extern_decl(p: mut Parser, span: Span): uint64 begin
    parser_advance(p)  /* 'extern' */
    var inner: uint64 := 0
    var k := parser_peek(p)
    if k == TK_FUNCTION then
        inner := parse_func_decl(p, parser_current_span(p), 0, false, false)
    elsif k == TK_PROCEDURE then
        inner := parse_proc_decl(p, parser_current_span(p), 0, false)
    end

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
    node_set_kind(node, DECL_EXTERN)
    node_set_span(node, span)
    store64(node + NODE_HDR_BYTES, inner)
    return node
end

/* ── Type expression parser ──────────────────────────────────────────────────── */

function parse_type_expr(p: mut Parser): uint64 begin
    var span := parser_current_span(p)
    var k := parser_peek(p)

    /* Ownership qualifier */
    var ownership: int32 := OWN_NONE
    if k == TK_OWN  then ownership := OWN_OWN;  parser_advance(p) end
    if k == TK_REF  then ownership := OWN_REF;  parser_advance(p) end
    if k == TK_MUT  then ownership := OWN_MUT;  parser_advance(p) end
    if k == TK_RC   then ownership := OWN_RC;   parser_advance(p) end
    if k == TK_WEAK then ownership := OWN_WEAK; parser_advance(p) end
    if k == TK_ISO  then ownership := OWN_ISO;  parser_advance(p) end
    if k == TK_TRN  then ownership := OWN_TRN;  parser_advance(p) end
    if k == TK_VAL  then ownership := OWN_VAL;  parser_advance(p) end
    if k == TK_BOX  then ownership := OWN_BOX;  parser_advance(p) end
    if k == TK_TAG  then ownership := OWN_TAG;  parser_advance(p) end
    if ownership != OWN_NONE then k := parser_peek(p) end

    /* Optional type: ?T */
    if k == TK_QUESTION then
        parser_advance(p)
        var inner := parse_type_expr(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
        node_set_kind(node, TYPE_OPTIONAL)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES, inner)
        return node
    end

    /* Pointer type: *T */
    if k == TK_STAR then
        parser_advance(p)
        var mutable: int32 := if parser_check(p, TK_MUT) then 1 else 0 end
        if mutable == 1 then parser_advance(p) end
        var inner := parse_type_expr(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
        node_set_kind(node, TYPE_POINTER)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES, inner)
        store32(node + NODE_HDR_BYTES + 8, mutable)
        return node
    end

    /* Array/slice: [N]T or []T */
    if k == TK_LBRACKET then
        parser_advance(p)
        var size_expr: uint64 := 0
        if not parser_check(p, TK_RBRACKET) then
            size_expr := parse_expr(p)
        end
        parser_expect(p, TK_RBRACKET)
        var elem := parse_type_expr(p)
        var ty_kind := if size_expr != 0 then TYPE_ARRAY else TYPE_SLICE end
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
        node_set_kind(node, ty_kind)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES,     elem)
        store64(node + NODE_HDR_BYTES + 8, size_expr)
        return node
    end

    /* Function type: function(A, B): R */
    if k == TK_FUNCTION then
        parser_advance(p)
        /* parse parameter types */
        var param_tys := maia_mmap(128)
        var pt_count: uint32 := 0
        if parser_check(p, TK_LPAREN) then
            parser_advance(p)
            while not parser_check(p, TK_RPAREN) and not parser_at_end(p) do
                var pt := parse_type_expr(p)
                store64(param_tys + (pt_count as uint64) * 8, pt)
                pt_count := pt_count + 1
                if parser_check(p, TK_COMMA) then parser_advance(p) end
            end
            parser_try_consume(p, TK_RPAREN)
        end
        var ret_ty: uint64 := 0
        if parser_check(p, TK_COLON) then
            parser_advance(p)
            ret_ty := parse_type_expr(p)
        end
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 24)
        node_set_kind(node, TYPE_FUNC)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES,      param_tys)
        store32(node + NODE_HDR_BYTES + 8,  pt_count as int32)
        store64(node + NODE_HDR_BYTES + 16, ret_ty)
        return node
    end

    /* Named type (possibly generic): Ident or Ident(T, U) */
    if k == TK_IDENT then
        var name_start := parser_tok_start(p, p.pos)
        var name_len   := parser_tok_end(p, p.pos) - name_start
        parser_advance(p)

        /* Generic application: Foo(T, U) */
        if parser_check(p, TK_LPAREN) then
            parser_advance(p)
            var args := maia_mmap(128)
            var arg_count: uint32 := 0
            while not parser_check(p, TK_RPAREN) and not parser_at_end(p) do
                var a := parse_type_expr(p)
                store64(args + (arg_count as uint64) * 8, a)
                arg_count := arg_count + 1
                if parser_check(p, TK_COMMA) then parser_advance(p) end
            end
            parser_try_consume(p, TK_RPAREN)
            var node := ast_alloc(p.arena, NODE_HDR_BYTES + 24)
            node_set_kind(node, TYPE_GENERIC)
            node_set_span(node, span)
            store32(node + NODE_HDR_BYTES,      name_start as int32)
            store32(node + NODE_HDR_BYTES + 4,  name_len as int32)
            store64(node + NODE_HDR_BYTES + 8,  args)
            store32(node + NODE_HDR_BYTES + 16, arg_count as int32)
            return node
        end

        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
        node_set_kind(node, TYPE_NAMED)
        node_set_span(node, span)
        store32(node + NODE_HDR_BYTES,     name_start as int32)
        store32(node + NODE_HDR_BYTES + 4, name_len as int32)
        if ownership != OWN_NONE then
            var onode := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
            node_set_kind(onode, TYPE_OWNED)
            node_set_span(onode, span)
            store32(onode + NODE_HDR_BYTES,     ownership)
            store64(onode + NODE_HDR_BYTES + 8, node)
            return onode
        end
        return node
    end

    /* Unit type () */
    var node := ast_alloc(p.arena, NODE_HDR_BYTES)
    node_set_kind(node, TYPE_UNIT)
    node_set_span(node, span)
    return node
end

/* ── Statement parser ────────────────────────────────────────────────────────── */

function parse_stmt(p: mut Parser): uint64 begin
    var span := parser_current_span(p)
    var k := parser_peek(p)

    if k == TK_BEGIN   then return parse_block_stmt(p) end
    if k == TK_VAR     then return parse_var_stmt(p, span) end
    if k == TK_CONST   then return parse_const_stmt(p, span) end
    if k == TK_IF      then return parse_if_stmt(p, span) end
    if k == TK_WHILE   then return parse_while_stmt(p, span) end
    if k == TK_FOR     then return parse_for_stmt(p, span) end
    if k == TK_LOOP    then return parse_loop_stmt(p, span) end
    if k == TK_RETURN  then return parse_return_stmt(p, span) end
    if k == TK_BREAK   then
        parser_advance(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES)
        node_set_kind(node, STMT_BREAK)
        node_set_span(node, span)
        return node
    end
    if k == TK_CONTINUE then
        parser_advance(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES)
        node_set_kind(node, STMT_CONTINUE)
        node_set_span(node, span)
        return node
    end
    if k == TK_MATCH  then return parse_match_stmt(p, span) end
    if k == TK_DEFER  then return parse_defer_stmt(p, span) end
    if k == TK_UNSAFE then return parse_unsafe_stmt(p, span) end
    if k == TK_SAFE   then return parse_safe_stmt(p, span) end

    /* Expression statement or assignment */
    var expr := parse_expr(p)
    /* Check for assignment operators */
    var ak := parser_peek(p)
    if ak == TK_COLON_EQ or ak == TK_PLUS_EQ or ak == TK_MINUS_EQ or
       ak == TK_STAR_EQ  or ak == TK_SLASH_EQ or ak == TK_PERCENT_EQ or
       ak == TK_AMP_EQ   or ak == TK_PIPE_EQ  or ak == TK_CARET_EQ or
       ak == TK_LT_LT_EQ or ak == TK_GT_GT_EQ then
        var op := assign_op_from_tk(ak)
        parser_advance(p)
        var rhs := parse_expr(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 24)
        node_set_kind(node, STMT_ASSIGN)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES,      expr)
        store64(node + NODE_HDR_BYTES + 8,  rhs)
        store32(node + NODE_HDR_BYTES + 16, op)
        return node
    end

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
    node_set_kind(node, STMT_EXPR)
    node_set_span(node, span)
    store64(node + NODE_HDR_BYTES, expr)
    return node
end

function assign_op_from_tk(k: int32): int32 begin
    if k == TK_COLON_EQ  then return BINOP_ASSIGN end
    if k == TK_PLUS_EQ   then return BINOP_ADD_ASSIGN end
    if k == TK_MINUS_EQ  then return BINOP_SUB_ASSIGN end
    if k == TK_STAR_EQ   then return BINOP_MUL_ASSIGN end
    if k == TK_SLASH_EQ  then return BINOP_DIV_ASSIGN end
    if k == TK_PERCENT_EQ then return BINOP_MOD_ASSIGN end
    if k == TK_AMP_EQ    then return BINOP_AND_ASSIGN end
    if k == TK_PIPE_EQ   then return BINOP_OR_ASSIGN end
    if k == TK_CARET_EQ  then return BINOP_XOR_ASSIGN end
    if k == TK_LT_LT_EQ  then return BINOP_SHL_ASSIGN end
    if k == TK_GT_GT_EQ  then return BINOP_SHR_ASSIGN end
    return BINOP_ASSIGN
end

function parse_block_stmt(p: mut Parser): uint64 begin
    var span := parser_current_span(p)
    parser_expect(p, TK_BEGIN)

    var stmts := maia_mmap(4096)
    var count: uint32 := 0

    while not parser_check(p, TK_END) and not parser_at_end(p) do
        var s := parse_stmt(p)
        if s != 0 then
            store64(stmts + (count as uint64) * 8, s)
            count := count + 1
        end
    end
    parser_expect(p, TK_END)

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
    node_set_kind(node, STMT_BLOCK)
    node_set_span(node, span)
    store64(node + NODE_HDR_BYTES,     stmts)
    store32(node + NODE_HDR_BYTES + 8, count as int32)
    return node
end

function parse_var_stmt(p: mut Parser, span: Span): uint64 begin
    parser_advance(p)  /* 'var' */
    var ownership: int32 := OWN_NONE
    if parser_check(p, TK_MUT)  then ownership := OWN_MUT;  parser_advance(p) end
    if parser_check(p, TK_OWN)  then ownership := OWN_OWN;  parser_advance(p) end

    var name_start := parser_tok_start(p, p.pos)
    var name_len   := parser_tok_end(p, p.pos) - name_start
    parser_advance(p)
    var ty: uint64 := 0
    if parser_check(p, TK_COLON) then
        parser_advance(p)
        ty := parse_type_expr(p)
    end
    var init: uint64 := 0
    if parser_check(p, TK_COLON_EQ) or parser_check(p, TK_EQ) then
        parser_advance(p)
        init := parse_expr(p)
    end

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 40)
    node_set_kind(node, STMT_VAR_DECL)
    node_set_span(node, span)
    store32(node + NODE_HDR_BYTES,      name_start as int32)
    store32(node + NODE_HDR_BYTES + 4,  name_len as int32)
    store64(node + NODE_HDR_BYTES + 8,  ty)
    store64(node + NODE_HDR_BYTES + 16, init)
    store32(node + NODE_HDR_BYTES + 24, ownership)
    return node
end

function parse_const_stmt(p: mut Parser, span: Span): uint64 begin
    parser_advance(p)
    var name_start := parser_tok_start(p, p.pos)
    var name_len   := parser_tok_end(p, p.pos) - name_start
    parser_advance(p)
    var ty: uint64 := 0
    if parser_check(p, TK_COLON) then
        parser_advance(p)
        ty := parse_type_expr(p)
    end
    parser_expect(p, TK_EQ)
    var value := parse_expr(p)

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 32)
    node_set_kind(node, STMT_CONST_DECL)
    node_set_span(node, span)
    store32(node + NODE_HDR_BYTES,      name_start as int32)
    store32(node + NODE_HDR_BYTES + 4,  name_len as int32)
    store64(node + NODE_HDR_BYTES + 8,  ty)
    store64(node + NODE_HDR_BYTES + 16, value)
    return node
end

function parse_if_stmt(p: mut Parser, span: Span): uint64 begin
    parser_advance(p)  /* 'if' */
    var cond := parse_expr(p)
    parser_expect(p, TK_THEN)
    /* then-branch: statements until elsif/else/end */
    var then_stmts := maia_mmap(4096)
    var then_count: uint32 := 0
    while not parser_check(p, TK_ELSIF) and not parser_check(p, TK_ELSE) and
          not parser_check(p, TK_END) and not parser_at_end(p) do
        var s := parse_stmt(p)
        if s != 0 then
            store64(then_stmts + (then_count as uint64) * 8, s)
            then_count := then_count + 1
        end
    end
    /* Package then-branch as a block */
    var then_block := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
    node_set_kind(then_block, STMT_BLOCK)
    node_set_span(then_block, span)
    store64(then_block + NODE_HDR_BYTES,     then_stmts)
    store32(then_block + NODE_HDR_BYTES + 8, then_count as int32)

    /* elsif branches */
    var elsif_arr := maia_mmap(512)
    var elsif_count: uint32 := 0
    while parser_check(p, TK_ELSIF) do
        parser_advance(p)
        var ec := parse_expr(p)
        parser_expect(p, TK_THEN)
        var es_stmts := maia_mmap(4096)
        var es_count: uint32 := 0
        while not parser_check(p, TK_ELSIF) and not parser_check(p, TK_ELSE) and
              not parser_check(p, TK_END) and not parser_at_end(p) do
            var s := parse_stmt(p)
            if s != 0 then
                store64(es_stmts + (es_count as uint64) * 8, s)
                es_count := es_count + 1
            end
        end
        var es_block := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
        node_set_kind(es_block, STMT_BLOCK)
        node_set_span(es_block, span)
        store64(es_block + NODE_HDR_BYTES,     es_stmts)
        store32(es_block + NODE_HDR_BYTES + 8, es_count as int32)
        /* Store (cond_ptr, block_ptr) pair */
        store64(elsif_arr + (elsif_count as uint64) * 16,     ec)
        store64(elsif_arr + (elsif_count as uint64) * 16 + 8, es_block)
        elsif_count := elsif_count + 1
    end

    var else_block: uint64 := 0
    if parser_check(p, TK_ELSE) then
        parser_advance(p)
        var el_stmts := maia_mmap(4096)
        var el_count: uint32 := 0
        while not parser_check(p, TK_END) and not parser_at_end(p) do
            var s := parse_stmt(p)
            if s != 0 then
                store64(el_stmts + (el_count as uint64) * 8, s)
                el_count := el_count + 1
            end
        end
        else_block := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
        node_set_kind(else_block, STMT_BLOCK)
        node_set_span(else_block, span)
        store64(else_block + NODE_HDR_BYTES,     el_stmts)
        store32(else_block + NODE_HDR_BYTES + 8, el_count as int32)
    end
    parser_expect(p, TK_END)

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 48)
    node_set_kind(node, STMT_IF)
    node_set_span(node, span)
    store64(node + NODE_HDR_BYTES,      cond)
    store64(node + NODE_HDR_BYTES + 8,  then_block)
    store64(node + NODE_HDR_BYTES + 16, elsif_arr)
    store32(node + NODE_HDR_BYTES + 24, elsif_count as int32)
    store64(node + NODE_HDR_BYTES + 32, else_block)
    return node
end

function parse_while_stmt(p: mut Parser, span: Span): uint64 begin
    parser_advance(p)  /* 'while' */
    var cond := parse_expr(p)
    parser_expect(p, TK_DO)
    var body := parse_block_body_until_end(p, span)

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
    node_set_kind(node, STMT_WHILE)
    node_set_span(node, span)
    store64(node + NODE_HDR_BYTES,     cond)
    store64(node + NODE_HDR_BYTES + 8, body)
    return node
end

function parse_for_stmt(p: mut Parser, span: Span): uint64 begin
    parser_advance(p)  /* 'for' */
    /* for [idx,] item in iter do … end */
    var index_var: uint32 := 0
    var index_len: uint32 := 0
    var item_start := parser_tok_start(p, p.pos)
    var item_len   := parser_tok_end(p, p.pos) - item_start
    parser_advance(p)

    /* Check for index variable: "for idx, item in …" */
    if parser_check(p, TK_COMMA) then
        parser_advance(p)
        index_var  := item_start
        index_len  := item_len
        item_start := parser_tok_start(p, p.pos)
        item_len   := parser_tok_end(p, p.pos) - item_start
        parser_advance(p)
    end

    parser_expect(p, TK_IN)
    var iter := parse_expr(p)
    parser_expect(p, TK_DO)
    var body := parse_block_body_until_end(p, span)

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 48)
    node_set_kind(node, STMT_FOR)
    node_set_span(node, span)
    store32(node + NODE_HDR_BYTES,      item_start as int32)
    store32(node + NODE_HDR_BYTES + 4,  item_len as int32)
    store32(node + NODE_HDR_BYTES + 8,  index_var as int32)
    store32(node + NODE_HDR_BYTES + 12, index_len as int32)
    store64(node + NODE_HDR_BYTES + 16, iter)
    store64(node + NODE_HDR_BYTES + 24, body)
    return node
end

function parse_loop_stmt(p: mut Parser, span: Span): uint64 begin
    parser_advance(p)  /* 'loop' */
    var body := parse_block_body_until_end(p, span)
    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
    node_set_kind(node, STMT_LOOP)
    node_set_span(node, span)
    store64(node + NODE_HDR_BYTES, body)
    return node
end

function parse_block_body_until_end(p: mut Parser, span: Span): uint64 begin
    var stmts := maia_mmap(4096)
    var count: uint32 := 0
    while not parser_check(p, TK_END) and not parser_at_end(p) do
        var s := parse_stmt(p)
        if s != 0 then
            store64(stmts + (count as uint64) * 8, s)
            count := count + 1
        end
    end
    parser_expect(p, TK_END)
    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
    node_set_kind(node, STMT_BLOCK)
    node_set_span(node, span)
    store64(node + NODE_HDR_BYTES,     stmts)
    store32(node + NODE_HDR_BYTES + 8, count as int32)
    return node
end

function parse_return_stmt(p: mut Parser, span: Span): uint64 begin
    parser_advance(p)  /* 'return' */
    var value: uint64 := 0
    var k := parser_peek(p)
    if k != TK_END and k != TK_ELSIF and k != TK_ELSE and
       k != TK_EOF and k != TK_SEMICOLON then
        value := parse_expr(p)
    end
    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
    node_set_kind(node, STMT_RETURN)
    node_set_span(node, span)
    store64(node + NODE_HDR_BYTES, value)
    return node
end

function parse_match_stmt(p: mut Parser, span: Span): uint64 begin
    parser_advance(p)  /* 'match' */
    var subject := parse_expr(p)
    parser_expect(p, TK_LBRACE)

    var arms := maia_mmap(1024)
    var arm_count: uint32 := 0

    while not parser_check(p, TK_RBRACE) and not parser_at_end(p) do
        var arm := parse_match_arm(p)
        if arm != 0 then
            store64(arms + (arm_count as uint64) * 8, arm)
            arm_count := arm_count + 1
        end
        parser_try_consume(p, TK_COMMA)
    end
    parser_expect(p, TK_RBRACE)

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 24)
    node_set_kind(node, STMT_MATCH)
    node_set_span(node, span)
    store64(node + NODE_HDR_BYTES,      subject)
    store64(node + NODE_HDR_BYTES + 8,  arms)
    store32(node + NODE_HDR_BYTES + 16, arm_count as int32)
    return node
end

function parse_match_arm(p: mut Parser): uint64 begin
    var span := parser_current_span(p)
    /* Pattern: integer literal, ident, string literal, or 'else' */
    var pattern: uint64 := 0
    var pat_kind: int32 := 0

    if parser_check(p, TK_ELSE) then
        pat_kind := 5  /* else pattern */
        parser_advance(p)
    elsif parser_check(p, TK_INT_LIT) then
        pat_kind := 1
        var ps := parser_current_span(p)
        pattern := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
        node_set_kind(pattern, EXPR_INT_LIT)
        node_set_span(pattern, ps)
        parser_advance(p)
    elsif parser_check(p, TK_STRING_LIT) then
        pat_kind := 2
        var ps := parser_current_span(p)
        pattern := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
        node_set_kind(pattern, EXPR_STRING_LIT)
        node_set_span(pattern, ps)
        parser_advance(p)
    else
        pat_kind := 3  /* ident pattern */
        var ps := parser_current_span(p)
        pattern := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
        node_set_kind(pattern, EXPR_IDENT)
        node_set_span(pattern, ps)
        store32(pattern + NODE_HDR_BYTES, parser_tok_start(p, p.pos) as int32)
        store32(pattern + NODE_HDR_BYTES + 4, (parser_tok_end(p, p.pos) - parser_tok_start(p, p.pos)) as int32)
        parser_advance(p)
    end

    parser_expect(p, TK_FAT_ARROW)

    /* Body: single stmt or begin…end block */
    var body: uint64 := 0
    if parser_check(p, TK_BEGIN) then
        body := parse_block_stmt(p)
    else
        body := parse_stmt(p)
    end

    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 24)
    node_set_kind(node, 0)
    node_set_span(node, span)
    store64(node + NODE_HDR_BYTES,      pattern)
    store32(node + NODE_HDR_BYTES + 8,  pat_kind)
    store64(node + NODE_HDR_BYTES + 16, body)
    return node
end

function parse_defer_stmt(p: mut Parser, span: Span): uint64 begin
    parser_advance(p)
    var body := parse_stmt(p)
    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
    node_set_kind(node, STMT_DEFER)
    node_set_span(node, span)
    store64(node + NODE_HDR_BYTES, body)
    return node
end

function parse_unsafe_stmt(p: mut Parser, span: Span): uint64 begin
    parser_advance(p)
    var body := parse_block_stmt(p)
    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
    node_set_kind(node, STMT_UNSAFE)
    node_set_span(node, span)
    store64(node + NODE_HDR_BYTES, body)
    return node
end

function parse_safe_stmt(p: mut Parser, span: Span): uint64 begin
    parser_advance(p)
    var body := parse_block_stmt(p)
    var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
    node_set_kind(node, STMT_SAFE)
    node_set_span(node, span)
    store64(node + NODE_HDR_BYTES, body)
    return node
end

/* ── Expression parser (Pratt / precedence climbing) ─────────────────────────── */

function parse_expr(p: mut Parser): uint64 begin
    return parse_expr_prec(p, 0)
end

function parse_expr_prec(p: mut Parser, min_prec: int32): uint64 begin
    var lhs := parse_unary(p)
    loop
        var k := parser_peek(p)
        var prec := binop_prec(k)
        if prec < min_prec or prec < 0 then break end

        var span := parser_current_span(p)
        var op := binop_from_tk(k)
        parser_advance(p)

        /* Right-associative for range and assign; left-associative otherwise */
        var next_prec := prec + 1
        if op == BINOP_RANGE or op == BINOP_RANGE_EXCL then next_prec := prec end

        var rhs := parse_expr_prec(p, next_prec)

        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 24)
        node_set_kind(node, EXPR_BINARY)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES,      lhs)
        store64(node + NODE_HDR_BYTES + 8,  rhs)
        store32(node + NODE_HDR_BYTES + 16, op)
        lhs := node
    end
    return lhs
end

function binop_prec(k: int32): int32 begin
    if k == TK_OR then return 1 end
    if k == TK_AND then return 2 end
    if k == TK_EQ_EQ or k == TK_BANG_EQ then return 3 end
    if k == TK_LT or k == TK_GT or k == TK_LT_EQ or k == TK_GT_EQ then return 4 end
    if k == TK_DOT_DOT or k == TK_DOT_DOT_LT then return 5 end
    if k == TK_PIPE then return 6 end
    if k == TK_CARET then return 7 end
    if k == TK_AMP then return 8 end
    if k == TK_LT_LT or k == TK_GT_GT then return 9 end
    if k == TK_PLUS or k == TK_MINUS then return 10 end
    if k == TK_STAR or k == TK_SLASH or k == TK_PERCENT or k == TK_SLASH_SLASH then return 11 end
    return -1
end

function binop_from_tk(k: int32): int32 begin
    if k == TK_PLUS then return BINOP_ADD end
    if k == TK_MINUS then return BINOP_SUB end
    if k == TK_STAR then return BINOP_MUL end
    if k == TK_SLASH then return BINOP_DIV end
    if k == TK_PERCENT then return BINOP_MOD end
    if k == TK_SLASH_SLASH then return BINOP_INT_DIV end
    if k == TK_EQ_EQ then return BINOP_EQ end
    if k == TK_BANG_EQ then return BINOP_NE end
    if k == TK_LT then return BINOP_LT end
    if k == TK_GT then return BINOP_GT end
    if k == TK_LT_EQ then return BINOP_LE end
    if k == TK_GT_EQ then return BINOP_GE end
    if k == TK_AND then return BINOP_AND end
    if k == TK_OR then return BINOP_OR end
    if k == TK_AMP then return BINOP_BIT_AND end
    if k == TK_PIPE then return BINOP_BIT_OR end
    if k == TK_CARET then return BINOP_BIT_XOR end
    if k == TK_LT_LT then return BINOP_SHL end
    if k == TK_GT_GT then return BINOP_SHR end
    if k == TK_DOT_DOT then return BINOP_RANGE end
    if k == TK_DOT_DOT_LT then return BINOP_RANGE_EXCL end
    return BINOP_ADD
end

function parse_unary(p: mut Parser): uint64 begin
    var span := parser_current_span(p)
    var k := parser_peek(p)

    if k == TK_MINUS then
        parser_advance(p)
        var operand := parse_unary(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
        node_set_kind(node, EXPR_UNARY)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES,     operand)
        store32(node + NODE_HDR_BYTES + 8, UNOP_NEG)
        return node
    end
    if k == TK_NOT or k == TK_BANG then
        parser_advance(p)
        var operand := parse_unary(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
        node_set_kind(node, EXPR_UNARY)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES,     operand)
        store32(node + NODE_HDR_BYTES + 8, UNOP_NOT)
        return node
    end
    if k == TK_TILDE then
        parser_advance(p)
        var operand := parse_unary(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
        node_set_kind(node, EXPR_UNARY)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES,     operand)
        store32(node + NODE_HDR_BYTES + 8, UNOP_BIT_NOT)
        return node
    end
    if k == TK_AMP then
        parser_advance(p)
        var operand := parse_unary(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
        node_set_kind(node, EXPR_UNARY)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES,     operand)
        store32(node + NODE_HDR_BYTES + 8, UNOP_ADDR_OF)
        return node
    end
    if k == TK_STAR then
        parser_advance(p)
        var operand := parse_unary(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
        node_set_kind(node, EXPR_UNARY)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES,     operand)
        store32(node + NODE_HDR_BYTES + 8, UNOP_DEREF)
        return node
    end
    if k == TK_CONSUME then
        parser_advance(p)
        var operand := parse_unary(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
        node_set_kind(node, EXPR_CONSUME)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES, operand)
        return node
    end
    if k == TK_AWAIT then
        parser_advance(p)
        var operand := parse_unary(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
        node_set_kind(node, EXPR_AWAIT)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES, operand)
        return node
    end
    if k == TK_SPAWN then
        parser_advance(p)
        var call := parse_unary(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
        node_set_kind(node, EXPR_SPAWN)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES, call)
        return node
    end

    return parse_postfix(p)
end

function parse_postfix(p: mut Parser): uint64 begin
    var lhs := parse_primary(p)
    loop
        var span := parser_current_span(p)
        var k := parser_peek(p)

        /* Cast: expr as Type */
        if k == TK_AS then
            parser_advance(p)
            var ty := parse_type_expr(p)
            var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
            node_set_kind(node, EXPR_CAST)
            node_set_span(node, span)
            store64(node + NODE_HDR_BYTES,     lhs)
            store64(node + NODE_HDR_BYTES + 8, ty)
            lhs := node
            continue
        end

        /* Default operator: expr ?? fallback */
        if k == TK_QUESTION_QUESTION then
            parser_advance(p)
            var fallback := parse_expr_prec(p, 0)
            var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
            node_set_kind(node, EXPR_DEFAULT)
            node_set_span(node, span)
            store64(node + NODE_HDR_BYTES,     lhs)
            store64(node + NODE_HDR_BYTES + 8, fallback)
            lhs := node
            continue
        end

        /* Call: expr(args) */
        if k == TK_LPAREN then
            parser_advance(p)
            var args := maia_mmap(512)
            var arg_count: uint32 := 0
            while not parser_check(p, TK_RPAREN) and not parser_at_end(p) do
                var a := parse_expr(p)
                store64(args + (arg_count as uint64) * 8, a)
                arg_count := arg_count + 1
                if parser_check(p, TK_COMMA) then parser_advance(p) end
            end
            parser_try_consume(p, TK_RPAREN)
            var node := ast_alloc(p.arena, NODE_HDR_BYTES + 24)
            node_set_kind(node, EXPR_CALL)
            node_set_span(node, span)
            store64(node + NODE_HDR_BYTES,      lhs)
            store64(node + NODE_HDR_BYTES + 8,  args)
            store32(node + NODE_HDR_BYTES + 16, arg_count as int32)
            lhs := node
            continue
        end

        /* Index: expr[idx] */
        if k == TK_LBRACKET then
            parser_advance(p)
            var idx := parse_expr(p)
            /* Slice: expr[lo..hi] */
            if parser_check(p, TK_DOT_DOT) or parser_check(p, TK_DOT_DOT_LT) then
                var excl := if parser_check(p, TK_DOT_DOT_LT) then 1 else 0 end
                parser_advance(p)
                var hi: uint64 := 0
                if not parser_check(p, TK_RBRACKET) then hi := parse_expr(p) end
                parser_expect(p, TK_RBRACKET)
                var node := ast_alloc(p.arena, NODE_HDR_BYTES + 32)
                node_set_kind(node, EXPR_SLICE_EXPR)
                node_set_span(node, span)
                store64(node + NODE_HDR_BYTES,      lhs)
                store64(node + NODE_HDR_BYTES + 8,  idx)
                store64(node + NODE_HDR_BYTES + 16, hi)
                store32(node + NODE_HDR_BYTES + 24, excl)
                lhs := node
            else
                parser_expect(p, TK_RBRACKET)
                var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
                node_set_kind(node, EXPR_INDEX)
                node_set_span(node, span)
                store64(node + NODE_HDR_BYTES,     lhs)
                store64(node + NODE_HDR_BYTES + 8, idx)
                lhs := node
            end
            continue
        end

        /* Field access or method call: expr.name or expr.name(args) */
        if k == TK_DOT then
            parser_advance(p)
            var field_start := parser_tok_start(p, p.pos)
            var field_len   := parser_tok_end(p, p.pos) - field_start
            parser_advance(p)

            if parser_check(p, TK_LPAREN) then
                /* Method call */
                parser_advance(p)
                var args := maia_mmap(512)
                var arg_count: uint32 := 0
                while not parser_check(p, TK_RPAREN) and not parser_at_end(p) do
                    var a := parse_expr(p)
                    store64(args + (arg_count as uint64) * 8, a)
                    arg_count := arg_count + 1
                    if parser_check(p, TK_COMMA) then parser_advance(p) end
                end
                parser_try_consume(p, TK_RPAREN)
                var node := ast_alloc(p.arena, NODE_HDR_BYTES + 32)
                node_set_kind(node, EXPR_METHOD_CALL)
                node_set_span(node, span)
                store64(node + NODE_HDR_BYTES,      lhs)
                store32(node + NODE_HDR_BYTES + 8,  field_start as int32)
                store32(node + NODE_HDR_BYTES + 12, field_len as int32)
                store64(node + NODE_HDR_BYTES + 16, args)
                store32(node + NODE_HDR_BYTES + 24, arg_count as int32)
                lhs := node
            else
                /* Field access */
                var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
                node_set_kind(node, EXPR_FIELD)
                node_set_span(node, span)
                store64(node + NODE_HDR_BYTES,     lhs)
                store32(node + NODE_HDR_BYTES + 8,  field_start as int32)
                store32(node + NODE_HDR_BYTES + 12, field_len as int32)
                lhs := node
            end
            continue
        end

        break
    end
    return lhs
end

function parse_primary(p: mut Parser): uint64 begin
    var span := parser_current_span(p)
    var k := parser_peek(p)

    /* Integer literal */
    if k == TK_INT_LIT then
        parser_advance(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
        node_set_kind(node, EXPR_INT_LIT)
        node_set_span(node, span)
        return node
    end

    /* Float literal */
    if k == TK_FLOAT_LIT then
        parser_advance(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
        node_set_kind(node, EXPR_FLOAT_LIT)
        node_set_span(node, span)
        return node
    end

    /* String literal */
    if k == TK_STRING_LIT then
        parser_advance(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
        node_set_kind(node, EXPR_STRING_LIT)
        node_set_span(node, span)
        return node
    end

    /* Bool literals */
    if k == TK_TRUE then
        parser_advance(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
        node_set_kind(node, EXPR_BOOL_LIT)
        node_set_span(node, span)
        store32(node + NODE_HDR_BYTES, 1)
        return node
    end
    if k == TK_FALSE then
        parser_advance(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
        node_set_kind(node, EXPR_BOOL_LIT)
        node_set_span(node, span)
        store32(node + NODE_HDR_BYTES, 0)
        return node
    end

    /* Null literal */
    if k == TK_NULL then
        parser_advance(p)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES)
        node_set_kind(node, EXPR_NULL_LIT)
        node_set_span(node, span)
        return node
    end

    /* Grouped expression: ( expr ) */
    if k == TK_LPAREN then
        parser_advance(p)
        var inner := parse_expr(p)
        parser_expect(p, TK_RPAREN)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 8)
        node_set_kind(node, EXPR_GROUPED)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES, inner)
        return node
    end

    /* Array literal: [ e1, e2, … ] */
    if k == TK_LBRACKET then
        parser_advance(p)
        var elems := maia_mmap(512)
        var elem_count: uint32 := 0
        while not parser_check(p, TK_RBRACKET) and not parser_at_end(p) do
            var e := parse_expr(p)
            store64(elems + (elem_count as uint64) * 8, e)
            elem_count := elem_count + 1
            if parser_check(p, TK_COMMA) then parser_advance(p) end
        end
        parser_expect(p, TK_RBRACKET)
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
        node_set_kind(node, EXPR_ARRAY_LIT)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES,     elems)
        store32(node + NODE_HDR_BYTES + 8, elem_count as int32)
        return node
    end

    /* Builtin call: @name(args) */
    if k == TK_AT then
        parser_advance(p)
        var name_start := parser_tok_start(p, p.pos)
        var name_len   := parser_tok_end(p, p.pos) - name_start
        parser_advance(p)
        var args := maia_mmap(128)
        var arg_count: uint32 := 0
        if parser_check(p, TK_LPAREN) then
            parser_advance(p)
            while not parser_check(p, TK_RPAREN) and not parser_at_end(p) do
                var a := parse_expr(p)
                store64(args + (arg_count as uint64) * 8, a)
                arg_count := arg_count + 1
                if parser_check(p, TK_COMMA) then parser_advance(p) end
            end
            parser_try_consume(p, TK_RPAREN)
        end
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 24)
        node_set_kind(node, EXPR_BUILTIN_CALL)
        node_set_span(node, span)
        store32(node + NODE_HDR_BYTES,      name_start as int32)
        store32(node + NODE_HDR_BYTES + 4,  name_len as int32)
        store64(node + NODE_HDR_BYTES + 8,  args)
        store32(node + NODE_HDR_BYTES + 16, arg_count as int32)
        return node
    end

    /* If expression (used as expr, e.g. `if cond then val else val end`) */
    if k == TK_IF then
        parser_advance(p)
        var cond := parse_expr(p)
        parser_expect(p, TK_THEN)
        var then_val := parse_expr(p)
        var else_val: uint64 := 0
        if parser_check(p, TK_ELSE) then
            parser_advance(p)
            else_val := parse_expr(p)
        end
        parser_try_consume(p, TK_END)
        /* Reuse STMT_IF node as inline-if expression (kind = STMT_IF, but treated as expr) */
        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 24)
        node_set_kind(node, STMT_IF)
        node_set_span(node, span)
        store64(node + NODE_HDR_BYTES,      cond)
        store64(node + NODE_HDR_BYTES + 8,  then_val)
        store64(node + NODE_HDR_BYTES + 16, else_val)
        return node
    end

    /* Identifier (or struct literal) */
    if k == TK_IDENT then
        var name_start := parser_tok_start(p, p.pos)
        var name_len   := parser_tok_end(p, p.pos) - name_start
        parser_advance(p)

        /* Struct literal: Ident { .field = expr, … } */
        if parser_check(p, TK_LBRACE) then
            parser_advance(p)
            var fields := maia_mmap(512)
            var field_count: uint32 := 0
            while not parser_check(p, TK_RBRACE) and not parser_at_end(p) do
                if parser_check(p, TK_DOT) then
                    parser_advance(p)
                    var fn_start := parser_tok_start(p, p.pos)
                    var fn_len   := parser_tok_end(p, p.pos) - fn_start
                    parser_advance(p)
                    parser_expect(p, TK_EQ)
                    var fval := parse_expr(p)
                    /* Store field init as (name_start, name_len, val) triple */
                    store32(fields + (field_count as uint64) * 24,      fn_start as int32)
                    store32(fields + (field_count as uint64) * 24 + 4,  fn_len as int32)
                    store64(fields + (field_count as uint64) * 24 + 8,  fval)
                    field_count := field_count + 1
                    if parser_check(p, TK_COMMA) then parser_advance(p) end
                else
                    parser_advance(p)
                end
            end
            parser_expect(p, TK_RBRACE)
            var node := ast_alloc(p.arena, NODE_HDR_BYTES + 32)
            node_set_kind(node, EXPR_STRUCT_LIT)
            node_set_span(node, span)
            store32(node + NODE_HDR_BYTES,      name_start as int32)
            store32(node + NODE_HDR_BYTES + 4,  name_len as int32)
            store64(node + NODE_HDR_BYTES + 8,  fields)
            store32(node + NODE_HDR_BYTES + 16, field_count as int32)
            return node
        end

        var node := ast_alloc(p.arena, NODE_HDR_BYTES + 16)
        node_set_kind(node, EXPR_IDENT)
        node_set_span(node, span)
        store32(node + NODE_HDR_BYTES,     name_start as int32)
        store32(node + NODE_HDR_BYTES + 4, name_len as int32)
        return node
    end

    /* Wildcard/placeholder expression */
    var node := ast_alloc(p.arena, NODE_HDR_BYTES)
    node_set_kind(node, EXPR_NULL_LIT)
    node_set_span(node, span)
    return node
end
/// Maia self-hosted compiler — semantic analyzer.
/// Performs name resolution, type inference, and type checking.

module Sema

use AST

extern function maia_mmap(len: uint64): uint64
extern function store32(addr: uint64, v: int32)
extern function store64(addr: uint64, v: uint64)
extern function load32(addr: uint64): int32
extern function load64(addr: uint64): uint64

/* ── Type IDs ────────────────────────────────────────────────────────────────── */

const TYPE_VOID:   int32 = 0
const TYPE_BOOL:   int32 = 1
const TYPE_INT8:   int32 = 2
const TYPE_INT16:  int32 = 3
const TYPE_INT32:  int32 = 4
const TYPE_INT64:  int32 = 5
const TYPE_UINT8:  int32 = 6
const TYPE_UINT16: int32 = 7
const TYPE_UINT32: int32 = 8
const TYPE_UINT64: int32 = 9
const TYPE_F32:    int32 = 10
const TYPE_F64:    int32 = 11
const TYPE_STRING: int32 = 12
const TYPE_USIZE:  int32 = 13
const TYPE_ISIZE:  int32 = 14
const TYPE_NULL:   int32 = 15
const TYPE_FIRST_USER: int32 = 16

/* ── Symbol kinds ────────────────────────────────────────────────────────────── */

const SYM_VAR:      int32 = 0
const SYM_CONST:    int32 = 1
const SYM_FUNCTION: int32 = 2
const SYM_PROC:     int32 = 3
const SYM_TYPE:     int32 = 4
const SYM_MODULE:   int32 = 5

/* ── Symbol entry (stored in hash table) ────────────────────────────────────── */
/* Layout: name_ptr(8), name_len(4), kind(4), type_id(4), is_mutable(4), */
/*         ownership(4), _pad(4) = 32 bytes */

const SYMBOL_BYTES: uint32 = 32

/* ── Simple open-addressing hash table for symbols ───────────────────────────── */

type SymbolTable = struct {
    buckets: uint64,  /* ptr to Symbol[cap] */
    cap:     uint32,
    count:   uint32,
    parent:  uint64,  /* ptr to parent SymbolTable (0 = global) */
}

function symtab_new(parent: uint64): SymbolTable begin
    const CAP: uint32 = 64
    var buckets := maia_mmap((CAP as uint64) * SYMBOL_BYTES as uint64)
    return SymbolTable { .buckets = buckets, .cap = CAP, .count = 0, .parent = parent }
end

/* FNV-1a hash for a name slice */
function name_hash(name_ptr: uint64, name_len: uint32): uint32 begin
    var h: uint32 := 2166136261
    var i: uint32 := 0
    while i < name_len do
        var b := load_byte(name_ptr + i as uint64)
        h := h ^ b as uint32
        h := h * 16777619
        i := i + 1
    end
    return h
end

extern function load_byte(addr: uint64): int32

function names_equal(a_ptr: uint64, a_len: uint32, b_ptr: uint64, b_len: uint32): bool begin
    if a_len != b_len then return false end
    var i: uint32 := 0
    while i < a_len do
        if load_byte(a_ptr + i as uint64) != load_byte(b_ptr + i as uint64) then
            return false
        end
        i := i + 1
    end
    return true
end

procedure symtab_define(tab: mut SymbolTable, name_ptr: uint64, name_len: uint32,
                          kind: int32, type_id: int32, is_mutable: int32, ownership: int32) begin
    var h := name_hash(name_ptr, name_len) % tab.cap
    var i := h
    loop
        var slot := tab.buckets + (i as uint64) * SYMBOL_BYTES as uint64
        var existing_len := load32(slot + 8)
        if existing_len == 0 then
            /* Empty slot — write here */
            store64(slot,     name_ptr)
            store32(slot + 8,  name_len as int32)
            store32(slot + 12, kind)
            store32(slot + 16, type_id)
            store32(slot + 20, is_mutable)
            store32(slot + 24, ownership)
            tab.count := tab.count + 1
            break
        end
        i := (i + 1) % tab.cap
        if i == h then break end  /* table full (shouldn't happen with our capacities) */
    end
end

function symtab_lookup(tab: ref SymbolTable, name_ptr: uint64, name_len: uint32): uint64 begin
    /* Returns pointer to symbol slot, or 0 if not found */
    var h := name_hash(name_ptr, name_len) % tab.cap
    var i := h
    loop
        var slot := tab.buckets + (i as uint64) * SYMBOL_BYTES as uint64
        var slen := load32(slot + 8)
        if slen == 0 then
            break  /* not found in this scope */
        end
        var sptr := load64(slot)
        if names_equal(name_ptr, name_len, sptr, slen as uint32) then
            return slot
        end
        i := (i + 1) % tab.cap
        if i == h then break end
    end
    /* Check parent scope */
    if tab.parent != 0 then
        var parent_tab: SymbolTable := load_symtab(tab.parent)
        return symtab_lookup(parent_tab, name_ptr, name_len)
    end
    return 0
end

/* Load a SymbolTable from a pointer */
function load_symtab(ptr: uint64): SymbolTable begin
    return SymbolTable {
        .buckets = load64(ptr),
        .cap     = load32(ptr + 8)  as uint32,
        .count   = load32(ptr + 12) as uint32,
        .parent  = load64(ptr + 16),
    }
end

/* ── Type registry ───────────────────────────────────────────────────────────── */

type TypeRegistry = struct {
    types:   uint64,  /* flat buffer of type descriptors */
    count:   int32,
}

/* Type descriptor layout (32 bytes): */
/*   kind(4), bits(4), signed(4), is_ptr(4), inner_ty(4), _pad[12] */
const TYPE_DESC_BYTES: uint32 = 32

function typereg_new(): TypeRegistry begin
    var types := maia_mmap(16384)  /* room for 512 type descriptors */
    return TypeRegistry { .types = types, .count = 0 }
end

/* ── Sema context ────────────────────────────────────────────────────────────── */

type Sema = struct {
    global:    SymbolTable,
    current:   uint64,  /* ptr to current SymbolTable (stored in arena) */
    types:     TypeRegistry,
    diags:     uint64,  /* ptr to diagnostic buffer */
    diag_count:int32,
    src:       uint64,
    src_len:   uint32,
    ret_ty:    int32,  /* current function return type */
}

function sema_new(src: uint64, src_len: uint32): Sema begin
    var global := symtab_new(0)
    var types  := typereg_new()

    /* Register built-in type names in global scope */
    /* (we use string literal pointers from our own source for names) */
    /* Abbreviated: just record the type IDs by well-known names. */
    /* Full name resolution via keyword comparison in sema_resolve_type. */

    return Sema {
        .global     = global,
        .current    = 0,
        .types      = types,
        .diags      = maia_mmap(65536),
        .diag_count = 0,
        .src        = src,
        .src_len    = src_len,
        .ret_ty     = TYPE_VOID,
    }
end

/* Resolve a type name (given as src offset + length) to a TypeId. */
function sema_resolve_named_type(src: uint64, name_start: uint32, name_len: uint32): int32 begin
    /* Compare name against known primitive type names. */
    var c0 := load_byte(src + name_start as uint64)
    if name_len == 4 then
        /* "void" = 118 111 105 100 */
        if c0 == 118 and load_byte(src + name_start as uint64 + 1) == 111 and
           load_byte(src + name_start as uint64 + 2) == 105 and
           load_byte(src + name_start as uint64 + 3) == 100 then
            return TYPE_VOID
        end
        /* "bool" = 98 111 111 108 */
        if c0 == 98 and load_byte(src + name_start as uint64 + 1) == 111 and
           load_byte(src + name_start as uint64 + 2) == 111 and
           load_byte(src + name_start as uint64 + 3) == 108 then
            return TYPE_BOOL
        end
        /* "int8" = 105 110 116 56 */
        if c0 == 105 and load_byte(src + name_start as uint64 + 1) == 110 and
           load_byte(src + name_start as uint64 + 2) == 116 and
           load_byte(src + name_start as uint64 + 3) == 56 then
            return TYPE_INT8
        end
        /* "int8 " handled above; "f32 " = 102 51 50 (3 chars actually) */
    end
    if name_len == 3 then
        /* "f32" = 102 51 50 */
        if c0 == 102 and load_byte(src + name_start as uint64 + 1) == 51 and
           load_byte(src + name_start as uint64 + 2) == 50 then
            return TYPE_F32
        end
        /* "f64" = 102 54 52 */
        if c0 == 102 and load_byte(src + name_start as uint64 + 1) == 54 and
           load_byte(src + name_start as uint64 + 2) == 52 then
            return TYPE_F64
        end
        /* "u8 " = 117 56 (2 chars) */
    end
    if name_len == 2 then
        /* "u8" = 117 56 */
        if c0 == 117 and load_byte(src + name_start as uint64 + 1) == 56 then
            return TYPE_UINT8
        end
    end
    if name_len == 5 then
        /* "int16" = 105 110 116 49 54 */
        if c0 == 105 and load_byte(src + name_start as uint64 + 1) == 110 and
           load_byte(src + name_start as uint64 + 2) == 116 and
           load_byte(src + name_start as uint64 + 3) == 49 and
           load_byte(src + name_start as uint64 + 4) == 54 then
            return TYPE_INT16
        end
        /* "int32" = 105 110 116 51 50 */
        if c0 == 105 and load_byte(src + name_start as uint64 + 1) == 110 and
           load_byte(src + name_start as uint64 + 2) == 116 and
           load_byte(src + name_start as uint64 + 3) == 51 and
           load_byte(src + name_start as uint64 + 4) == 50 then
            return TYPE_INT32
        end
        /* "int64" = 105 110 116 54 52 */
        if c0 == 105 and load_byte(src + name_start as uint64 + 1) == 110 and
           load_byte(src + name_start as uint64 + 2) == 116 and
           load_byte(src + name_start as uint64 + 3) == 54 and
           load_byte(src + name_start as uint64 + 4) == 52 then
            return TYPE_INT64
        end
        /* "usize" = 117 115 105 122 101 */
        if c0 == 117 and load_byte(src + name_start as uint64 + 1) == 115 and
           load_byte(src + name_start as uint64 + 2) == 105 and
           load_byte(src + name_start as uint64 + 3) == 122 and
           load_byte(src + name_start as uint64 + 4) == 101 then
            return TYPE_USIZE
        end
        /* "isize" = 105 115 105 122 101 */
        if c0 == 105 and load_byte(src + name_start as uint64 + 1) == 115 and
           load_byte(src + name_start as uint64 + 2) == 105 and
           load_byte(src + name_start as uint64 + 3) == 122 and
           load_byte(src + name_start as uint64 + 4) == 101 then
            return TYPE_ISIZE
        end
    end
    if name_len == 6 then
        /* "uint32" = 117 105 110 116 51 50 */
        if c0 == 117 and load_byte(src + name_start as uint64 + 1) == 105 and
           load_byte(src + name_start as uint64 + 2) == 110 and
           load_byte(src + name_start as uint64 + 3) == 116 and
           load_byte(src + name_start as uint64 + 4) == 51 and
           load_byte(src + name_start as uint64 + 5) == 50 then
            return TYPE_UINT32
        end
        /* "uint64" = 117 105 110 116 54 52 */
        if c0 == 117 and load_byte(src + name_start as uint64 + 1) == 105 and
           load_byte(src + name_start as uint64 + 2) == 110 and
           load_byte(src + name_start as uint64 + 3) == 116 and
           load_byte(src + name_start as uint64 + 4) == 54 and
           load_byte(src + name_start as uint64 + 5) == 52 then
            return TYPE_UINT64
        end
        /* "string" = 115 116 114 105 110 103 */
        if c0 == 115 and load_byte(src + name_start as uint64 + 1) == 116 and
           load_byte(src + name_start as uint64 + 2) == 114 and
           load_byte(src + name_start as uint64 + 3) == 105 and
           load_byte(src + name_start as uint64 + 4) == 110 and
           load_byte(src + name_start as uint64 + 5) == 103 then
            return TYPE_STRING
        end
        /* "uint16" = 117 105 110 116 49 54 */
        if c0 == 117 and load_byte(src + name_start as uint64 + 1) == 105 and
           load_byte(src + name_start as uint64 + 2) == 110 and
           load_byte(src + name_start as uint64 + 3) == 116 and
           load_byte(src + name_start as uint64 + 4) == 49 and
           load_byte(src + name_start as uint64 + 5) == 54 then
            return TYPE_UINT16
        end
        /* "uint8 " = 117 105 110 116 56 (5 chars — oops, already handled above for 5-char check) */
    end
    if name_len == 5 then
        /* "uint8" = 117 105 110 116 56 */
        if c0 == 117 and load_byte(src + name_start as uint64 + 1) == 105 and
           load_byte(src + name_start as uint64 + 2) == 110 and
           load_byte(src + name_start as uint64 + 3) == 116 and
           load_byte(src + name_start as uint64 + 4) == 56 then
            return TYPE_UINT8
        end
    end
    /* Unknown type: return TYPE_FIRST_USER as a placeholder */
    return TYPE_FIRST_USER
end

/* Analyze an entire module (first pass: register, second pass: check). */
procedure sema_analyze_module(s: mut Sema, mod: ref Module) begin
    /* First pass: register top-level declarations */
    var i: uint32 := 0
    while i < mod.decl_count do
        var d := load64(mod.decls + (i as uint64) * 8)
        sema_register_decl(s, d)
        i := i + 1
    end
    /* Second pass: check bodies */
    i := 0
    while i < mod.decl_count do
        var d := load64(mod.decls + (i as uint64) * 8)
        sema_check_decl(s, d)
        i := i + 1
    end
end

procedure sema_register_decl(s: mut Sema, decl: uint64) begin
    var kind := node_kind(decl)
    if kind == DECL_FUNC then
        var name_start := load32(decl + NODE_HDR_BYTES) as uint32
        var name_len   := load32(decl + NODE_HDR_BYTES + 4) as uint32
        var name_ptr   := s.src + name_start as uint64
        symtab_define(s.global, name_ptr, name_len, SYM_FUNCTION, TYPE_VOID, 0, OWN_NONE)
    end
    if kind == DECL_PROC then
        var name_start := load32(decl + NODE_HDR_BYTES) as uint32
        var name_len   := load32(decl + NODE_HDR_BYTES + 4) as uint32
        var name_ptr   := s.src + name_start as uint64
        symtab_define(s.global, name_ptr, name_len, SYM_PROC, TYPE_VOID, 0, OWN_NONE)
    end
    if kind == DECL_TYPE then
        var name_start := load32(decl + NODE_HDR_BYTES) as uint32
        var name_len   := load32(decl + NODE_HDR_BYTES + 4) as uint32
        var name_ptr   := s.src + name_start as uint64
        symtab_define(s.global, name_ptr, name_len, SYM_TYPE, TYPE_FIRST_USER, 0, OWN_NONE)
    end
    if kind == DECL_CONST then
        var name_start := load32(decl + NODE_HDR_BYTES) as uint32
        var name_len   := load32(decl + NODE_HDR_BYTES + 4) as uint32
        var name_ptr   := s.src + name_start as uint64
        symtab_define(s.global, name_ptr, name_len, SYM_CONST, TYPE_INT32, 0, OWN_NONE)
    end
    if kind == DECL_EXTERN then
        var inner := load64(decl + NODE_HDR_BYTES)
        if inner != 0 then
            sema_register_decl(s, inner)
        end
    end
end

procedure sema_check_decl(s: mut Sema, decl: uint64) begin
    var kind := node_kind(decl)
    if kind == DECL_FUNC then
        var body := load64(decl + NODE_HDR_BYTES + 32)
        var ret_node := load64(decl + NODE_HDR_BYTES + 24)
        var prev_ret := s.ret_ty
        if ret_node != 0 then
            s.ret_ty := sema_resolve_type_node(s, ret_node)
        else
            s.ret_ty := TYPE_VOID
        end
        if body != 0 then sema_check_stmt(s, body) end
        s.ret_ty := prev_ret
    end
    if kind == DECL_PROC then
        var body := load64(decl + NODE_HDR_BYTES + 24)
        var prev_ret := s.ret_ty
        s.ret_ty := TYPE_VOID
        if body != 0 then sema_check_stmt(s, body) end
        s.ret_ty := prev_ret
    end
end

procedure sema_check_stmt(s: mut Sema, stmt: uint64) begin
    var kind := node_kind(stmt)
    if kind == STMT_BLOCK then
        var stmts := load64(stmt + NODE_HDR_BYTES)
        var count  := load32(stmt + NODE_HDR_BYTES + 8) as uint32
        var i: uint32 := 0
        while i < count do
            var child := load64(stmts + (i as uint64) * 8)
            sema_check_stmt(s, child)
            i := i + 1
        end
    end
    if kind == STMT_IF then
        var cond := load64(stmt + NODE_HDR_BYTES)
    sema_check_expr(s, cond)
        var then_b := load64(stmt + NODE_HDR_BYTES + 8)
        if then_b != 0 then sema_check_stmt(s, then_b) end
        var else_b := load64(stmt + NODE_HDR_BYTES + 32)
        if else_b != 0 then sema_check_stmt(s, else_b) end
    end
    if kind == STMT_WHILE then
        var cond := load64(stmt + NODE_HDR_BYTES)
    sema_check_expr(s, cond)
        var body := load64(stmt + NODE_HDR_BYTES + 8)
        if body != 0 then sema_check_stmt(s, body) end
    end
    if kind == STMT_RETURN then
        var v := load64(stmt + NODE_HDR_BYTES)
        if v != 0 then sema_check_expr(s, v) end
    end
    if kind == STMT_EXPR then
        var expr := load64(stmt + NODE_HDR_BYTES)
    sema_check_expr(s, expr)
    end
    if kind == STMT_VAR_DECL then
        var init := load64(stmt + NODE_HDR_BYTES + 16)
        if init != 0 then sema_check_expr(s, init) end
    end
    if kind == STMT_ASSIGN then
        var lhs := load64(stmt + NODE_HDR_BYTES)
        var rhs := load64(stmt + NODE_HDR_BYTES + 8)
    sema_check_expr(s, lhs)
    sema_check_expr(s, rhs)
    end
    if kind == STMT_LOOP then
        var body := load64(stmt + NODE_HDR_BYTES)
        if body != 0 then sema_check_stmt(s, body) end
    end
    if kind == STMT_FOR then
        var iter := load64(stmt + NODE_HDR_BYTES + 16)
    sema_check_expr(s, iter)
        var body := load64(stmt + NODE_HDR_BYTES + 24)
        if body != 0 then sema_check_stmt(s, body) end
    end
    if kind == STMT_MATCH then
        var subj := load64(stmt + NODE_HDR_BYTES)
    sema_check_expr(s, subj)
        var arms := load64(stmt + NODE_HDR_BYTES + 8)
        var arm_count := load32(stmt + NODE_HDR_BYTES + 16) as uint32
        var i: uint32 := 0
        while i < arm_count do
            var arm := load64(arms + (i as uint64) * 8)
            var arm_body := load64(arm + NODE_HDR_BYTES + 16)
            if arm_body != 0 then sema_check_stmt(s, arm_body) end
            i := i + 1
        end
    end
end

function sema_check_expr(s: ref Sema, expr: uint64): int32 begin
    if expr == 0 then return TYPE_VOID end
    var kind := node_kind(expr)
    if kind == EXPR_INT_LIT   then return TYPE_INT64 end
    if kind == EXPR_FLOAT_LIT then return TYPE_F64 end
    if kind == EXPR_STRING_LIT then return TYPE_STRING end
    if kind == EXPR_BOOL_LIT  then return TYPE_BOOL end
    if kind == EXPR_NULL_LIT  then return TYPE_NULL end
    if kind == EXPR_BINARY then
        var lhs_ty := sema_check_expr(s, load64(expr + NODE_HDR_BYTES))
        var rhs_ty := sema_check_expr(s, load64(expr + NODE_HDR_BYTES + 8))
        var op := load32(expr + NODE_HDR_BYTES + 16)
        if op == BINOP_EQ or op == BINOP_NE or op == BINOP_LT or
           op == BINOP_GT or op == BINOP_LE or op == BINOP_GE or
           op == BINOP_AND or op == BINOP_OR then
            return TYPE_BOOL
        end
    rhs_ty
        return lhs_ty
    end
    if kind == EXPR_CALL then
        /* Check each argument */
        var args := load64(expr + NODE_HDR_BYTES + 8)
        var arg_count := load32(expr + NODE_HDR_BYTES + 16) as uint32
        var i: uint32 := 0
        while i < arg_count do
            var arg := load64(args + (i as uint64) * 8)
    sema_check_expr(s, arg)
            i := i + 1
        end
        return TYPE_INT32  /* simplified: assume functions return int32 */
    end
    if kind == EXPR_CAST then
        var inner := load64(expr + NODE_HDR_BYTES)
    sema_check_expr(s, inner)
        var ty_node := load64(expr + NODE_HDR_BYTES + 8)
        return sema_resolve_type_node(s, ty_node)
    end
    if kind == EXPR_FIELD then
        var recv := load64(expr + NODE_HDR_BYTES)
    sema_check_expr(s, recv)
        return TYPE_INT32
    end
    if kind == EXPR_INDEX then
        var arr := load64(expr + NODE_HDR_BYTES)
        var idx := load64(expr + NODE_HDR_BYTES + 8)
    sema_check_expr(s, arr)
    sema_check_expr(s, idx)
        return TYPE_INT32
    end
    if kind == EXPR_GROUPED then
        return sema_check_expr(s, load64(expr + NODE_HDR_BYTES))
    end
    if kind == STMT_IF then
        /* Inline if expression */
        var cond := load64(expr + NODE_HDR_BYTES)
    sema_check_expr(s, cond)
        var then_v := load64(expr + NODE_HDR_BYTES + 8)
        var else_v := load64(expr + NODE_HDR_BYTES + 16)
        var t := sema_check_expr(s, then_v)
        if else_v != 0 then sema_check_expr(s, else_v) end
        return t
    end
    return TYPE_INT32
end

function sema_resolve_type_node(s: ref Sema, ty_node: uint64): int32 begin
    if ty_node == 0 then return TYPE_VOID end
    var kind := node_kind(ty_node)
    if kind == TYPE_NAMED then
        var name_start := load32(ty_node + NODE_HDR_BYTES) as uint32
        var name_len   := load32(ty_node + NODE_HDR_BYTES + 4) as uint32
        return sema_resolve_named_type(s.src, name_start, name_len)
    end
    if kind == TYPE_POINTER then return TYPE_UINT64 end
    if kind == TYPE_OPTIONAL then return TYPE_UINT64 end
    if kind == TYPE_ARRAY    then return TYPE_UINT64 end
    if kind == TYPE_SLICE    then return TYPE_UINT64 end
    if kind == TYPE_FUNC     then return TYPE_UINT64 end
    if kind == TYPE_OWNED then
        var inner := load64(ty_node + NODE_HDR_BYTES + 8)
        return sema_resolve_type_node(s, inner)
    end
    return TYPE_INT32
end

function sema_has_errors(s: ref Sema): bool begin
    return s.diag_count > 0
end
/// Maia self-hosted compiler — IR (intermediate representation).
/// Three-address code: functions → basic blocks → instructions.
/// Virtual registers (VReg = uint32), values, and block IDs.

module IR

use Sema

extern function maia_mmap(len: uint64): uint64
extern function store32(addr: uint64, v: int32)
extern function store64(addr: uint64, v: uint64)
extern function load32(addr: uint64): int32
extern function load64(addr: uint64): uint64
extern function load_byte(addr: uint64): int32
extern function maia_write(fd: int32, buf: uint64, count: uint64): int64
extern function maia_exit(code: int32)

/* ── Value kinds ─────────────────────────────────────────────────────────────── */

const VAL_VREG:        int32 = 0
const VAL_IMM_INT:     int32 = 1
const VAL_IMM_FLOAT:   int32 = 2
const VAL_IMM_BOOL:    int32 = 3
const VAL_IMM_NULL:    int32 = 4
const VAL_GLOBAL:      int32 = 5
const VAL_STRING_CONST:int32 = 6

/* Value layout (16 bytes): kind(4), vreg(4), imm_int_lo(4), imm_int_hi(4) */
const VALUE_BYTES: uint32 = 16

function val_vreg(vreg: uint32): uint64 begin
    var sv := vreg  /* save before maia_mmap clobbers rdi */
    var buf := maia_mmap(VALUE_BYTES as uint64)
    store32(buf, VAL_VREG)
    store32(buf + 4, sv as int32)
    return buf
end

function val_imm_int(v: int64): uint64 begin
    var sv := v  /* save before maia_mmap clobbers rdi/rsi */
    var buf := maia_mmap(VALUE_BYTES as uint64)
    store32(buf, VAL_IMM_INT)
    store32(buf + 8,  (sv as int32))
    store32(buf + 12, ((sv >> 32) as int32))
    return buf
end

function val_imm_bool(b: bool): uint64 begin
    var sb := b  /* save before maia_mmap */
    var buf := maia_mmap(VALUE_BYTES as uint64)
    store32(buf, VAL_IMM_BOOL)
    store32(buf + 4, if sb then 1 else 0 end)
    return buf
end

function val_imm_null(): uint64 begin
    var buf := maia_mmap(VALUE_BYTES as uint64)
    store32(buf, VAL_IMM_NULL)
    return buf
end

function val_global(name_ptr: uint64, name_len: uint32): uint64 begin
    var snp := name_ptr   /* save before maia_mmap clobbers rdi */
    var snl := name_len   /* save before maia_mmap clobbers rsi */
    var buf := maia_mmap(VALUE_BYTES as uint64)
    store32(buf, VAL_GLOBAL)
    store32(buf + 4, snl as int32)
    store64(buf + 8, snp)
    return buf
end

function val_global_len(v: uint64): uint32 begin
    return load32(v + 4) as uint32
end

function val_string_const(idx: uint32): uint64 begin
    var buf := maia_mmap(VALUE_BYTES as uint64)
    store32(buf, VAL_STRING_CONST)
    store32(buf + 4, idx as int32)
    return buf
end

function val_kind(v: uint64): int32 begin return load32(v) end
function val_vreg_id(v: uint64): uint32 begin return load32(v + 4) as uint32 end
function val_imm_int_val(v: uint64): int64 begin
    var lo := load32(v + 8) as int64
    var hi := load32(v + 12) as int64
    return lo or (hi << 32)
end
function val_global_ptr(v: uint64): uint64 begin return load64(v + 8) end

/* ── Instruction kinds ───────────────────────────────────────────────────────── */

const INSTR_BINOP:     int32 = 0
const INSTR_UNOP:      int32 = 1
const INSTR_COPY:      int32 = 2
const INSTR_CAST:      int32 = 3
const INSTR_CALL:      int32 = 4
const INSTR_ADDR_OF:   int32 = 5
const INSTR_LOAD:      int32 = 6
const INSTR_STORE:     int32 = 7
const INSTR_INDEX_GET: int32 = 8
const INSTR_INDEX_SET: int32 = 9
const INSTR_FIELD_GET: int32 = 10
const INSTR_FIELD_SET: int32 = 11
const INSTR_JUMP:      int32 = 12
const INSTR_BRANCH:    int32 = 13
const INSTR_RET:       int32 = 14
const INSTR_ALLOCA:    int32 = 15
const INSTR_NOP:       int32 = 16
const INSTR_PHI:       int32 = 17

/* Instruction layout (48 bytes): */
/*   kind(4), dst_vreg(4), type_id(4), block_id(4), */
/*   lhs(8), rhs(8), extra(8), args_ptr(8), args_count(4), op(4) */
const INSTR_BYTES: uint32 = 56

/* ── IR BinOp constants ──────────────────────────────────────────────────────── */

const IR_ADD:     int32 = 0
const IR_SUB:     int32 = 1
const IR_MUL:     int32 = 2
const IR_DIV:     int32 = 3
const IR_MOD:     int32 = 4
const IR_INT_DIV: int32 = 5
const IR_EQ:      int32 = 6
const IR_NE:      int32 = 7
const IR_LT:      int32 = 8
const IR_GT:      int32 = 9
const IR_LE:      int32 = 10
const IR_GE:      int32 = 11
const IR_AND:     int32 = 12
const IR_OR:      int32 = 13
const IR_XOR:     int32 = 14
const IR_SHL:     int32 = 15
const IR_SHR:     int32 = 16

/* ── IR UnOp constants ───────────────────────────────────────────────────────── */

const IR_NEG:     int32 = 0
const IR_NOT:     int32 = 1
const IR_BIT_NOT: int32 = 2

/* ── Basic Block ─────────────────────────────────────────────────────────────── */

type BasicBlock = struct {
    id:          uint32,
    label_ptr:   uint64,
    label_len:   uint32,
    instrs:      uint64,  /* ptr to Instr[] */
    instr_count: uint32,
    instr_cap:   uint32,
}

function bb_new(id: uint32, label_ptr: uint64, label_len: uint32): BasicBlock begin
    const CAP: uint32 = 64
    var instrs := maia_mmap((CAP as uint64) * INSTR_BYTES as uint64)
    return BasicBlock {
        .id          = id,
        .label_ptr   = label_ptr,
        .label_len   = label_len,
        .instrs      = instrs,
        .instr_count = 0,
        .instr_cap   = CAP,
    }
end

procedure bb_emit(bb: mut BasicBlock, instr: uint64) begin
    var idx := bb.instr_count
    var dst := bb.instrs + (idx as uint64) * INSTR_BYTES as uint64
    /* Copy 56 bytes of the instr struct */
    var i: uint32 := 0
    while i < INSTR_BYTES do
        var byte_ := load_byte(instr + i as uint64)
        store32_byte(dst + i as uint64, byte_)
        i := i + 1
    end
    bb.instr_count := bb.instr_count + 1
end

/* Store a single byte at an address (uses store32 with masking on aligned offset) */
extern function store_byte(addr: uint64, v: int32)

procedure store32_byte(addr: uint64, v: int32) begin
    store_byte(addr, v)
end

function bb_is_terminated(bb: ref BasicBlock): bool begin
    if bb.instr_count == 0 then return false end
    var last := bb.instrs + (bb.instr_count - 1) as uint64 * INSTR_BYTES as uint64
    var k := load32(last)
    return k == INSTR_JUMP or k == INSTR_BRANCH or k == INSTR_RET
end

/* ── IR Function ─────────────────────────────────────────────────────────────── */

type IrFunction = struct {
    name_ptr:    uint64,
    name_len:    uint32,
    ret_ty:      int32,
    blocks:      uint64,  /* ptr to BasicBlock[] (each stored as 48 bytes) */
    block_count: uint32,
    block_cap:   uint32,
    params:      uint64,  /* ptr to (name_ptr(8), vreg(4), type_id(4))[] */
    param_count: uint32,
    next_vreg:   uint32,
    next_block:  uint32,
    is_external: bool,
}

const BB_STRUCT_BYTES: uint32 = 48

function irfn_new(name_ptr: uint64, name_len: uint32, ret_ty: int32): IrFunction begin
    const BLK_CAP: uint32 = 64
    var snp  := name_ptr   /* save before maia_mmap clobbers rdi */
    var snl  := name_len   /* save before maia_mmap clobbers rsi */
    var srt  := ret_ty     /* save before maia_mmap clobbers rdx */
    var blks := maia_mmap((BLK_CAP as uint64) * BB_STRUCT_BYTES as uint64)
    var prms := maia_mmap(128)
    return IrFunction {
        .name_ptr    = snp,
        .name_len    = snl,
        .ret_ty      = srt,
        .blocks      = blks,
        .block_count = 0,
        .block_cap   = BLK_CAP,
        .params      = prms,
        .param_count = 0,
        .next_vreg   = 0,
        .next_block  = 0,
        .is_external = false,
    }
end

function irfn_fresh_vreg(fn_: mut IrFunction): uint32 begin
    var v := fn_.next_vreg
    fn_.next_vreg := fn_.next_vreg + 1
    return v
end

function irfn_add_block(fn_: mut IrFunction, label_ptr: uint64, label_len: uint32): uint32 begin
    var id := fn_.next_block
    fn_.next_block := fn_.next_block + 1
    var bb := bb_new(id, label_ptr, label_len)
    /* Store bb into fn_.blocks[id] */
    var dst := fn_.blocks + (id as uint64) * BB_STRUCT_BYTES as uint64
    store32(dst,      bb.id as int32)
    store64(dst + 8,  bb.label_ptr)
    store32(dst + 16, bb.label_len as int32)
    store64(dst + 24, bb.instrs)
    store32(dst + 32, bb.instr_count as int32)
    store32(dst + 36, bb.instr_cap as int32)
    fn_.block_count := fn_.block_count + 1
    return id
end

function irfn_current_block(fn_: ref IrFunction): uint64 begin
    /* Returns a pointer to the last block */
    var idx := fn_.block_count - 1
    return fn_.blocks + (idx as uint64) * BB_STRUCT_BYTES as uint64
end

function irfn_get_block(fn_: ref IrFunction, id: uint32): uint64 begin
    return fn_.blocks + (id as uint64) * BB_STRUCT_BYTES as uint64
end

procedure irfn_emit(fn_: mut IrFunction, instr_buf: uint64) begin
    var bb_ptr := irfn_current_block(fn_)
    var instr_count := load32(bb_ptr + 32) as uint32
    var instrs_base := load64(bb_ptr + 24)
    var dst := instrs_base + (instr_count as uint64) * INSTR_BYTES as uint64
    /* Copy INSTR_BYTES bytes */
    var i: uint32 := 0
    while i < INSTR_BYTES do
        store_byte(dst + i as uint64, load_byte(instr_buf + i as uint64))
        i := i + 1
    end
    store32(bb_ptr + 32, (instr_count + 1) as int32)
end

/* ── IR Module ───────────────────────────────────────────────────────────────── */

type IrModule = struct {
    functions:   uint64,  /* ptr to IrFunction pointer array */
    fn_count:    uint32,
    fn_cap:      uint32,
    globals:     uint64,  /* ptr to (name_ptr, ty, init_val, is_const) entries */
    global_count:uint32,
    string_pool: uint64,  /* ptr to (str_ptr(8), str_len(4)) entries */
    str_count:   uint32,
}

const IRFN_PTR_BYTES: uint32 = 8  /* we store pointers to IrFunction structs */
const GLOBAL_BYTES:   uint32 = 32
const STR_ENTRY_BYTES:uint32 = 12

function irmod_new(): IrModule begin
    const FN_CAP:  uint32 = 256
    const GLB_CAP: uint32 = 256
    const STR_CAP: uint32 = 1024
    return IrModule {
        .functions    = maia_mmap((FN_CAP as uint64) * IRFN_PTR_BYTES as uint64),
        .fn_count     = 0,
        .fn_cap       = FN_CAP,
        .globals      = maia_mmap((GLB_CAP as uint64) * GLOBAL_BYTES as uint64),
        .global_count = 0,
        .string_pool  = maia_mmap((STR_CAP as uint64) * STR_ENTRY_BYTES as uint64),
        .str_count    = 0,
    }
end

function irmod_intern_string(mod: mut IrModule, str_ptr: uint64, str_len: uint32): uint32 begin
    /* Search for existing string */
    var i: uint32 := 0
    while i < mod.str_count do
        var slot := mod.string_pool + (i as uint64) * STR_ENTRY_BYTES as uint64
        var sp := load64(slot)
        var sl := load32(slot + 8) as uint32
        if sl == str_len then
            var eq := strings_equal(sp, str_ptr, str_len)
            if eq then return i end
        end
        i := i + 1
    end
    var idx := mod.str_count
    var slot := mod.string_pool + (idx as uint64) * STR_ENTRY_BYTES as uint64
    store64(slot,     str_ptr)
    store32(slot + 8, str_len as int32)
    mod.str_count := mod.str_count + 1
    return idx
end

function strings_equal(a: uint64, b: uint64, len: uint32): bool begin
    var i: uint32 := 0
    while i < len do
        if load_byte(a + i as uint64) != load_byte(b + i as uint64) then
            return false
        end
        i := i + 1
    end
    return true
end

/* ── IR Builder ──────────────────────────────────────────────────────────────── */

type Builder = struct {
    mod:              uint64,  /* ptr to IrModule */
    sema_:            uint64,  /* ptr to Sema */
    src:              uint64,
    src_len:          uint32,
    current_fn:       uint64,  /* ptr to current IrFunction (0 = none) */
    /* Local variable map: name_ptr(8), name_len(4), vreg(4) per entry */
    locals:           uint64,
    local_count:      uint32,
    loop_exit_block:  int32,  /* -1 = none */
    loop_cond_block:  int32,
}

const LOCAL_ENTRY_BYTES: uint32 = 16

function builder_new(mod: uint64, sema_: uint64, src: uint64, src_len: uint32): Builder begin
    var smod     := mod      /* save all params before maia_mmap clobbers ABI regs */
    var ssema    := sema_
    var ssrc     := src
    var ssrc_len := src_len
    var locs     := maia_mmap(4096)   /* locals array */
    return Builder {
        .mod          = smod,
        .sema_        = ssema,
        .src          = ssrc,
        .src_len      = ssrc_len,
        .current_fn   = 0,
        .locals       = locs,
        .local_count  = 0,
        .loop_exit_block = -1,
        .loop_cond_block = -1,
    }
end

procedure builder_clear_locals(b: mut Builder) begin
    b.local_count := 0
end

procedure builder_add_local(b: mut Builder, name_ptr: uint64, name_len: uint32, vreg: uint32) begin
    var b_raw := b as uint64
    var locals := load64(b_raw + 36)      /* Builder.locals @36 */
    var count  := load32(b_raw + 44) as uint32  /* Builder.local_count @44 */
    var slot := locals + (count as uint64) * LOCAL_ENTRY_BYTES as uint64
    store64(slot,     name_ptr)
    store32(slot + 8, name_len as int32)
    store32(slot + 12, vreg as int32)
    store32(b_raw + 44, (count + 1) as int32)
end

function builder_find_local(b: ref Builder, name_ptr: uint64, name_len: uint32): int32 begin
    var b_raw := b as uint64
    var locals := load64(b_raw + 36)
    var count  := load32(b_raw + 44) as uint32
    var i: uint32 := 0
    while i < count do
        var slot := locals + (i as uint64) * LOCAL_ENTRY_BYTES as uint64
        var sp := load64(slot)
        var sl := load32(slot + 8) as uint32
        if sl == name_len then
            if strings_equal(sp, name_ptr, name_len) then
                return load32(slot + 12)
            end
        end
        i := i + 1
    end
    return -1
end

/* Allocate a new instruction buffer on the heap */
function instr_alloc(kind: int32): uint64 begin
    var buf := maia_mmap(INSTR_BYTES as uint64)
    store32(buf, kind)
    return buf
end

procedure builder_lower_module(b: mut Builder, mod: ref Module) begin
    var sb     := b              /* save b before calls */
    var sm_raw := mod as uint64  /* raw Module ptr - direct offsets avoid field access issues */
    var decl_count := load32(sm_raw + 20) as uint32  /* Module.decl_count @20 */
    var decls_arr  := load64(sm_raw + 12)            /* Module.decls @12 */
    var i: uint32 := 0
    while i < decl_count do
        var d := load64(decls_arr + (i as uint64) * 8)
        builder_lower_decl(sb, d)
        i := i + 1
    end
end

procedure builder_lower_decl(b: mut Builder, decl: uint64) begin
    var sb_raw := b as uint64   /* raw Builder ptr for explicit field access */
    var sd := decl              /* raw decl node ptr */
    var kind := node_kind(sd)
    if kind == DECL_FUNC then
        var body := load64(sd + 56)   /* NODE_HDR_BYTES(24) + 32 = 56 */
        if body == 0 then return end
        builder_lower_function(b, body, sd)
    end
    if kind == DECL_PROC then
        var body := load64(sd + 48)   /* NODE_HDR_BYTES(24) + 24 = 48 */
        if body == 0 then return end
        builder_lower_function(b, body, sd)
    end
    if kind == DECL_EXTERN then
        var inner := load64(sd + 24)   /* NODE_HDR_BYTES = 24, hardcoded */
        if inner == 0 then return end
        /* Use explicit field access via raw ptr */
        var ext_mod  := load64(sb_raw + 0)   /* Builder.mod @0 */
        var ext_src  := load64(sb_raw + 16)  /* Builder.src @16 */
        var inner_kind := node_kind(inner)
        if inner_kind == DECL_FUNC or inner_kind == DECL_PROC then
            var name_start := load32(inner + 24) as uint32  /* NODE_HDR_BYTES=24 */
            var name_len   := load32(inner + 28) as uint32
            var name_ptr   := ext_src + name_start as uint64
            /* Add an external function entry to the module */
            var fn_count := load32(ext_mod + 8)
            var fn_arr   := load64(ext_mod)
            /* External fn entry */
            var fn_entry := maia_mmap(64)
            store64(fn_entry,     name_ptr)
            store32(fn_entry + 8, name_len as int32)
            store32(fn_entry + 52, 1)
            store64(fn_arr + (fn_count as uint64) * IRFN_PTR_BYTES as uint64, fn_entry)
            store32(ext_mod + 8, fn_count + 1)
        end
    end
end

procedure builder_lower_function(b: mut Builder, body: uint64, decl: uint64) begin
    var b_raw   := b as uint64  /* raw Builder ptr for direct field access */
    var sbody   := body
    var sdecl   := decl
    /* Extract fields via explicit ptr arithmetic — Builder.src @16 */
    var b_src       := load64(b_raw + 16)   /* Builder.src @16 */
    var name_start  := load32(sdecl + 24) as uint32   /* NODE_HDR_BYTES=24 */
    var name_len    := load32(sdecl + 28) as uint32
    var name_ptr    := b_src + name_start as uint64
    var param_count := load32(sdecl + 40) as uint32
    /* Create IrFunction */
    var fn_ := irfn_new(name_ptr, name_len, TYPE_VOID)
    fn_.next_vreg := param_count
    /* builder_clear_locals: store 0 to Builder.local_count @44 */
    store32(b_raw + 44, 0)

    /* Allocate function struct on heap */
    var fn_buf := maia_mmap(256)
    var fn_raw := fn_ as uint64   /* raw IrFunction ptr for field access */
    store64(fn_buf,       load64(fn_raw + 0))    /* name_ptr */
    store32(fn_buf + 8,   load32(fn_raw + 8))    /* name_len */
    store32(fn_buf + 12,  load32(fn_raw + 12))   /* ret_ty */
    store64(fn_buf + 16,  load64(fn_raw + 16))   /* blocks */
    store32(fn_buf + 24,  load32(fn_raw + 24))   /* block_count */
    store32(fn_buf + 28,  load32(fn_raw + 28))   /* block_cap */
    store64(fn_buf + 32,  load64(fn_raw + 32))   /* params */
    store32(fn_buf + 40,  load32(fn_raw + 40))   /* param_count */
    store32(fn_buf + 44,  load32(fn_raw + 44))   /* next_vreg */
    store32(fn_buf + 48,  load32(fn_raw + 48))   /* next_block */
    store32(fn_buf + 52,  0)                      /* is_external = false */

    /* Builder.current_fn @28 := fn_buf */
    store64(b_raw + 28, fn_buf)

    /* Add entry block */
    var entry_lbl := string_const_ptr("entry")
    irfn_add_block_by_ptr(fn_buf, entry_lbl, 5)

    builder_lower_stmt(b, sbody)

    /* Ensure terminator */
    var cur_fn := load64(b_raw + 28)  /* Builder.current_fn @28 */
    var last_bb := irfn_current_block_by_ptr(cur_fn)
    if not bb_is_terminated_by_ptr(last_bb) then
        var ret_instr := instr_alloc(INSTR_RET)
        irfn_emit_by_ptr(cur_fn, ret_instr)
    end

    /* Add fn_buf to module: Builder.mod @0 */
    var mod_ptr   := load64(b_raw + 0)
    var fn_count  := load32(mod_ptr + 8) as uint32
    var fn_arr    := load64(mod_ptr)
    store64(fn_arr + (fn_count as uint64) * IRFN_PTR_BYTES as uint64, fn_buf)
    store32(mod_ptr + 8, (fn_count + 1) as int32)
end

/* Helpers that operate on a pointer to IrFunction struct in memory */
function irfn_add_block_by_ptr(fn_ptr: uint64, label_ptr: uint64, label_len: uint32): uint32 begin
    var next_block := load32(fn_ptr + 48) as uint32
    var blocks     := load64(fn_ptr + 16)
    var dst        := blocks + (next_block as uint64) * BB_STRUCT_BYTES as uint64
    store32(dst,      next_block as int32)
    store64(dst + 8,  label_ptr)
    store32(dst + 16, label_len as int32)
    store64(dst + 24, maia_mmap(64 * INSTR_BYTES as uint64))
    store32(dst + 32, 0)  /* instr_count */
    store32(dst + 36, 64)  /* instr_cap */
    store32(fn_ptr + 48, (next_block + 1) as int32)
    var blk_count := load32(fn_ptr + 24) as uint32
    store32(fn_ptr + 24, (blk_count + 1) as int32)
    return next_block
end

function irfn_current_block_by_ptr(fn_ptr: uint64): uint64 begin
    var block_count := load32(fn_ptr + 24) as uint32
    var blocks      := load64(fn_ptr + 16)
    if block_count == 0 then return 0 end
    return blocks + (block_count - 1) as uint64 * BB_STRUCT_BYTES as uint64
end

function bb_is_terminated_by_ptr(bb_ptr: uint64): bool begin
    var count := load32(bb_ptr + 32) as uint32
    if count == 0 then return false end
    var instrs := load64(bb_ptr + 24)
    var last := instrs + (count - 1) as uint64 * INSTR_BYTES as uint64
    var k := load32(last)
    return k == INSTR_JUMP or k == INSTR_BRANCH or k == INSTR_RET
end

procedure irfn_emit_by_ptr(fn_ptr: uint64, instr_buf: uint64) begin
    var bb_ptr     := irfn_current_block_by_ptr(fn_ptr)
    if bb_ptr == 0 then return end
    var count      := load32(bb_ptr + 32) as uint32
    var instrs     := load64(bb_ptr + 24)
    var dst        := instrs + (count as uint64) * INSTR_BYTES as uint64
    var i: uint32 := 0
    while i < INSTR_BYTES do
        store_byte(dst + i as uint64, load_byte(instr_buf + i as uint64))
        i := i + 1
    end
    store32(bb_ptr + 32, (count + 1) as int32)
end

function string_const_ptr(s: string): uint64 begin
    /* In Maia, string literals are null-terminated pointers in rodata. */
    /* We cast the string to a uint64 pointer. */
    return s as uint64
end

/* Wrapper to call sema_resolve_type_node via pointer */
function sema_resolve_type_node_by_ptr(sema_ptr: uint64, ty_node: uint64): int32 begin
    /* Load sema fields needed for type resolution */
    var src     := load64(sema_ptr + 40)  /* sema.src at offset ~40 (rough) */
    src
    /* Simplified: just use the type node kind directly */
    var k := load32(ty_node)
    if k == TYPE_NAMED then
        var name_start := load32(ty_node + NODE_HDR_BYTES) as uint32
        var name_len   := load32(ty_node + NODE_HDR_BYTES + 4) as uint32
        return sema_resolve_named_type(src, name_start, name_len)
    end
    return TYPE_INT32
end

/* ── Statement lowering ──────────────────────────────────────────────────────── */

procedure builder_lower_stmt(b: mut Builder, stmt: uint64) begin
    if stmt == 0 then return end
    var b_raw := b as uint64  /* raw Builder ptr */
    var sstmt := stmt
    var kind := node_kind(sstmt)
    var cur_fn := load64(b_raw + 28)   /* Builder.current_fn @28 */

    if kind == STMT_BLOCK then
        var stmts := load64(sstmt + 24)   /* NODE_HDR_BYTES=24 */
        var count  := load32(sstmt + 32) as uint32  /* 24+8=32 */
        var i: uint32 := 0
        while i < count do
            builder_lower_stmt(b, load64(stmts + (i as uint64) * 8))
            i := i + 1
        end
        return
    end

    if kind == STMT_VAR_DECL then
        var next_v  := load32(cur_fn + 44) as uint32
        store32(cur_fn + 44, (next_v + 1) as int32)
        var dst := next_v
        /* alloca */
        var instr := instr_alloc(INSTR_ALLOCA)
        store32(instr + 4,  dst as int32)
        store32(instr + 8,  TYPE_INT32)
        store32(instr + 12, 1)
        irfn_emit_by_ptr(cur_fn, instr)
        /* record local */
        var name_start := load32(sstmt + 24) as uint32  /* NODE_HDR_BYTES=24 */
        var name_len   := load32(sstmt + 28) as uint32
        var b_src  := load64(b_raw + 16)  /* Builder.src @16 */
        var name_ptr   := b_src + name_start as uint64
        builder_add_local(b, name_ptr, name_len, dst)
        /* init */
        var init_node := load64(sstmt + 40)  /* 24+16=40 */
        if init_node != 0 then
            var v := builder_lower_expr(b, init_node)
            var sinstr := instr_alloc(INSTR_STORE)
            store64(sinstr + 8,  val_vreg(dst))
            store64(sinstr + 16, v)
            irfn_emit_by_ptr(cur_fn, sinstr)
        end
        return
    end

    if kind == STMT_EXPR then
        var expr := load64(sstmt + 24)  /* NODE_HDR_BYTES=24 */
        builder_lower_expr(b, expr)
        return
    end

    if kind == STMT_RETURN then
        var val_node := load64(sstmt + 24)
        var instr := instr_alloc(INSTR_RET)
        if val_node != 0 then
            var v := builder_lower_expr(b, val_node)
            store64(instr + 8, v)
        end
        irfn_emit_by_ptr(cur_fn, instr)
        return
    end

    if kind == STMT_ASSIGN then
        var target := load64(sstmt + 24)    /* NODE_HDR_BYTES=24 */
        var value_node := load64(sstmt + 32)  /* 24+8=32 */
        var rhs := builder_lower_expr(b, value_node)
        var tgt_kind := node_kind(target)
        if tgt_kind == EXPR_IDENT then
            var ns := load32(target + 24) as uint32
            var nl := load32(target + 28) as uint32
            var b_src2 := load64(b_raw + 16)
            var np := b_src2 + ns as uint64
            var vreg := builder_find_local(b, np, nl)
            var sinstr := instr_alloc(INSTR_STORE)
            if vreg >= 0 then
                store64(sinstr + 8,  val_vreg(vreg as uint32))
            else
                store64(sinstr + 8,  val_global(np, nl))
            end
            store64(sinstr + 16, rhs)
            irfn_emit_by_ptr(cur_fn, sinstr)
        end
        return
    end

    if kind == STMT_IF then
        var cond_val := builder_lower_expr(b, load64(sstmt + 24))
        var fn_ptr := cur_fn
        var then_id := irfn_add_block_by_ptr(fn_ptr, string_const_ptr("if_then"), 7)
        var else_id := irfn_add_block_by_ptr(fn_ptr, string_const_ptr("if_else"), 7)
        var merge_id := irfn_add_block_by_ptr(fn_ptr, string_const_ptr("if_merge"), 8)
        /* Branch */
        var binstr := instr_alloc(INSTR_BRANCH)
        store64(binstr + 8,  cond_val)
        store32(binstr + 16, then_id as int32)
        store32(binstr + 20, else_id as int32)
        irfn_emit_by_ptr(fn_ptr, binstr)
        /* Then */
        irfn_switch_to_block(fn_ptr, then_id)
        var then_branch := load64(stmt + NODE_HDR_BYTES + 8)
        if then_branch != 0 then builder_lower_stmt(b, then_branch) end
        if not bb_is_terminated_by_ptr(irfn_current_block_by_ptr(fn_ptr)) then
            var jinstr := instr_alloc(INSTR_JUMP)
            store32(jinstr + 4, merge_id as int32)
            irfn_emit_by_ptr(fn_ptr, jinstr)
        end
        /* Else */
        irfn_switch_to_block(fn_ptr, else_id)
        var else_branch := load64(stmt + NODE_HDR_BYTES + 32)
        if else_branch != 0 then builder_lower_stmt(b, else_branch) end
        if not bb_is_terminated_by_ptr(irfn_current_block_by_ptr(fn_ptr)) then
            var jinstr2 := instr_alloc(INSTR_JUMP)
            store32(jinstr2 + 4, merge_id as int32)
            irfn_emit_by_ptr(fn_ptr, jinstr2)
        end
        irfn_switch_to_block(fn_ptr, merge_id)
        return
    end

    if kind == STMT_WHILE then
        var fn_ptr := b.current_fn
        var cond_id := irfn_add_block_by_ptr(fn_ptr, string_const_ptr("while_cond"), 10)
        var body_id := irfn_add_block_by_ptr(fn_ptr, string_const_ptr("while_body"), 10)
        var exit_id := irfn_add_block_by_ptr(fn_ptr, string_const_ptr("while_exit"), 10)
        var jinstr := instr_alloc(INSTR_JUMP)
        store32(jinstr + 4, cond_id as int32)
        irfn_emit_by_ptr(fn_ptr, jinstr)
        irfn_switch_to_block(fn_ptr, cond_id)
        var cond_val := builder_lower_expr(b, load64(stmt + NODE_HDR_BYTES))
        var binstr := instr_alloc(INSTR_BRANCH)
        store64(binstr + 8,  cond_val)
        store32(binstr + 16, body_id as int32)
        store32(binstr + 20, exit_id as int32)
        irfn_emit_by_ptr(fn_ptr, binstr)
        irfn_switch_to_block(fn_ptr, body_id)
        var prev_exit := b.loop_exit_block
        var prev_cond := b.loop_cond_block
        b.loop_exit_block := exit_id as int32
        b.loop_cond_block := cond_id as int32
        builder_lower_stmt(b, load64(stmt + NODE_HDR_BYTES + 8))
        b.loop_exit_block := prev_exit
        b.loop_cond_block := prev_cond
        if not bb_is_terminated_by_ptr(irfn_current_block_by_ptr(fn_ptr)) then
            var bjinstr := instr_alloc(INSTR_JUMP)
            store32(bjinstr + 4, cond_id as int32)
            irfn_emit_by_ptr(fn_ptr, bjinstr)
        end
        irfn_switch_to_block(fn_ptr, exit_id)
        return
    end

    if kind == STMT_LOOP then
        var fn_ptr := b.current_fn
        var body_id := irfn_add_block_by_ptr(fn_ptr, string_const_ptr("loop_body"), 9)
        var exit_id := irfn_add_block_by_ptr(fn_ptr, string_const_ptr("loop_exit"), 9)
        var jinstr := instr_alloc(INSTR_JUMP)
        store32(jinstr + 4, body_id as int32)
        irfn_emit_by_ptr(fn_ptr, jinstr)
        irfn_switch_to_block(fn_ptr, body_id)
        var prev_exit := b.loop_exit_block
        b.loop_exit_block := exit_id as int32
        builder_lower_stmt(b, load64(stmt + NODE_HDR_BYTES))
        b.loop_exit_block := prev_exit
        if not bb_is_terminated_by_ptr(irfn_current_block_by_ptr(fn_ptr)) then
            var bjinstr := instr_alloc(INSTR_JUMP)
            store32(bjinstr + 4, body_id as int32)
            irfn_emit_by_ptr(fn_ptr, bjinstr)
        end
        irfn_switch_to_block(fn_ptr, exit_id)
        return
    end

    if kind == STMT_BREAK then
        if b.loop_exit_block >= 0 then
            var instr := instr_alloc(INSTR_JUMP)
            store32(instr + 4, b.loop_exit_block)
            irfn_emit_by_ptr(b.current_fn, instr)
        end
        return
    end

    if kind == STMT_CONTINUE then
        if b.loop_cond_block >= 0 then
            var instr := instr_alloc(INSTR_JUMP)
            store32(instr + 4, b.loop_cond_block)
            irfn_emit_by_ptr(b.current_fn, instr)
        end
        return
    end

    if kind == STMT_DEFER then
        /* Simplified: execute inline */
        builder_lower_stmt(b, load64(stmt + NODE_HDR_BYTES))
        return
    end

    if kind == STMT_SAFE or kind == STMT_UNSAFE then
        builder_lower_stmt(b, load64(stmt + NODE_HDR_BYTES))
        return
    end
end

/* Switch the "current block" in an IrFunction to the block with the given ID. */
/* We simulate this by re-ordering: move target block to end of list. */
/* (Simple approach: just set the current_fn's "active" block index.) */
/* For now, emit into the block directly using the block ID. */
procedure irfn_switch_to_block(fn_ptr: uint64, id: uint32) begin
    /* Reorder blocks array so block[id] is last */
    var block_count := load32(fn_ptr + 24) as uint32
    var blocks      := load64(fn_ptr + 16)
    /* Find the block and swap it to the end */
    var i: uint32 := 0
    while i < block_count do
        var bb_ptr := blocks + (i as uint64) * BB_STRUCT_BYTES as uint64
        var bb_id  := load32(bb_ptr) as uint32
        if bb_id == id then
            if i != block_count - 1 then
                /* Swap bb[i] with bb[block_count-1] */
                var last_ptr := blocks + (block_count - 1) as uint64 * BB_STRUCT_BYTES as uint64
                /* Copy block i to tmp buffer */
                var tmp := maia_mmap(BB_STRUCT_BYTES as uint64)
                var j: uint32 := 0
                while j < BB_STRUCT_BYTES do
                    store_byte(tmp + j as uint64, load_byte(bb_ptr + j as uint64))
                    j := j + 1
                end
                /* Copy last to i */
                j := 0
                while j < BB_STRUCT_BYTES do
                    store_byte(bb_ptr + j as uint64, load_byte(last_ptr + j as uint64))
                    j := j + 1
                end
                /* Copy tmp to last */
                j := 0
                while j < BB_STRUCT_BYTES do
                    store_byte(last_ptr + j as uint64, load_byte(tmp + j as uint64))
                    j := j + 1
                end
            end
            break
        end
        i := i + 1
    end
end

/* ── Expression lowering ─────────────────────────────────────────────────────── */

function builder_lower_expr(b: mut Builder, expr: uint64): uint64 begin
    if expr == 0 then return val_imm_int(0) end
    var b_raw := b as uint64   /* raw Builder ptr for direct field access */
    var sexpr := expr
    var kind := node_kind(sexpr)

    if kind == EXPR_INT_LIT then
        var start := node_span_start(sexpr)
        var b_src := load64(b_raw + 16)  /* Builder.src @16 */
        var v := parse_int_from_src(b_src, start)
        return val_imm_int(v)
    end

    if kind == EXPR_BOOL_LIT then
        var v := load32(sexpr + 24)  /* NODE_HDR_BYTES=24 */
        return val_imm_bool(v == 1)
    end

    if kind == EXPR_NULL_LIT then
        return val_imm_null()
    end

    if kind == EXPR_STRING_LIT then
        var span_start := node_span_start(sexpr) + 1
        var span_end   := load32(sexpr + 12) as uint32 - 1
        var mod_ptr    := load64(b_raw + 0)   /* Builder.mod @0 */
        var str_count  := load32(mod_ptr + 32) as uint32
        var str_pool   := load64(mod_ptr + 24)
        var b_src2 := load64(b_raw + 16)
        var str_ptr    := b_src2 + span_start as uint64
        var str_len    := span_end - span_start
        var idx: uint32 := str_count
        store64(str_pool + (idx as uint64) * STR_ENTRY_BYTES as uint64, str_ptr)
        store32(str_pool + (idx as uint64) * STR_ENTRY_BYTES as uint64 + 8, str_len as int32)
        store32(mod_ptr + 32, (str_count + 1) as int32)
        return val_string_const(idx)
    end

    if kind == EXPR_IDENT then
        var ns := load32(sexpr + 24) as uint32  /* NODE_HDR_BYTES=24 */
        var nl := load32(sexpr + 28) as uint32
        var b_src3 := load64(b_raw + 16)
        var np := b_src3 + ns as uint64
        var vreg := builder_find_local(b, np, nl)
        if vreg >= 0 then
            var fn_ptr := load64(b_raw + 28)  /* Builder.current_fn @28 */
            var next_v := load32(fn_ptr + 44) as uint32
            store32(fn_ptr + 44, (next_v + 1) as int32)
            var dst := next_v
            var instr := instr_alloc(INSTR_LOAD)
            store32(instr + 4,  dst as int32)
            store64(instr + 8,  val_vreg(vreg as uint32))
            store32(instr + 16, TYPE_INT32)
            irfn_emit_by_ptr(fn_ptr, instr)
            return val_vreg(dst)
        end
        return val_global(np, nl)
    end

    if kind == EXPR_BINARY then
        var lhs := builder_lower_expr(b, load64(sexpr + 24))  /* +NODE_HDR_BYTES */
        var rhs := builder_lower_expr(b, load64(sexpr + 32))  /* +NODE_HDR_BYTES+8 */
        var ast_op := load32(sexpr + 40)                        /* +NODE_HDR_BYTES+16 */
        var ir_op := ast_binop_to_ir(ast_op)
        var fn_ptr := load64(b_raw + 28)
        var next_v := load32(fn_ptr + 44) as uint32
        store32(fn_ptr + 44, (next_v + 1) as int32)
        var dst := next_v
        var instr := instr_alloc(INSTR_BINOP)
        store32(instr + 4,  dst as int32)
        store32(instr + 8,  TYPE_INT32)
        store32(instr + 12, ir_op)
        store64(instr + 16, lhs)
        store64(instr + 24, rhs)
        irfn_emit_by_ptr(fn_ptr, instr)
        return val_vreg(dst)
    end

    if kind == EXPR_CALL then
        var callee_node := load64(sexpr + 24)  /* NODE_HDR_BYTES=24 */
        var callee_val  := builder_lower_expr(b, callee_node)
        var args_ptr    := load64(sexpr + 32)  /* 24+8 */
        var arg_count   := load32(sexpr + 40) as uint32  /* 24+16 */
        var arg_vals := maia_mmap((arg_count as uint64) * 8)
        var i: uint32 := 0
        while i < arg_count do
            var anode := load64(args_ptr + (i as uint64) * 8)
            var av := builder_lower_expr(b, anode)
            store64(arg_vals + (i as uint64) * 8, av)
            i := i + 1
        end
        var fn_ptr := load64(b_raw + 28)  /* Builder.current_fn @28 */
        var next_v := load32(fn_ptr + 44) as uint32
        store32(fn_ptr + 44, (next_v + 1) as int32)
        var dst := next_v
        var instr := instr_alloc(INSTR_CALL)
        store32(instr + 4,  dst as int32)
        store32(instr + 8,  TYPE_INT32)
        store64(instr + 16, callee_val)
        store64(instr + 24, arg_vals)
        store32(instr + 32, arg_count as int32)
        irfn_emit_by_ptr(fn_ptr, instr)
        return val_vreg(dst)
    end

    if kind == EXPR_CAST then
        var inner := builder_lower_expr(b, load64(sexpr + 24))
        var fn_ptr := load64(b_raw + 28)
        var next_v := load32(fn_ptr + 44) as uint32
        store32(fn_ptr + 44, (next_v + 1) as int32)
        var dst := next_v
        var instr := instr_alloc(INSTR_CAST)
        store32(instr + 4,  dst as int32)
        store32(instr + 8,  TYPE_INT32)
        store64(instr + 16, inner)
        irfn_emit_by_ptr(fn_ptr, instr)
        return val_vreg(dst)
    end

    if kind == EXPR_GROUPED then
        return builder_lower_expr(b, load64(sexpr + 24))
    end

    if kind == EXPR_FIELD then
        var obj := builder_lower_expr(b, load64(sexpr + 24))
        var fn_ptr := load64(b_raw + 28)
        var next_v := load32(fn_ptr + 44) as uint32
        store32(fn_ptr + 44, (next_v + 1) as int32)
        var dst := next_v
        var instr := instr_alloc(INSTR_FIELD_GET)
        store32(instr + 4,  dst as int32)
        store32(instr + 8,  TYPE_INT32)
        store64(instr + 16, obj)
        var fname_start := load32(sexpr + 32) as uint32  /* 24+8 */
        var b_src4 := load64(b_raw + 16)
        store64(instr + 24, b_src4 + fname_start as uint64)
        irfn_emit_by_ptr(fn_ptr, instr)
        return val_vreg(dst)
    end

    if kind == EXPR_INDEX then
        var arr_val := builder_lower_expr(b, load64(sexpr + 24))
        var idx_val := builder_lower_expr(b, load64(sexpr + 32))
        var fn_ptr := load64(b_raw + 28)
        var next_v := load32(fn_ptr + 44) as uint32
        store32(fn_ptr + 44, (next_v + 1) as int32)
        var dst := next_v
        var instr := instr_alloc(INSTR_INDEX_GET)
        store32(instr + 4,  dst as int32)
        store32(instr + 8,  TYPE_INT32)
        store64(instr + 16, arr_val)
        store64(instr + 24, idx_val)
        irfn_emit_by_ptr(fn_ptr, instr)
        return val_vreg(dst)
    end

    if kind == STMT_IF then
        /* Inline if expression: if c then t else e end */
        var cond_val := builder_lower_expr(b, load64(sexpr + 24))
        var fn_ptr := load64(b_raw + 28)
        var then_id  := irfn_add_block_by_ptr(fn_ptr, string_const_ptr("ifexpr_then"), 11)
        var else_id  := irfn_add_block_by_ptr(fn_ptr, string_const_ptr("ifexpr_else"), 11)
        var merge_id := irfn_add_block_by_ptr(fn_ptr, string_const_ptr("ifexpr_merge"), 12)
        var result_v := load32(fn_ptr + 44) as uint32
        store32(fn_ptr + 44, (result_v + 1) as int32)
        var binstr := instr_alloc(INSTR_BRANCH)
        store64(binstr + 8,  cond_val)
        store32(binstr + 16, then_id as int32)
        store32(binstr + 20, else_id as int32)
        irfn_emit_by_ptr(fn_ptr, binstr)
        irfn_switch_to_block(fn_ptr, then_id)
        var then_val := builder_lower_expr(b, load64(sexpr + 32))
        var cinstr_t := instr_alloc(INSTR_COPY)
        store32(cinstr_t + 4, result_v as int32)
        store64(cinstr_t + 8, then_val)
        irfn_emit_by_ptr(fn_ptr, cinstr_t)
        var jinstr_t := instr_alloc(INSTR_JUMP)
        store32(jinstr_t + 4, merge_id as int32)
        irfn_emit_by_ptr(fn_ptr, jinstr_t)
        irfn_switch_to_block(fn_ptr, else_id)
        var else_node := load64(sexpr + 40)
        if else_node != 0 then
            var else_val := builder_lower_expr(b, else_node)
            var cinstr_e := instr_alloc(INSTR_COPY)
            store32(cinstr_e + 4, result_v as int32)
            store64(cinstr_e + 8, else_val)
            irfn_emit_by_ptr(fn_ptr, cinstr_e)
        end
        var jinstr_e := instr_alloc(INSTR_JUMP)
        store32(jinstr_e + 4, merge_id as int32)
        irfn_emit_by_ptr(fn_ptr, jinstr_e)
        irfn_switch_to_block(fn_ptr, merge_id)
        return val_vreg(result_v)
    end

    /* Unhandled expression — return zero */
    return val_imm_int(0)
end

function ast_binop_to_ir(op: int32): int32 begin
    if op == BINOP_ADD then return IR_ADD end
    if op == BINOP_SUB then return IR_SUB end
    if op == BINOP_MUL then return IR_MUL end
    if op == BINOP_DIV then return IR_DIV end
    if op == BINOP_MOD then return IR_MOD end
    if op == BINOP_INT_DIV then return IR_INT_DIV end
    if op == BINOP_EQ  then return IR_EQ end
    if op == BINOP_NE  then return IR_NE end
    if op == BINOP_LT  then return IR_LT end
    if op == BINOP_GT  then return IR_GT end
    if op == BINOP_LE  then return IR_LE end
    if op == BINOP_GE  then return IR_GE end
    if op == BINOP_AND then return IR_AND end
    if op == BINOP_OR  then return IR_OR end
    if op == BINOP_BIT_AND then return IR_AND end
    if op == BINOP_BIT_OR  then return IR_OR end
    if op == BINOP_BIT_XOR then return IR_XOR end
    if op == BINOP_SHL then return IR_SHL end
    if op == BINOP_SHR then return IR_SHR end
    return IR_ADD
end

function parse_int_from_src(src: uint64, start: uint32): int64 begin
    var result: int64 := 0
    var i := start
    var c := load_byte(src + i as uint64)
    /* Handle optional sign */
    var neg: bool := false
    if c == 45 then  /* '-' */
        neg := true
        i := i + 1
        c := load_byte(src + i as uint64)
    end
    while c >= 48 and c <= 57 do
        result := result * 10 + (c - 48) as int64
        i := i + 1
        c := load_byte(src + i as uint64)
    end
    if neg then result := 0 - result end
    return result
end
/// Maia self-hosted compiler — x86_64 assembler.
/// Encodes individual instructions into a growable byte buffer,
/// with a two-pass label/relocation system.

module Assembler

extern function maia_mmap(len: uint64): uint64
extern function store32(addr: uint64, v: int32)
extern function store64(addr: uint64, v: uint64)
extern function load32(addr: uint64): int32
extern function load64(addr: uint64): uint64
extern function load_byte(addr: uint64): int32
extern function store_byte(addr: uint64, v: int32)

/* ── Physical registers ──────────────────────────────────────────────────────── */

const REG_RAX: int32 = 0
const REG_RCX: int32 = 1
const REG_RDX: int32 = 2
const REG_RBX: int32 = 3
const REG_RSP: int32 = 4
const REG_RBP: int32 = 5
const REG_RSI: int32 = 6
const REG_RDI: int32 = 7
const REG_R8:  int32 = 8
const REG_R9:  int32 = 9
const REG_R10: int32 = 10
const REG_R11: int32 = 11
const REG_R12: int32 = 12
const REG_R13: int32 = 13
const REG_R14: int32 = 14
const REG_R15: int32 = 15
const REG_AL:  int32 = 100  /* 8-bit alias for rax */

/* SysV AMD64 ABI argument registers (in order) */
const ARG0: int32 = REG_RDI
const ARG1: int32 = REG_RSI
const ARG2: int32 = REG_RDX
const ARG3: int32 = REG_RCX
const ARG4: int32 = REG_R8
const ARG5: int32 = REG_R9

/* ── Byte buffer ─────────────────────────────────────────────────────────────── */

type AsmBuf = struct {
    ptr: uint64,
    len: uint32,
    cap: uint32,
}

function asmbuf_new(): AsmBuf begin
    const CAP: uint32 = 65536
    var data_ptr := maia_mmap(CAP as uint64)
    /* Build AsmBuf manually: ptr@0(8), len@8(4), cap@12(4) */
    var buf := maia_mmap(16)
    store64(buf + 0,  data_ptr)
    store32(buf + 8,  0)
    store32(buf + 12, CAP as int32)
    return buf as AsmBuf
end

/* AsmBuf field offsets: ptr@0(uint64), len@8(uint32), cap@12(uint32) */

procedure asmbuf_emit(buf: mut AsmBuf, byte_: int32) begin
    var r   := buf as uint64
    var ptr := load64(r + 0)   /* AsmBuf.ptr @0 */
    var len := load32(r + 8) as uint32  /* AsmBuf.len @8 */
    store_byte(ptr + len as uint64, byte_)
    store32(r + 8, (len + 1) as int32)
end

procedure asmbuf_emit2(buf: mut AsmBuf, b0: int32, b1: int32) begin
    var sb0 := b0   /* save before any calls clobber rsi */
    var r   := buf as uint64
    var ptr := load64(r + 0)
    var len := load32(r + 8) as uint32
    store_byte(ptr + len as uint64,       sb0)
    store_byte(ptr + len as uint64 + 1,   b1)
    store32(r + 8, (len + 2) as int32)
end


procedure asmbuf_emit_u32(buf: mut AsmBuf, v: uint32) begin
    asmbuf_emit(buf, (v       and 0xff) as int32)
    asmbuf_emit(buf, ((v >>  8) and 0xff) as int32)
    asmbuf_emit(buf, ((v >> 16) and 0xff) as int32)
    asmbuf_emit(buf, ((v >> 24) and 0xff) as int32)
end

procedure asmbuf_emit_u64(buf: mut AsmBuf, v: uint64) begin
    asmbuf_emit_u32(buf, (v and 0xffffffff) as uint32)
    asmbuf_emit_u32(buf, ((v >> 32) and 0xffffffff) as uint32)
end

procedure asmbuf_emit_i32(buf: mut AsmBuf, v: int32) begin
    asmbuf_emit_u32(buf, v as uint32)
end

function asmbuf_cur(buf: ref AsmBuf): uint32 begin
    return load32(buf as uint64 + 8) as uint32   /* AsmBuf.len @8 */
end

procedure asmbuf_patch_i32(buf: ref AsmBuf, off: uint32, v: int32) begin
    var ptr := load64(buf as uint64 + 0)
    store_byte(ptr + off as uint64,       (v        and 0xff) as int32)
    store_byte(ptr + off as uint64 + 1,   ((v >>  8) and 0xff) as int32)
    store_byte(ptr + off as uint64 + 2,   ((v >> 16) and 0xff) as int32)
    store_byte(ptr + off as uint64 + 3,   ((v >> 24) and 0xff) as int32)
end

/* ── REX prefix helpers ──────────────────────────────────────────────────────── */

function rex_w(reg: int32, rm: int32): int32 begin
    /* REX.W = 48, REX.R if reg >= 8, REX.B if rm >= 8 */
    var rex := 0x48
    if reg >= 8 then rex := rex or 0x04 end
    if rm  >= 8 then rex := rex or 0x01 end
    return rex
end

procedure emit_rex_w(buf: mut AsmBuf, reg: int32, rm: int32) begin
    asmbuf_emit(buf, rex_w(reg, rm))
end

/* ModRM byte: mod=11 (register operands), reg field, r/m field */
function modrm_rr(reg: int32, rm: int32): int32 begin
    return 0xC0 or ((reg and 7) << 3) or (rm and 7)
end

/* ModRM for [rbp + disp8]: mod=01, reg, r/m=rbp(5) */
function modrm_rbp_disp8(reg: int32): int32 begin
    return 0x45 or ((reg and 7) << 3)
end

/* ── Instruction emitters ────────────────────────────────────────────────────── */

/* push reg */
procedure emit_push_r(buf: mut AsmBuf, reg: int32) begin
    if reg >= 8 then asmbuf_emit(buf, 0x41) end
    asmbuf_emit(buf, 0x50 or (reg and 7))
end

/* pop reg */
procedure emit_pop_r(buf: mut AsmBuf, reg: int32) begin
    if reg >= 8 then asmbuf_emit(buf, 0x41) end
    asmbuf_emit(buf, 0x58 or (reg and 7))
end

/* ret */
procedure emit_ret(buf: mut AsmBuf) begin
    asmbuf_emit(buf, 0xC3)
end

/* nop */
procedure emit_nop(buf: mut AsmBuf) begin
    asmbuf_emit(buf, 0x90)
end

/* ud2 */
procedure emit_ud2(buf: mut AsmBuf) begin
    asmbuf_emit2(buf, 0x0F, 0x0B)
end

/* syscall */
procedure emit_syscall(buf: mut AsmBuf) begin
    asmbuf_emit2(buf, 0x0F, 0x05)
end

/* mov reg, reg  (REX.W + 89 /r) */
procedure emit_mov_rr(buf: mut AsmBuf, dst: int32, src: int32) begin
    var sdst := dst; var ssrc := src
    emit_rex_w(buf, ssrc, sdst)
    asmbuf_emit(buf, 0x89)
    asmbuf_emit(buf, modrm_rr(ssrc, sdst))
end

/* mov reg, imm64  (REX.WB? + B8+r + imm64) */
procedure emit_mov_ri64(buf: mut AsmBuf, dst: int32, imm: int64) begin
    var sdst := dst   /* save before asmbuf_emit clobbers rsi */
    var rex := 0x48
    if sdst >= 8 then rex := rex or 0x01 end
    asmbuf_emit(buf, rex)
    asmbuf_emit(buf, 0xB8 or (sdst and 7))
    asmbuf_emit_u64(buf, imm as uint64)
end

/* mov reg, imm32 (sign-extend)  (REX.W + C7 /0) */
procedure emit_mov_ri32(buf: mut AsmBuf, dst: int32, imm: int32) begin
    var sdst := dst   /* save before emit_rex_w clobbers rsi */
    emit_rex_w(buf, 0, sdst)
    asmbuf_emit(buf, 0xC7)
    asmbuf_emit(buf, modrm_rr(0, sdst))
    asmbuf_emit_i32(buf, imm)
end

/* add dst, src  (REX.W + 01 /r) */
procedure emit_add_rr(buf: mut AsmBuf, dst: int32, src: int32) begin
    var sdst := dst; var ssrc := src
    emit_rex_w(buf, ssrc, sdst)
    asmbuf_emit(buf, 0x01)
    asmbuf_emit(buf, modrm_rr(ssrc, sdst))
end

/* sub dst, src  (REX.W + 29 /r) */
procedure emit_sub_rr(buf: mut AsmBuf, dst: int32, src: int32) begin
    var sdst := dst; var ssrc := src
    emit_rex_w(buf, ssrc, sdst)
    asmbuf_emit(buf, 0x29)
    asmbuf_emit(buf, modrm_rr(ssrc, sdst))
end

/* sub reg, imm8  (REX.W + 83 /5 + imm8) */
procedure emit_sub_ri8(buf: mut AsmBuf, dst: int32, imm: int32) begin
    var sdst := dst
    emit_rex_w(buf, 0, sdst)
    asmbuf_emit(buf, 0x83)
    asmbuf_emit(buf, modrm_rr(5, sdst))
    asmbuf_emit(buf, imm and 0xff)
end

/* imul dst, src  (REX.W + 0F AF /r) */
procedure emit_imul_rr(buf: mut AsmBuf, dst: int32, src: int32) begin
    var sdst := dst; var ssrc := src
    emit_rex_w(buf, sdst, ssrc)
    asmbuf_emit2(buf, 0x0F, 0xAF)
    asmbuf_emit(buf, modrm_rr(sdst, ssrc))
end

/* idiv src  (REX.W + F7 /7) */
procedure emit_idiv_r(buf: mut AsmBuf, src: int32) begin
    var ssrc := src
    emit_rex_w(buf, 0, ssrc)
    asmbuf_emit(buf, 0xF7)
    asmbuf_emit(buf, modrm_rr(7, ssrc))
end

/* xor dst, src  (REX.W + 31 /r) */
procedure emit_xor_rr(buf: mut AsmBuf, dst: int32, src: int32) begin
    var sdst := dst; var ssrc := src
    emit_rex_w(buf, ssrc, sdst)
    asmbuf_emit(buf, 0x31)
    asmbuf_emit(buf, modrm_rr(ssrc, sdst))
end

/* and dst, src  (REX.W + 21 /r) */
procedure emit_and_rr(buf: mut AsmBuf, dst: int32, src: int32) begin
    var sdst := dst; var ssrc := src
    emit_rex_w(buf, ssrc, sdst)
    asmbuf_emit(buf, 0x21)
    asmbuf_emit(buf, modrm_rr(ssrc, sdst))
end

/* or dst, src  (REX.W + 09 /r) */
procedure emit_or_rr(buf: mut AsmBuf, dst: int32, src: int32) begin
    var sdst := dst; var ssrc := src
    emit_rex_w(buf, ssrc, sdst)
    asmbuf_emit(buf, 0x09)
    asmbuf_emit(buf, modrm_rr(ssrc, sdst))
end

/* neg reg  (REX.W + F7 /3) */
procedure emit_neg_r(buf: mut AsmBuf, reg: int32) begin
    var sreg := reg
    emit_rex_w(buf, 0, sreg)
    asmbuf_emit(buf, 0xF7)
    asmbuf_emit(buf, modrm_rr(3, sreg))
end

/* not reg  (REX.W + F7 /2) */
procedure emit_not_r(buf: mut AsmBuf, reg: int32) begin
    var sreg := reg
    emit_rex_w(buf, 0, sreg)
    asmbuf_emit(buf, 0xF7)
    asmbuf_emit(buf, modrm_rr(2, sreg))
end

/* cmp dst, src  (REX.W + 3B /r) */
procedure emit_cmp_rr(buf: mut AsmBuf, lhs: int32, rhs: int32) begin
    var slhs := lhs; var srhs := rhs
    emit_rex_w(buf, slhs, srhs)
    asmbuf_emit(buf, 0x3B)
    asmbuf_emit(buf, modrm_rr(slhs, srhs))
end

/* test dst, src  (REX.W + 85 /r) */
procedure emit_test_rr(buf: mut AsmBuf, lhs: int32, rhs: int32) begin
    var slhs := lhs; var srhs := rhs
    emit_rex_w(buf, srhs, slhs)
    asmbuf_emit(buf, 0x85)
    asmbuf_emit(buf, modrm_rr(srhs, slhs))
end

/* sete al  (0F 94 C0) */
procedure emit_sete(buf: mut AsmBuf) begin
    asmbuf_emit2(buf, 0x0F, 0x94); asmbuf_emit2(buf, 0xC0, 0x90)  /* sete al; nop */
end

/* setne al (0F 95 C0) */
procedure emit_setne(buf: mut AsmBuf) begin
    asmbuf_emit2(buf, 0x0F, 0x95); asmbuf_emit2(buf, 0xC0, 0x90)
end

/* setl al  (0F 9C C0) */
procedure emit_setl(buf: mut AsmBuf) begin
    asmbuf_emit2(buf, 0x0F, 0x9C); asmbuf_emit2(buf, 0xC0, 0x90)
end

/* setg al  (0F 9F C0) */
procedure emit_setg(buf: mut AsmBuf) begin
    asmbuf_emit2(buf, 0x0F, 0x9F); asmbuf_emit2(buf, 0xC0, 0x90)
end

/* setle al (0F 9E C0) */
procedure emit_setle(buf: mut AsmBuf) begin
    asmbuf_emit2(buf, 0x0F, 0x9E); asmbuf_emit2(buf, 0xC0, 0x90)
end

/* setge al (0F 9D C0) */
procedure emit_setge(buf: mut AsmBuf) begin
    asmbuf_emit2(buf, 0x0F, 0x9D); asmbuf_emit2(buf, 0xC0, 0x90)
end

/* movzx reg, al  (REX.W? + 0F B6 /r — zero-extend byte to 64-bit) */
procedure emit_movzx_ral(buf: mut AsmBuf, dst: int32) begin
    var sdst := dst
    emit_rex_w(buf, sdst, REG_RAX)
    asmbuf_emit2(buf, 0x0F, 0xB6)
    asmbuf_emit(buf, modrm_rr(sdst, REG_RAX))
end

/* shl reg, cl  (REX.W + D3 /4) */
procedure emit_shl_rcl(buf: mut AsmBuf, reg: int32) begin
    var sreg := reg
    emit_rex_w(buf, 0, sreg)
    asmbuf_emit(buf, 0xD3)
    asmbuf_emit(buf, modrm_rr(4, sreg))
end

/* shr reg, cl  (REX.W + D3 /5) */
procedure emit_shr_rcl(buf: mut AsmBuf, reg: int32) begin
    emit_rex_w(buf, 0, reg)
    asmbuf_emit(buf, 0xD3)
    asmbuf_emit(buf, modrm_rr(5, reg))
end

/* mov reg, [base]  (REX.W + 8B /r  mod=00) */
procedure emit_mov_rm(buf: mut AsmBuf, dst: int32, base: int32) begin
    emit_rex_w(buf, dst, base)
    asmbuf_emit(buf, 0x8B)
    /* mod=00, reg=dst, r/m=base */
    if base == REG_RSP or base == REG_R12 then
        /* SIB byte needed for rsp/r12 as base */
        asmbuf_emit(buf, (dst and 7) << 3 or 4)  /* mod=00, reg, r/m=100 (SIB) */
        asmbuf_emit(buf, 0x24)  /* SIB: ss=0, index=4(none), base=rsp */
    else
        asmbuf_emit(buf, (dst and 7) << 3 or (base and 7))
    end
end

/* mov [base], src  (REX.W + 89 /r  mod=00) */
procedure emit_mov_mr(buf: mut AsmBuf, base: int32, src: int32) begin
    emit_rex_w(buf, src, base)
    asmbuf_emit(buf, 0x89)
    if base == REG_RSP or base == REG_R12 then
        asmbuf_emit(buf, (src and 7) << 3 or 4)
        asmbuf_emit(buf, 0x24)
    else
        asmbuf_emit(buf, (src and 7) << 3 or (base and 7))
    end
end

/* mov reg, [base + idx*8]  (REX.W + 8B /r mod=00 SIB scale=8) */
procedure emit_mov_rm_sib8(buf: mut AsmBuf, dst: int32, base: int32, idx: int32) begin
    var need_rex_x := if idx >= 8 then 0x02 else 0 end
    var need_rex_b := if base >= 8 then 0x01 else 0 end
    var need_rex_r := if dst >= 8 then 0x04 else 0 end
    asmbuf_emit(buf, 0x48 or need_rex_r or need_rex_x or need_rex_b)
    asmbuf_emit(buf, 0x8B)
    asmbuf_emit(buf, (dst and 7) << 3 or 4)  /* mod=00, reg=dst, r/m=100 (SIB) */
    asmbuf_emit(buf, (3 << 6) or ((idx and 7) << 3) or (base and 7))  /* scale=8, idx, base */
end

/* mov [base + idx*8], src */
procedure emit_mov_mr_sib8(buf: mut AsmBuf, base: int32, idx: int32, src: int32) begin
    var need_rex_x := if idx >= 8 then 0x02 else 0 end
    var need_rex_b := if base >= 8 then 0x01 else 0 end
    var need_rex_r := if src >= 8 then 0x04 else 0 end
    asmbuf_emit(buf, 0x48 or need_rex_r or need_rex_x or need_rex_b)
    asmbuf_emit(buf, 0x89)
    asmbuf_emit(buf, (src and 7) << 3 or 4)
    asmbuf_emit(buf, (3 << 6) or ((idx and 7) << 3) or (base and 7))
end

/* mov reg, [rbp + disp8]  (REX.W + 8B /r mod=01) */
procedure emit_mov_rbp_disp8(buf: mut AsmBuf, dst: int32, disp: int32) begin
    emit_rex_w(buf, dst, REG_RBP)
    asmbuf_emit(buf, 0x8B)
    asmbuf_emit(buf, modrm_rbp_disp8(dst))
    asmbuf_emit(buf, disp and 0xff)
end

/* mov [rbp + disp8], src  (REX.W + 89 /r mod=01) */
procedure emit_mov_rbp_disp8_src(buf: mut AsmBuf, disp: int32, src: int32) begin
    emit_rex_w(buf, src, REG_RBP)
    asmbuf_emit(buf, 0x89)
    asmbuf_emit(buf, 0x45 or ((src and 7) << 3))
    asmbuf_emit(buf, disp and 0xff)
end

/* lea dst, [rbp + disp8]  (REX.W + 8D /r mod=01) */
procedure emit_lea_rbp_disp8(buf: mut AsmBuf, dst: int32, disp: int32) begin
    emit_rex_w(buf, dst, REG_RBP)
    asmbuf_emit(buf, 0x8D)
    asmbuf_emit(buf, modrm_rbp_disp8(dst))
    asmbuf_emit(buf, disp and 0xff)
end

/* call rel32  (E8 + rel32) */
/* Returns the offset of the rel32 field for later patching. */
function emit_call_rel32(buf: mut AsmBuf): uint32 begin
    asmbuf_emit(buf, 0xE8)
    var off := asmbuf_cur(buf)
    asmbuf_emit_i32(buf, 0)  /* placeholder */
    return off
end

/* call *reg  (REX.W? + FF /2) */
procedure emit_call_r(buf: mut AsmBuf, reg: int32) begin
    if reg >= 8 then asmbuf_emit(buf, 0x41) end
    asmbuf_emit(buf, 0xFF)
    asmbuf_emit(buf, modrm_rr(2, reg))
end

/* jmp rel32  (E9 + rel32) */
function emit_jmp_rel32(buf: mut AsmBuf): uint32 begin
    asmbuf_emit(buf, 0xE9)
    var off := asmbuf_cur(buf)
    asmbuf_emit_i32(buf, 0)
    return off
end

/* jne rel32  (0F 85 + rel32) */
function emit_jne_rel32(buf: mut AsmBuf): uint32 begin
    asmbuf_emit2(buf, 0x0F, 0x85)
    var off := asmbuf_cur(buf)
    asmbuf_emit_i32(buf, 0)
    return off
end

/* Patch a rel32 branch so it jumps to target_off from the end of the instruction. */
/* branch_imm_off = offset of the 4-byte immediate; instruction end = branch_imm_off + 4 */
procedure patch_rel32(buf: ref AsmBuf, branch_imm_off: uint32, target_off: uint32) begin
    var instr_end := branch_imm_off + 4
    var rel := (target_off as int32) - (instr_end as int32)
    asmbuf_patch_i32(buf, branch_imm_off, rel)
end

/* ── Label / relocation system ───────────────────────────────────────────────── */
/* Labels are uint32 IDs.  A relocation records where to patch and which label. */

type LabelMap = struct {
    offsets:  uint64,  /* label_id → offset (uint32), -1 = undefined */
    cap:      uint32,
    relocs:   uint64,  /* (site_off: uint32, label_id: uint32) pairs */
    reloc_cnt:uint32,
}

const UNDEF_LABEL: uint32 = 4294967295  /* 0xFFFFFFFF */

/* LabelMap field offsets: offsets@0(uint64), cap@8(uint32), relocs@12(uint64), reloc_cnt@20(uint32) */

function labelmap_new(): LabelMap begin
    const CAP: uint32 = 1024
    var offsets := maia_mmap((CAP as uint64) * 4)
    var i: uint32 := 0
    while i < CAP do
        store32(offsets + (i as uint64) * 4, UNDEF_LABEL as int32)
        i := i + 1
    end
    var relocs := maia_mmap((CAP as uint64) * 8)
    /* Build LabelMap manually: offsets@0(8), cap@8(4), relocs@12(8), reloc_cnt@20(4) */
    var lm := maia_mmap(24)
    store64(lm + 0,  offsets)
    store32(lm + 8,  CAP as int32)
    store64(lm + 12, relocs)
    store32(lm + 20, 0)
    return lm as LabelMap
end

procedure labelmap_define(lm: mut LabelMap, id: uint32, off: uint32) begin
    var offsets := load64(lm as uint64 + 0)
    store32(offsets + (id as uint64) * 4, off as int32)
end

function labelmap_resolve(lm: ref LabelMap, id: uint32): uint32 begin
    var offsets := load64(lm as uint64 + 0)
    return load32(offsets + (id as uint64) * 4) as uint32
end

procedure labelmap_add_reloc(lm: mut LabelMap, site_off: uint32, label_id: uint32) begin
    var r := lm as uint64
    var relocs    := load64(r + 12)
    var reloc_cnt := load32(r + 20) as uint32
    var slot := relocs + (reloc_cnt as uint64) * 8
    store32(slot,     site_off as int32)
    store32(slot + 4, label_id as int32)
    store32(r + 20, (reloc_cnt + 1) as int32)
end

procedure labelmap_resolve_relocs(lm: ref LabelMap, buf: ref AsmBuf) begin
    var r         := lm as uint64
    var relocs    := load64(r + 12)
    var reloc_cnt := load32(r + 20) as uint32
    var i: uint32 := 0
    while i < reloc_cnt do
        var slot     := relocs + (i as uint64) * 8
        var site_off := load32(slot)     as uint32
        var label_id := load32(slot + 4) as uint32
        var target   := labelmap_resolve(lm, label_id)
        if target != UNDEF_LABEL then
            patch_rel32(buf, site_off, target)
        end
        i := i + 1
    end
end

/* ── Extern call site table ──────────────────────────────────────────────────── */
/* Records (imm_off: uint32, name_ptr: uint64, name_len: uint32) triples. */

type ExternSites = struct {
    ptr:   uint64,
    count: uint32,
}

const EXTERN_ENTRY: uint32 = 16  /* imm_off(4), _pad(4), name_ptr(8) — + name_len in next slot */

/* ExternSites/StringRefs field offsets: ptr@0(uint64), count@8(uint32) */

function extern_sites_new(): ExternSites begin
    var data := maia_mmap(4096)
    var es := maia_mmap(12)
    store64(es + 0, data)
    store32(es + 8, 0)
    return es as ExternSites
end

procedure extern_sites_add(es: mut ExternSites, imm_off: uint32, name_ptr: uint64, name_len: uint32) begin
    var r     := es as uint64
    var ptr   := load64(r + 0)
    var count := load32(r + 8) as uint32
    var slot := ptr + (count as uint64) * 24
    store32(slot,      imm_off as int32)
    store32(slot + 4,  name_len as int32)
    store64(slot + 8,  name_ptr)
    store32(r + 8, (count + 1) as int32)
end

/* ── String ref table ────────────────────────────────────────────────────────── */

type StringRefs = struct {
    ptr:   uint64,
    count: uint32,
}

const STR_REF_BYTES: uint32 = 8  /* imm_off(4), string_idx(4) */

function string_refs_new(): StringRefs begin
    var data := maia_mmap(4096)
    var sr := maia_mmap(12)
    store64(sr + 0, data)
    store32(sr + 8, 0)
    return sr as StringRefs
end

procedure string_refs_add(sr: mut StringRefs, imm_off: uint32, string_idx: uint32) begin
    var r     := sr as uint64
    var ptr   := load64(r + 0)
    var count := load32(r + 8) as uint32
    var slot := ptr + (count as uint64) * STR_REF_BYTES as uint64
    store32(slot,     imm_off as int32)
    store32(slot + 4, string_idx as int32)
    store32(r + 8, (count + 1) as int32)
end
/// Maia self-hosted compiler — x86_64 code generator.
/// Lowers IrModule to native x86_64 machine code.
/// Targets Linux ELF64, System V AMD64 ABI.

module Codegen_X86_64

use IR
use Assembler

extern function maia_mmap(len: uint64): uint64
extern function store32(addr: uint64, v: int32)
extern function store64(addr: uint64, v: uint64)
extern function load32(addr: uint64): int32
extern function load64(addr: uint64): uint64
extern function load_byte(addr: uint64): int32
extern function store_byte(addr: uint64, v: int32)

/* ── Register allocator (linear scan, greedy) ────────────────────────────────── */
/* Maps VReg → physical register or spill slot. */

/* Allocatable registers (caller-saved first) */
const ALLOC_ORDER_LEN: uint32 = 12
const ALLOC_R10: int32 = 0
const ALLOC_R11: int32 = 1
const ALLOC_RAX: int32 = 2
const ALLOC_RCX: int32 = 3
const ALLOC_RDX: int32 = 4
const ALLOC_RSI: int32 = 5
const ALLOC_RDI: int32 = 6
const ALLOC_RBX: int32 = 7
const ALLOC_R12: int32 = 8
const ALLOC_R13: int32 = 9
const ALLOC_R14: int32 = 10
const ALLOC_R15: int32 = 11

function alloc_phys_reg(idx: int32): int32 begin
    if idx == 0  then return REG_R10 end
    if idx == 1  then return REG_R11 end
    if idx == 2  then return REG_RAX end
    if idx == 3  then return REG_RCX end
    if idx == 4  then return REG_RDX end
    if idx == 5  then return REG_RSI end
    if idx == 6  then return REG_RDI end
    if idx == 7  then return REG_RBX end
    if idx == 8  then return REG_R12 end
    if idx == 9  then return REG_R13 end
    if idx == 10 then return REG_R14 end
    if idx == 11 then return REG_R15 end
    return REG_RAX
end

/* RegAlloc: maps vreg → (kind, value) */
/*   kind=0: register (value = physical reg number) */
/*   kind=1: spill (value = stack offset from rbp, negative) */
/* Layout per entry: kind(4), value(4) */
const RA_ENTRY_BYTES: uint32 = 8
const RA_MAX_VREGS:   uint32 = 256

type RegAlloc = struct {
    entries:   uint64,  /* vreg → (kind, phys_or_spill) */
    used:      uint64,  /* bool[16] — which physical regs are taken */
    next_spill:int32,  /* grows negative from 0 */
}

function ra_new(): RegAlloc begin
    var entries := maia_mmap((RA_MAX_VREGS as uint64) * RA_ENTRY_BYTES as uint64)
    var i: uint32 := 0
    while i < RA_MAX_VREGS do
        store32(entries + (i as uint64) * RA_ENTRY_BYTES as uint64, -1)
        i := i + 1
    end
    /* Build RegAlloc manually via raw stores to avoid struct_lit field access issues */
    var used := maia_mmap(16)
    var buf  := maia_mmap(24)  /* RegAlloc struct: entries@0(8), used@8(8), next_spill@16(4) */
    store64(buf + 0,  entries)
    store64(buf + 8,  used)
    store32(buf + 16, 0)   /* next_spill = 0 */
    return buf as RegAlloc
end

/* RegAlloc field offsets: entries@0, used@8, next_spill@16 */

procedure ra_assign_param(ra: mut RegAlloc, vreg: uint32, reg: int32) begin
    var r := ra as uint64
    var entries := load64(r + 0)
    var used    := load64(r + 8)
    var slot := entries + (vreg as uint64) * RA_ENTRY_BYTES as uint64
    store32(slot,     0)
    store32(slot + 4, reg)
    store_byte(used + reg as uint64, 1)
end

function ra_alloc(ra: mut RegAlloc, vreg: uint32): int32 begin
    var r := ra as uint64
    var entries    := load64(r + 0)
    var used       := load64(r + 8)
    var next_spill := load32(r + 16)
    var slot := entries + (vreg as uint64) * RA_ENTRY_BYTES as uint64
    if load32(slot) >= 0 then
        return load32(slot + 4)
    end
    var i: int32 := 0
    while i < ALLOC_ORDER_LEN as int32 do
        var phys := alloc_phys_reg(i)
        if load_byte(used + phys as uint64) == 0 then
            store_byte(used + phys as uint64, 1)
            store32(slot,     0)
            store32(slot + 4, phys)
            return phys
        end
        i := i + 1
    end
    /* Spill: allocate stack slot */
    var new_spill := next_spill - 8
    store32(r + 16, new_spill)  /* update next_spill */
    store32(slot,     1)
    store32(slot + 4, new_spill)
    return new_spill
end

function ra_get(ra: ref RegAlloc, vreg: uint32): int32 begin
    var entries := load64(ra as uint64 + 0)
    var slot := entries + (vreg as uint64) * RA_ENTRY_BYTES as uint64
    if load32(slot) < 0 then return REG_RAX end
    if load32(slot) == 0 then return load32(slot + 4) end
    return REG_RAX
end

function ra_is_spill(ra: ref RegAlloc, vreg: uint32): bool begin
    var entries := load64(ra as uint64 + 0)
    var slot := entries + (vreg as uint64) * RA_ENTRY_BYTES as uint64
    return load32(slot) == 1
end

function ra_spill_off(ra: ref RegAlloc, vreg: uint32): int32 begin
    var entries := load64(ra as uint64 + 0)
    var slot := entries + (vreg as uint64) * RA_ENTRY_BYTES as uint64
    return load32(slot + 4)
end

function ra_stack_size(ra: ref RegAlloc): uint32 begin
    var next_spill := load32(ra as uint64 + 16)
    var sz := 0 - next_spill
    return ((sz + 15) / 16 * 16) as uint32
end

/* ── Codegen result ──────────────────────────────────────────────────────────── */

type CodegenResult = struct {
    text_ptr:       uint64,
    text_len:       uint32,
    rodata_ptr:     uint64,
    rodata_len:     uint32,
    /* Symbol table: name_ptr(8), name_len(4), offset(4) triples */
    syms_ptr:       uint64,
    sym_count:      uint32,
    extern_sites:   ExternSites,
    string_refs:    StringRefs,
    strings_ptr:    uint64,  /* (str_ptr(8), str_len(4)) from IrModule.string_pool */
    string_count:   uint32,
}

/* ── Codegen state ───────────────────────────────────────────────────────────── */

type Codegen = struct {
    buf:          AsmBuf,
    rodata:       AsmBuf,
    labels:       LabelMap,
    extern_sites: ExternSites,
    string_refs:  StringRefs,
    /* Function label registry: name_ptr(8), name_len(4), label_id(4) per entry */
    fn_labels:    uint64,
    fn_label_cnt: uint32,
    next_label:   uint32,
}

function codegen_new(): Codegen begin
    return Codegen {
        .buf          = asmbuf_new(),
        .rodata       = asmbuf_new(),
        .labels       = labelmap_new(),
        .extern_sites = extern_sites_new(),
        .string_refs  = string_refs_new(),
        .fn_labels    = maia_mmap(4096),
        .fn_label_cnt = 0,
        .next_label   = 0,
    }
end

/* Codegen field offsets: buf@0, rodata@8, labels@16, extern_sites@24, string_refs@32, fn_labels@40, fn_label_cnt@48, next_label@52 */

function cg_fresh_label(cg: mut Codegen): uint32 begin
    var r := cg as uint64
    var l := load32(r + 52) as uint32  /* next_label @52 */
    store32(r + 52, (l + 1) as int32)
    return l
end

procedure cg_define_label(cg: mut Codegen, id: uint32) begin
    var r := cg as uint64
    var lm  := load64(r + 16)  /* labels @16 */
    var buf := load64(r + 0)   /* buf @0 */
    var cur := asmbuf_cur(buf)
    labelmap_define(lm, id, cur)
end

procedure cg_register_fn_label(cg: mut Codegen, name_ptr: uint64, name_len: uint32, label_id: uint32) begin
    var r := cg as uint64
    var fn_labels := load64(r + 40)   /* fn_labels @40 */
    var fn_cnt    := load32(r + 48) as uint32  /* fn_label_cnt @48 */
    var slot := fn_labels + (fn_cnt as uint64) * 16
    store64(slot,      name_ptr)
    store32(slot + 8,  name_len as int32)
    store32(slot + 12, label_id as int32)
    store32(r + 48, (fn_cnt + 1) as int32)
end

function cg_fn_label(cg: ref Codegen, name_ptr: uint64, name_len: uint32): int32 begin
    var r := cg as uint64
    var fn_labels := load64(r + 40)
    var fn_cnt    := load32(r + 48) as uint32
    var i: uint32 := 0
    while i < fn_cnt do
        var slot := fn_labels + (i as uint64) * 16
        var np := load64(slot)
        var nl := load32(slot + 8) as uint32
        if nl == name_len and strings_equal(np, name_ptr, name_len) then
            return load32(slot + 12)
        end
        i := i + 1
    end
    return -1
end

/* ── Main generation entry point ─────────────────────────────────────────────── */

function codegen_generate(cg: mut Codegen, mod_ptr: uint64): CodegenResult begin
    /* Use raw ptr for all Codegen field access to avoid spill-interaction issues */
    var cg_raw    := cg as uint64
    var cg_rodata := load64(cg_raw + 8)   /* Codegen.rodata @8 */

    /* Build rodata from string pool */
    var str_pool  := load64(mod_ptr + 24)
    var str_count := load32(mod_ptr + 32) as uint32
    var i: uint32 := 0
    while i < str_count do
        var slot    := str_pool + (i as uint64) * STR_ENTRY_BYTES as uint64
        var sp      := load64(slot)
        var sl      := load32(slot + 8) as uint32
        /* Emit string bytes + null terminator into rodata */
        var j: uint32 := 0
        while j < sl do
            asmbuf_emit(cg_rodata, load_byte(sp + j as uint64))
            j := j + 1
        end
        asmbuf_emit(cg_rodata, 0)  /* null terminator */
        i := i + 1
    end

    /* First pass: assign label IDs to all internal functions */
    var fn_arr   := load64(mod_ptr)
    var fn_count := load32(mod_ptr + 8) as uint32
    i := 0
    while i < fn_count do
        var fn_ptr := load64(fn_arr + (i as uint64) * IRFN_PTR_BYTES as uint64)
        var is_ext := load32(fn_ptr + 52)
        if is_ext == 0 then
            var lbl := cg_fresh_label(cg)
            var np := load64(fn_ptr)
            var nl := load32(fn_ptr + 8) as uint32
            cg_register_fn_label(cg, np, nl, lbl)
        end
        i := i + 1
    end

    /* Second pass: generate code */
    i := 0
    while i < fn_count do
        var fn_ptr := load64(fn_arr + (i as uint64) * IRFN_PTR_BYTES as uint64)
        var is_ext := load32(fn_ptr + 52)
        if is_ext == 0 then
            cg_gen_function(cg, fn_ptr, mod_ptr)
        end
        i := i + 1
    end

    /* Resolve label relocations: use raw ptr for Codegen.labels@16 and Codegen.buf@0 */
    var cg_labels_ptr := load64(cg_raw + 16)  /* Codegen.labels @16 */
    var cg_buf_ptr    := load64(cg_raw + 0)   /* Codegen.buf @0 */
    labelmap_resolve_relocs(cg_labels_ptr, cg_buf_ptr)

    /* Build symbol table - use raw ptr for cg fields */
    var cg_fn_label_cnt := load32(cg_raw + 48) as uint32  /* Codegen.fn_label_cnt @48 */
    var cg_fn_labels    := load64(cg_raw + 40)             /* Codegen.fn_labels @40 */
    var syms_ptr := maia_mmap((cg_fn_label_cnt as uint64) * 16)
    var sym_count: uint32 := 0
    i := 0
    while i < cg_fn_label_cnt do
        var slot := cg_fn_labels + (i as uint64) * 16
        var np   := load64(slot)
        var nl   := load32(slot + 8) as uint32
        var lbl  := load32(slot + 12) as uint32
        var off  := labelmap_resolve(cg_labels_ptr, lbl)
        if off != UNDEF_LABEL then
            var ssym := syms_ptr + (sym_count as uint64) * 16
            store64(ssym,     np)
            store32(ssym + 8, nl as int32)
            store32(ssym + 12, off as int32)
            sym_count := sym_count + 1
        end
        i := i + 1
    end

    /* Get rodata, extern_sites, string_refs via raw ptr */
    var cg_ext_sites := load64(cg_raw + 24)  /* Codegen.extern_sites @24 */
    var cg_str_refs  := load64(cg_raw + 32)  /* Codegen.string_refs @32 */
    /* buf fields: buf is AsmBuf struct ptr; ptr@0, len@8 within AsmBuf */
    var cg_buf_data_ptr := load64(cg_buf_ptr + 0)  /* AsmBuf.ptr */
    var cg_buf_len      := load32(cg_buf_ptr + 8) as uint32  /* AsmBuf.len */
    var cg_rod_data_ptr := load64(cg_rodata + 0)  /* rodata AsmBuf.ptr */
    var cg_rod_len      := load32(cg_rodata + 8) as uint32  /* rodata AsmBuf.len */

    return CodegenResult {
        .text_ptr     = cg_buf_data_ptr,
        .text_len     = cg_buf_len,
        .rodata_ptr   = cg_rod_data_ptr,
        .rodata_len   = cg_rod_len,
        .syms_ptr     = syms_ptr,
        .sym_count    = sym_count,
        .extern_sites = cg_ext_sites,
        .string_refs  = cg_str_refs,
        .strings_ptr  = str_pool,
        .string_count = str_count,
    }
end

/* ── Function code generation ────────────────────────────────────────────────── */

procedure cg_gen_function(cg: mut Codegen, fn_ptr: uint64, mod_ptr: uint64) begin
    var cg_raw := cg as uint64  /* raw Codegen ptr - use for all field access */
    var cg_buf := load64(cg_raw + 0)   /* Codegen.buf @0 (AsmBuf ptr) */
    var np := load64(fn_ptr)
    var nl := load32(fn_ptr + 8) as uint32
    var lbl_id := cg_fn_label(cg, np, nl)
    if lbl_id < 0 then return end

    /* Define label at current text offset */
    cg_define_label(cg, lbl_id as uint32)

    /* Register allocator */
    var ra := ra_new()
    var param_count := load32(fn_ptr + 40) as uint32
    var i: uint32 := 0
    while i < param_count and i < 6 do
        ra_assign_param(ra, i, cg_arg_reg(i))
        i := i + 1
    end

    /* Pre-allocate all vregs */
    var block_count := load32(fn_ptr + 24) as uint32
    var blocks      := load64(fn_ptr + 16)
    i := 0
    while i < block_count do
        var bb_ptr     := blocks + (i as uint64) * BB_STRUCT_BYTES as uint64
        var instr_count := load32(bb_ptr + 32) as uint32
        var instrs     := load64(bb_ptr + 24)
        var j: uint32 := 0
        while j < instr_count do
            var instr := instrs + (j as uint64) * INSTR_BYTES as uint64
            cg_preallloc(ra, instr)
            j := j + 1
        end
        i := i + 1
    end

    /* Prologue */
    var stack_sz := ra_stack_size(ra) + 8
    var aligned_sz := (stack_sz + 15) / 16 * 16
    emit_push_r(cg_buf, REG_RBP)
    emit_mov_rr(cg_buf, REG_RBP, REG_RSP)
    if aligned_sz > 0 then
        emit_sub_ri8(cg_buf, REG_RSP, aligned_sz as int32)
    end

    /* Assign block labels */
    var block_labels := maia_mmap((block_count as uint64) * 4)
    i := 0
    while i < block_count do
        var bl := cg_fresh_label(cg)
        store32(block_labels + (i as uint64) * 4, bl as int32)
        i := i + 1
    end

    /* Generate each basic block */
    i := 0
    while i < block_count do
        var bb_ptr     := blocks + (i as uint64) * BB_STRUCT_BYTES as uint64
        var bl         := load32(block_labels + (i as uint64) * 4) as uint32
        cg_define_label(cg, bl)
        var instr_count := load32(bb_ptr + 32) as uint32
        var instrs      := load64(bb_ptr + 24)
        var j: uint32 := 0
        while j < instr_count do
            var instr := instrs + (j as uint64) * INSTR_BYTES as uint64
            cg_gen_instr(cg, instr, ra, block_labels, mod_ptr)
            j := j + 1
        end
        i := i + 1
    end
end

procedure cg_preallloc(ra: mut RegAlloc, instr: uint64) begin
    var kind := load32(instr)
    var dst  := load32(instr + 4) as uint32
    if kind == INSTR_BINOP or kind == INSTR_UNOP or kind == INSTR_COPY or
       kind == INSTR_CAST  or kind == INSTR_CALL or kind == INSTR_ADDR_OF or
       kind == INSTR_LOAD  or kind == INSTR_ALLOCA or
       kind == INSTR_INDEX_GET or kind == INSTR_FIELD_GET then
    ra_alloc(ra, dst)
    end
end

function cg_arg_reg(idx: uint32): int32 begin
    if idx == 0 then return REG_RDI end
    if idx == 1 then return REG_RSI end
    if idx == 2 then return REG_RDX end
    if idx == 3 then return REG_RCX end
    if idx == 4 then return REG_R8 end
    return REG_R9
end

procedure cg_gen_instr(cg: mut Codegen, instr: uint64, ra: mut RegAlloc,
                        block_labels: uint64, mod_ptr: uint64) begin
    var scg := cg
    var sra := ra
    var kind := load32(instr)

    if kind == INSTR_NOP then
        emit_nop(scg.buf)
        return
    end

    if kind == INSTR_COPY then
        var dst_v := load32(instr + 4) as uint32
        var src   := load64(instr + 8)
        var dst_r := ra_get(sra, dst_v)
        cg_load_value(scg, src, dst_r, sra)
        return
    end

    if kind == INSTR_BINOP then
        var dst_v := load32(instr + 4) as uint32
        var ty    := load32(instr + 8)
        var op    := load32(instr + 12)
        var lhs_v := load64(instr + 16)
        var rhs_v := load64(instr + 24)
        var dst_r := ra_get(sra, dst_v)
        var tmp   := REG_R11
        cg_load_value(scg, lhs_v, dst_r, sra)
        cg_load_value(scg, rhs_v, tmp, sra)
    ty
        if op == IR_ADD then emit_add_rr(scg.buf, dst_r, tmp) end
        if op == IR_SUB then emit_sub_rr(scg.buf, dst_r, tmp) end
        if op == IR_MUL then emit_imul_rr(scg.buf, dst_r, tmp) end
        if op == IR_DIV or op == IR_INT_DIV then
            emit_mov_rr(scg.buf, REG_RAX, dst_r)
            emit_xor_rr(scg.buf, REG_RDX, REG_RDX)
            emit_idiv_r(scg.buf, tmp)
            emit_mov_rr(scg.buf, dst_r, REG_RAX)
        end
        if op == IR_MOD then
            emit_mov_rr(scg.buf, REG_RAX, dst_r)
            emit_xor_rr(scg.buf, REG_RDX, REG_RDX)
            emit_idiv_r(scg.buf, tmp)
            emit_mov_rr(scg.buf, dst_r, REG_RDX)
        end
        if op == IR_EQ then
            emit_cmp_rr(scg.buf, dst_r, tmp)
            emit_xor_rr(scg.buf, dst_r, dst_r)
            emit_sete(scg.buf)
            emit_movzx_ral(scg.buf, dst_r)
        end
        if op == IR_NE then
            emit_cmp_rr(scg.buf, dst_r, tmp)
            emit_xor_rr(scg.buf, dst_r, dst_r)
            emit_setne(scg.buf)
            emit_movzx_ral(scg.buf, dst_r)
        end
        if op == IR_LT then
            emit_cmp_rr(scg.buf, dst_r, tmp)
            emit_xor_rr(scg.buf, dst_r, dst_r)
            emit_setl(scg.buf)
            emit_movzx_ral(scg.buf, dst_r)
        end
        if op == IR_GT then
            emit_cmp_rr(scg.buf, dst_r, tmp)
            emit_xor_rr(scg.buf, dst_r, dst_r)
            emit_setg(scg.buf)
            emit_movzx_ral(scg.buf, dst_r)
        end
        if op == IR_LE then
            emit_cmp_rr(scg.buf, dst_r, tmp)
            emit_xor_rr(scg.buf, dst_r, dst_r)
            emit_setle(scg.buf)
            emit_movzx_ral(scg.buf, dst_r)
        end
        if op == IR_GE then
            emit_cmp_rr(scg.buf, dst_r, tmp)
            emit_xor_rr(scg.buf, dst_r, dst_r)
            emit_setge(scg.buf)
            emit_movzx_ral(scg.buf, dst_r)
        end
        if op == IR_AND then emit_and_rr(scg.buf, dst_r, tmp) end
        if op == IR_OR  then emit_or_rr(scg.buf, dst_r, tmp) end
        if op == IR_XOR then emit_xor_rr(scg.buf, dst_r, tmp) end
        if op == IR_SHL then
            emit_mov_rr(scg.buf, REG_RCX, tmp)
            emit_shl_rcl(scg.buf, dst_r)
        end
        if op == IR_SHR then
            emit_mov_rr(scg.buf, REG_RCX, tmp)
            emit_shr_rcl(scg.buf, dst_r)
        end
        return
    end

    if kind == INSTR_UNOP then
        var dst_v := load32(instr + 4) as uint32
        var op    := load32(instr + 12)
        var src_v := load64(instr + 16)
        var dst_r := ra_get(sra, dst_v)
        cg_load_value(scg, src_v, dst_r, sra)
        if op == IR_NEG     then emit_neg_r(scg.buf, dst_r) end
        if op == IR_BIT_NOT then emit_not_r(scg.buf, dst_r) end
        if op == IR_NOT then
            emit_test_rr(scg.buf, dst_r, dst_r)
            emit_xor_rr(scg.buf, dst_r, dst_r)
            emit_sete(scg.buf)
            emit_movzx_ral(scg.buf, dst_r)
        end
        return
    end

    if kind == INSTR_CALL then
        var dst_v     := load32(instr + 4) as uint32
        var callee_v  := load64(instr + 16)
        var args_ptr  := load64(instr + 24)
        var arg_count := load32(instr + 32) as uint32
        var dst_r     := ra_get(sra, dst_v)
        var i: uint32 := 0
        while i < arg_count and i < 6 do
            var av := load64(args_ptr + (i as uint64) * 8)
            cg_load_value(scg, av, cg_arg_reg(i), sra)
            i := i + 1
        end
        var ck := val_kind(callee_v)
        if ck == VAL_GLOBAL then
            var name_ptr := val_global_ptr(callee_v)
            var name_len := val_global_len(callee_v)
            var lbl := cg_fn_label(scg, name_ptr, name_len)
            if lbl >= 0 then
                /* Internal call: emit E8 + rel32 placeholder; add reloc */
                asmbuf_emit(scg.buf, 0xE8)
                var imm_off := asmbuf_cur(scg.buf)
                asmbuf_emit_i32(scg.buf, 0)
                labelmap_add_reloc(scg.labels, imm_off, lbl as uint32)
            else
                /* External call: mov r11, imm32; call r11 (address patched by linker) */
                var imm_off2 := asmbuf_cur(scg.buf) + 2  /* after REX + B8 */
                emit_mov_ri32(scg.buf, REG_R11, 0)
                emit_call_r(scg.buf, REG_R11)
                extern_sites_add(scg.extern_sites, imm_off2, name_ptr, name_len)
            end
        elsif ck == VAL_VREG then
            var vr := val_vreg_id(callee_v)
            var cr := ra_get(sra, vr)
            emit_call_r(scg.buf, cr)
        else
            emit_call_r(scg.buf, REG_R11)
        end
        /* Return value is in RAX; move to dst */
        emit_mov_rr(scg.buf, dst_r, REG_RAX)
        return
    end

    if kind == INSTR_RET then
        var val_ptr := load64(instr + 8)
        if val_ptr != 0 then
            cg_load_value(scg, val_ptr, REG_RAX, sra)
        else
            emit_xor_rr(scg.buf, REG_RAX, REG_RAX)
        end
        emit_mov_rr(scg.buf, REG_RSP, REG_RBP)
        emit_pop_r(scg.buf, REG_RBP)
        emit_ret(scg.buf)
        return
    end

    if kind == INSTR_JUMP then
        var target := load32(instr + 4) as uint32
        var target_lbl := load32(block_labels + (target as uint64) * 4) as uint32
        var imm_off := emit_jmp_rel32(scg.buf)
        labelmap_add_reloc(scg.labels, imm_off, target_lbl)
        return
    end

    if kind == INSTR_BRANCH then
        var cond_v      := load64(instr + 8)
        var true_block  := load32(instr + 16) as uint32
        var false_block := load32(instr + 20) as uint32
        cg_load_value(scg, cond_v, REG_RAX, sra)
        emit_test_rr(scg.buf, REG_RAX, REG_RAX)
        var true_lbl  := load32(block_labels + (true_block as uint64) * 4) as uint32
        var false_lbl := load32(block_labels + (false_block as uint64) * 4) as uint32
        var jne_imm := emit_jne_rel32(scg.buf)
        labelmap_add_reloc(scg.labels, jne_imm, true_lbl)
        var jmp_imm := emit_jmp_rel32(scg.buf)
        labelmap_add_reloc(scg.labels, jmp_imm, false_lbl)
        return
    end

    if kind == INSTR_ALLOCA then
        var dst_v := load32(instr + 4) as uint32
        var dst_r := ra_get(sra, dst_v)
        if ra_is_spill(sra, dst_v) then
            var off := ra_spill_off(sra, dst_v)
            emit_lea_rbp_disp8(scg.buf, dst_r, off)
        else
            emit_sub_ri8(scg.buf, REG_RSP, 8)
            emit_mov_rr(scg.buf, dst_r, REG_RSP)
        end
        return
    end

    if kind == INSTR_LOAD then
        var dst_v  := load32(instr + 4) as uint32
        var addr_v := load64(instr + 8)
        var dst_r  := ra_get(sra, dst_v)
        if val_kind(addr_v) == VAL_VREG then
            var base_r := ra_get(sra, val_vreg_id(addr_v))
            emit_mov_rm(scg.buf, dst_r, base_r)
        else
            cg_load_value(scg, addr_v, REG_R10, sra)
            emit_mov_rm(scg.buf, dst_r, REG_R10)
        end
        return
    end

    if kind == INSTR_STORE then
        var addr_v := load64(instr + 8)
        var src_v  := load64(instr + 16)
        cg_load_value(scg, src_v, REG_R10, sra)
        if val_kind(addr_v) == VAL_VREG then
            var base_r := ra_get(sra, val_vreg_id(addr_v))
            emit_mov_mr(scg.buf, base_r, REG_R10)
        end
        return
    end

    if kind == INSTR_INDEX_GET then
        var dst_v := load32(instr + 4) as uint32
        var arr_v := load64(instr + 16)
        var idx_v := load64(instr + 24)
        var dst_r := ra_get(sra, dst_v)
        cg_load_value(scg, arr_v, REG_R10, sra)
        cg_load_value(scg, idx_v, REG_R11, sra)
        emit_mov_rm_sib8(scg.buf, dst_r, REG_R10, REG_R11)
        return
    end

    if kind == INSTR_INDEX_SET then
        var arr_v := load64(instr + 16)
        var idx_v := load64(instr + 24)
        var src_v := load64(instr + 32)
        cg_load_value(scg, arr_v, REG_R10, sra)
        cg_load_value(scg, idx_v, REG_R11, sra)
        cg_load_value(scg, src_v, REG_R9, sra)
        emit_mov_mr_sib8(scg.buf, REG_R10, REG_R11, REG_R9)
        return
    end

    if kind == INSTR_FIELD_GET then
        var dst_v  := load32(instr + 4) as uint32
        var obj_v  := load64(instr + 16)
        var dst_r  := ra_get(sra, dst_v)
        cg_load_value(scg, obj_v, dst_r, sra)
        /* Simplified: load from offset 0 (field offset tracking not yet implemented) */
        emit_mov_rm(scg.buf, dst_r, dst_r)
        return
    end

    if kind == INSTR_CAST then
        var dst_v := load32(instr + 4) as uint32
        var src_v := load64(instr + 16)
        var dst_r := ra_get(sra, dst_v)
        cg_load_value(scg, src_v, dst_r, sra)
        /* Integer widening/truncation: just copy for now */
        return
    end

    if kind == INSTR_ADDR_OF then
        var dst_v  := load32(instr + 4) as uint32
        var src_vr := load32(instr + 8) as uint32
        var dst_r  := ra_get(sra, dst_v)
        if ra_is_spill(sra, src_vr) then
            emit_lea_rbp_disp8(scg.buf, dst_r, ra_spill_off(sra, src_vr))
        else
            emit_push_r(scg.buf, ra_get(sra, src_vr))
            emit_mov_rr(scg.buf, dst_r, REG_RSP)
        end
        return
    end
end

/* Load an IR Value into a physical register. */
procedure cg_load_value(cg: mut Codegen, val_ptr: uint64, dst: int32, ra: mut RegAlloc) begin
    var scg := cg
    var sdst := dst
    var sra  := ra
    var kind := val_kind(val_ptr)

    if kind == VAL_IMM_INT then
        var v := val_imm_int_val(val_ptr)
        if v == 0 then
            emit_xor_rr(scg.buf, sdst, sdst)
        else
            emit_mov_ri64(scg.buf, sdst, v)
        end
        return
    end

    if kind == VAL_IMM_BOOL then
        var b := load32(val_ptr + 4)
        emit_mov_ri32(scg.buf, sdst, b)
        return
    end

    if kind == VAL_IMM_NULL then
        emit_xor_rr(scg.buf, sdst, sdst)
        return
    end

    if kind == VAL_STRING_CONST then
        var idx := load32(val_ptr + 4) as uint32
        /* Rodata offset: for idx=0 it's 0; for idx>0 we'd need the string pool */
        /* Emit mov_ri with placeholder; linker will patch to rodata_vaddr + rodata_off */
        var imm_off := asmbuf_cur(scg.buf) + if sdst >= 8 then 2 else 1 end
        emit_mov_ri32(scg.buf, sdst, 0)
        string_refs_add(scg.string_refs, imm_off, idx)
        return
    end

    if kind == VAL_GLOBAL then
        /* Load address of global/extern function (load 0 as placeholder) */
        emit_mov_ri32(scg.buf, sdst, 0)
        return
    end

    if kind == VAL_VREG then
        /* Copy source vreg's physical register to dst */
        var vr := val_vreg_id(val_ptr)
        var src_r := ra_get(sra, vr)
        if src_r != sdst then
            emit_mov_rr(scg.buf, sdst, src_r)
        end
        return
    end
end

/* Compute strlen of a null-terminated pointer */
function cg_strlen(ptr: uint64): uint32 begin
    var i: uint32 := 0
    while load_byte(ptr + i as uint64) != 0 do
        i := i + 1
    end
    return i
end
/// Maia self-hosted compiler — ELF64 linker.
/// Produces a statically-linked ELF64 executable for Linux x86_64.
/// Layout: ELF header → program headers → .text → .rodata → .shstrtab → section headers.
/// The built-in runtime (writeln + _start + syscall stubs) is prepended to .text.

module Linker

use Assembler
use Codegen_X86_64

extern function maia_mmap(len: uint64): uint64
extern function maia_write(fd: int32, buf: uint64, count: uint64): int64
extern function maia_open(path: uint64): int32
extern function store32(addr: uint64, v: int32)
extern function store64(addr: uint64, v: uint64)
extern function load32(addr: uint64): int32
extern function load64(addr: uint64): uint64
extern function load_byte(addr: uint64): int32
extern function store_byte(addr: uint64, v: int32)

/* ── ELF constants ───────────────────────────────────────────────────────────── */

const ELF_MAGIC:    uint32 = 0x464C457F
const ELFCLASS64:   int32  = 2
const ELFDATA2LSB:  int32  = 1
const ET_EXEC:      int32  = 2
const EM_X86_64:    int32  = 62
const PT_LOAD:      uint32 = 1
const PF_X:         uint32 = 1
const PF_W:         uint32 = 2
const PF_R:         uint32 = 4
const SHT_NULL:     uint32 = 0
const SHT_PROGBITS: uint32 = 1
const SHT_STRTAB:   uint32 = 3
const SHF_ALLOC:    uint64 = 2
const SHF_EXECINSTR:uint64 = 4
const LOAD_ADDR:    uint64 = 0x400000
const PAGE_SIZE:    uint64 = 0x1000

/* ── Output buffer helpers ───────────────────────────────────────────────────── */

type OutBuf = struct {
    ptr: uint64,
    pos: uint64,
    cap: uint64,
}

function outbuf_new(cap: uint64): OutBuf begin
    return OutBuf { .ptr = maia_mmap(cap), .pos = 0, .cap = cap }
end

procedure outbuf_write_u8(buf: mut OutBuf, v: int32) begin
    store_byte(buf.ptr + buf.pos, v)
    buf.pos := buf.pos + 1
end

procedure outbuf_write_u16le(buf: mut OutBuf, v: int32) begin
    outbuf_write_u8(buf, v and 0xff)
    outbuf_write_u8(buf, (v >> 8) and 0xff)
end

procedure outbuf_write_u32le(buf: mut OutBuf, v: uint32) begin
    outbuf_write_u8(buf, (v and 0xff) as int32)
    outbuf_write_u8(buf, ((v >> 8)  and 0xff) as int32)
    outbuf_write_u8(buf, ((v >> 16) and 0xff) as int32)
    outbuf_write_u8(buf, ((v >> 24) and 0xff) as int32)
end

procedure outbuf_write_u64le(buf: mut OutBuf, v: uint64) begin
    outbuf_write_u32le(buf, (v and 0xffffffff) as uint32)
    outbuf_write_u32le(buf, ((v >> 32) and 0xffffffff) as uint32)
end

procedure outbuf_write_bytes(buf: mut OutBuf, src: uint64, len: uint64) begin
    var i: uint64 := 0
    while i < len do
        outbuf_write_u8(buf, load_byte(src + i))
        i := i + 1
    end
end

procedure outbuf_zero(buf: mut OutBuf, count: uint64) begin
    var i: uint64 := 0
    while i < count do
        outbuf_write_u8(buf, 0)
        i := i + 1
    end
end

procedure outbuf_patch_u32le(buf: ref OutBuf, off: uint64, v: uint32) begin
    store_byte(buf.ptr + off,     (v and 0xff) as int32)
    store_byte(buf.ptr + off + 1, ((v >> 8)  and 0xff) as int32)
    store_byte(buf.ptr + off + 2, ((v >> 16) and 0xff) as int32)
    store_byte(buf.ptr + off + 3, ((v >> 24) and 0xff) as int32)
end

/* ── Runtime stubs (same machine code as bootstrap/src/linker.zig) ───────────── */
/* The runtime is the same code emitted by the bootstrap linker: */
/*   [0]   writeln stub (81 bytes) */
/*   [81]  _start stub  (~22 bytes) */
/*   [103] maia_mmap, maia_open, maia_read, maia_write, maia_close, maia_exit, maia_fsize */
/* Total runtime: ~284 bytes. */

const RUNTIME_WRITELN_OFF: uint32 = 0
const RUNTIME_START_OFF:   uint32 = 81
const RUNTIME_MMAP_OFF:    uint32 = 103
const RUNTIME_OPEN_OFF:    uint32 = 148
const RUNTIME_READ_OFF:    uint32 = 169
const RUNTIME_WRITE_OFF:   uint32 = 180
const RUNTIME_CLOSE_OFF:   uint32 = 195
const RUNTIME_EXIT_OFF:    uint32 = 210
const RUNTIME_FSIZE_OFF:   uint32 = 221

function runtime_stub_offset(name_ptr: uint64, name_len: uint32): uint32 begin
    /* Compare name against known stub names */
    if name_len == 7 and bytes_eq_7(name_ptr, 119, 114, 105, 116, 101, 108, 110) then
        return RUNTIME_WRITELN_OFF  /* "writeln" */
    end
    if name_len == 5 and bytes_eq_5(name_ptr, 119, 114, 105, 116, 101) then
        return RUNTIME_WRITELN_OFF  /* "write" */
    end
    if name_len == 9 and bytes_match(name_ptr, "maia_mmap", 9) then
        return RUNTIME_MMAP_OFF
    end
    if name_len == 9 and bytes_match(name_ptr, "maia_open", 9) then
        return RUNTIME_OPEN_OFF
    end
    if name_len == 9 and bytes_match(name_ptr, "maia_read", 9) then
        return RUNTIME_READ_OFF
    end
    if name_len == 10 and bytes_match(name_ptr, "maia_write", 10) then
        return RUNTIME_WRITE_OFF
    end
    if name_len == 10 and bytes_match(name_ptr, "maia_close", 10) then
        return RUNTIME_CLOSE_OFF
    end
    if name_len == 9 and bytes_match(name_ptr, "maia_exit", 9) then
        return RUNTIME_EXIT_OFF
    end
    if name_len == 10 and bytes_match(name_ptr, "maia_fsize", 10) then
        return RUNTIME_FSIZE_OFF
    end
    if name_len == 10 and bytes_match(name_ptr, "load_byte\x00", 9) then
        return RUNTIME_READ_OFF  /* approximate — full implementation maps it to a helper */
    end
    return RUNTIME_WRITELN_OFF  /* fallback */
end

function bytes_eq_7(p: uint64, b0: int32, b1: int32, b2: int32, b3: int32, b4: int32, b5: int32, b6: int32): bool begin
    return load_byte(p) == b0 and load_byte(p+1) == b1 and load_byte(p+2) == b2 and
           load_byte(p+3) == b3 and load_byte(p+4) == b4 and load_byte(p+5) == b5 and
           load_byte(p+6) == b6
end

function bytes_eq_5(p: uint64, b0: int32, b1: int32, b2: int32, b3: int32, b4: int32): bool begin
    return load_byte(p) == b0 and load_byte(p+1) == b1 and load_byte(p+2) == b2 and
           load_byte(p+3) == b3 and load_byte(p+4) == b4
end

function bytes_match(p: uint64, s: string, len: uint32): bool begin
    var sp := s as uint64
    var i: uint32 := 0
    while i < len do
        if load_byte(p + i as uint64) != load_byte(sp + i as uint64) then
            return false
        end
        i := i + 1
    end
    return true
end

/* ── Build the runtime blob (same bytes as the bootstrap runtime) ────────────── */
/* In the self-hosted compiler the runtime bytes are embedded as a constant array. */
/* For Phase 1 we reconstruct them procedurally so we don't need compile-time */
/* literal byte arrays. */

function build_runtime(buf: mut AsmBuf, main_off: uint32) begin
    /* _writeln stub (81 bytes) */
    /* push rbp */
    asmbuf_emit(buf, 0x55)
    asmbuf_emit2(buf, 0x48, 0x89); asmbuf_emit(buf, 0xE5)  /* mov rbp, rsp */
    asmbuf_emit2(buf, 0x48, 0x31); asmbuf_emit(buf, 0xC0)  /* xor rax, rax (length=0) */
    /* strlen loop [7] */
    asmbuf_emit2(buf, 0x80, 0x3C); asmbuf_emit2(buf, 0x07, 0x00)  /* cmp byte [rdi+rax], 0 */
    asmbuf_emit2(buf, 0x74, 0x05)  /* je +5 */
    asmbuf_emit2(buf, 0x48, 0xFF); asmbuf_emit(buf, 0xC0)  /* inc rax */
    asmbuf_emit2(buf, 0xEB, 0xF5)  /* jmp -11 */
    /* strlen done [18] */
    asmbuf_emit2(buf, 0x48, 0x89); asmbuf_emit(buf, 0xC2)  /* mov rdx, rax */
    asmbuf_emit2(buf, 0x48, 0x89); asmbuf_emit(buf, 0xFE)  /* mov rsi, rdi */
    asmbuf_emit2(buf, 0x48, 0xC7); asmbuf_emit2(buf, 0xC7, 0x01); asmbuf_emit2(buf, 0x00, 0x00); asmbuf_emit(buf, 0x00)  /* mov rdi, 1 */
    asmbuf_emit2(buf, 0x48, 0xC7); asmbuf_emit2(buf, 0xC0, 0x01); asmbuf_emit2(buf, 0x00, 0x00); asmbuf_emit(buf, 0x00)  /* mov rax, 1 */
    asmbuf_emit2(buf, 0x0F, 0x05)  /* syscall */
    /* Write newline */
    asmbuf_emit2(buf, 0x48, 0x83); asmbuf_emit2(buf, 0xEC, 0x08)  /* sub rsp, 8 */
    asmbuf_emit2(buf, 0xC6, 0x04); asmbuf_emit2(buf, 0x24, 0x0A)  /* mov byte [rsp], '\n' */
    asmbuf_emit2(buf, 0x48, 0xC7); asmbuf_emit2(buf, 0xC0, 0x01); asmbuf_emit2(buf, 0x00, 0x00); asmbuf_emit(buf, 0x00)  /* mov rax, 1 */
    asmbuf_emit2(buf, 0x48, 0xC7); asmbuf_emit2(buf, 0xC7, 0x01); asmbuf_emit2(buf, 0x00, 0x00); asmbuf_emit(buf, 0x00)  /* mov rdi, 1 */
    asmbuf_emit2(buf, 0x48, 0x8D); asmbuf_emit2(buf, 0x34, 0x24)  /* lea rsi, [rsp] */
    asmbuf_emit2(buf, 0x48, 0xC7); asmbuf_emit2(buf, 0xC2, 0x01); asmbuf_emit2(buf, 0x00, 0x00); asmbuf_emit(buf, 0x00)  /* mov rdx, 1 */
    asmbuf_emit2(buf, 0x0F, 0x05)  /* syscall */
    asmbuf_emit2(buf, 0x48, 0x83); asmbuf_emit2(buf, 0xC4, 0x08)  /* add rsp, 8 */
    asmbuf_emit(buf, 0x5D)  /* pop rbp */
    asmbuf_emit(buf, 0xC3)  /* ret */

    /* _start [81] */
    asmbuf_emit2(buf, 0x48, 0x31); asmbuf_emit(buf, 0xED)  /* xor rbp, rbp */
    /* call main (rel32 placeholder) */
    asmbuf_emit(buf, 0xE8)
    var call_site := asmbuf_cur(buf)
    /* Compute displacement: main is at runtime_size + main_off in text */
    /* Runtime size = 284, so displacement = 284 + main_off - (call_site + 4) */
    var rt_size: uint32 := 284
    var main_abs := rt_size + main_off
    var call_end := call_site + 4
    var disp := (main_abs as int32) - (call_end as int32)
    asmbuf_emit_i32(buf, disp)
    /* exit(rax) */
    asmbuf_emit2(buf, 0x48, 0x89); asmbuf_emit(buf, 0xC7)  /* mov rdi, rax */
    asmbuf_emit2(buf, 0x48, 0xC7); asmbuf_emit2(buf, 0xC0, 0x3C); asmbuf_emit2(buf, 0x00, 0x00); asmbuf_emit(buf, 0x00)  /* mov rax, 60 */
    asmbuf_emit2(buf, 0x0F, 0x05)  /* syscall */
    asmbuf_emit2(buf, 0x0F, 0x0B)  /* ud2 */

    /* maia_mmap [103] */
    asmbuf_emit(buf, 0x55); asmbuf_emit2(buf, 0x48, 0x89); asmbuf_emit(buf, 0xE5)
    asmbuf_emit2(buf, 0x48, 0x89); asmbuf_emit(buf, 0xFE)  /* mov rsi, rdi */
    asmbuf_emit2(buf, 0x48, 0x31); asmbuf_emit(buf, 0xFF)  /* xor rdi, rdi */
    asmbuf_emit2(buf, 0x48, 0xC7); asmbuf_emit2(buf, 0xC2, 0x03); asmbuf_emit2(buf, 0x00, 0x00); asmbuf_emit(buf, 0x00)
    asmbuf_emit2(buf, 0x49, 0xC7); asmbuf_emit2(buf, 0xC2, 0x22); asmbuf_emit2(buf, 0x00, 0x00); asmbuf_emit(buf, 0x00)
    asmbuf_emit2(buf, 0x49, 0xC7); asmbuf_emit2(buf, 0xC0, 0xFF); asmbuf_emit2(buf, 0xFF, 0xFF); asmbuf_emit(buf, 0xFF)
    asmbuf_emit2(buf, 0x4D, 0x31); asmbuf_emit(buf, 0xC9)
    asmbuf_emit2(buf, 0x48, 0xC7); asmbuf_emit2(buf, 0xC0, 0x09); asmbuf_emit2(buf, 0x00, 0x00); asmbuf_emit(buf, 0x00)
    asmbuf_emit2(buf, 0x0F, 0x05); asmbuf_emit(buf, 0x5D); asmbuf_emit(buf, 0xC3)

    /* maia_open [148] */
    asmbuf_emit(buf, 0x55); asmbuf_emit2(buf, 0x48, 0x89); asmbuf_emit(buf, 0xE5)
    asmbuf_emit2(buf, 0x48, 0x31); asmbuf_emit(buf, 0xF6)
    asmbuf_emit2(buf, 0x48, 0x31); asmbuf_emit(buf, 0xD2)
    asmbuf_emit2(buf, 0x48, 0xC7); asmbuf_emit2(buf, 0xC0, 0x02); asmbuf_emit2(buf, 0x00, 0x00); asmbuf_emit(buf, 0x00)
    asmbuf_emit2(buf, 0x0F, 0x05); asmbuf_emit(buf, 0x5D); asmbuf_emit(buf, 0xC3)

    /* maia_read [169] */
    asmbuf_emit(buf, 0x55); asmbuf_emit2(buf, 0x48, 0x89); asmbuf_emit(buf, 0xE5)
    asmbuf_emit2(buf, 0x48, 0x31); asmbuf_emit(buf, 0xC0)
    asmbuf_emit2(buf, 0x0F, 0x05); asmbuf_emit(buf, 0x5D); asmbuf_emit(buf, 0xC3)

    /* maia_write [180] */
    asmbuf_emit(buf, 0x55); asmbuf_emit2(buf, 0x48, 0x89); asmbuf_emit(buf, 0xE5)
    asmbuf_emit2(buf, 0x48, 0xC7); asmbuf_emit2(buf, 0xC0, 0x01); asmbuf_emit2(buf, 0x00, 0x00); asmbuf_emit(buf, 0x00)
    asmbuf_emit2(buf, 0x0F, 0x05); asmbuf_emit(buf, 0x5D); asmbuf_emit(buf, 0xC3)

    /* maia_close [195] */
    asmbuf_emit(buf, 0x55); asmbuf_emit2(buf, 0x48, 0x89); asmbuf_emit(buf, 0xE5)
    asmbuf_emit2(buf, 0x48, 0xC7); asmbuf_emit2(buf, 0xC0, 0x03); asmbuf_emit2(buf, 0x00, 0x00); asmbuf_emit(buf, 0x00)
    asmbuf_emit2(buf, 0x0F, 0x05); asmbuf_emit(buf, 0x5D); asmbuf_emit(buf, 0xC3)

    /* maia_exit [210] */
    asmbuf_emit2(buf, 0x48, 0xC7); asmbuf_emit2(buf, 0xC0, 0x3C); asmbuf_emit2(buf, 0x00, 0x00); asmbuf_emit(buf, 0x00)
    asmbuf_emit2(buf, 0x0F, 0x05); asmbuf_emit2(buf, 0x0F, 0x0B)

    /* maia_fsize [221] */
    asmbuf_emit(buf, 0x55); asmbuf_emit2(buf, 0x48, 0x89); asmbuf_emit(buf, 0xE5)
    asmbuf_emit2(buf, 0x48, 0x83); asmbuf_emit2(buf, 0xEC, 0x10)
    asmbuf_emit2(buf, 0x48, 0x89); asmbuf_emit2(buf, 0x7D, 0xF8)
    asmbuf_emit2(buf, 0x48, 0x31); asmbuf_emit(buf, 0xF6)
    asmbuf_emit2(buf, 0x48, 0xC7); asmbuf_emit2(buf, 0xC2, 0x02); asmbuf_emit2(buf, 0x00, 0x00); asmbuf_emit(buf, 0x00)
    asmbuf_emit2(buf, 0x48, 0xC7); asmbuf_emit2(buf, 0xC0, 0x08); asmbuf_emit2(buf, 0x00, 0x00); asmbuf_emit(buf, 0x00)
    asmbuf_emit2(buf, 0x0F, 0x05)
    asmbuf_emit2(buf, 0x48, 0x89); asmbuf_emit2(buf, 0x45, 0xF0)
    asmbuf_emit2(buf, 0x48, 0x8B); asmbuf_emit2(buf, 0x7D, 0xF8)
    asmbuf_emit2(buf, 0x48, 0x31); asmbuf_emit(buf, 0xF6)
    asmbuf_emit2(buf, 0x48, 0x31); asmbuf_emit(buf, 0xD2)
    asmbuf_emit2(buf, 0x48, 0xC7); asmbuf_emit2(buf, 0xC0, 0x08); asmbuf_emit2(buf, 0x00, 0x00); asmbuf_emit(buf, 0x00)
    asmbuf_emit2(buf, 0x0F, 0x05)
    asmbuf_emit2(buf, 0x48, 0x8B); asmbuf_emit2(buf, 0x45, 0xF0)
    asmbuf_emit2(buf, 0x48, 0x89); asmbuf_emit(buf, 0xEC)
    asmbuf_emit(buf, 0x5D); asmbuf_emit(buf, 0xC3)
    /* [284] — end of runtime stubs */
end

/* ── ELF builder ─────────────────────────────────────────────────────────────── */

type LinkerInput = struct {
    text_ptr:     uint64,
    text_len:     uint32,
    rodata_ptr:   uint64,
    rodata_len:   uint32,
    /* Symbol table for locating entry point */
    syms_ptr:     uint64,
    sym_count:    uint32,
    extern_sites: ExternSites,
    string_refs:  StringRefs,
    entry_name:   uint64,  /* ptr to entry function name (null-terminated) */
    entry_len:    uint32,
}

/* Find the offset of the named function in the user text section. */
function find_symbol_off(input: ref LinkerInput, name_ptr: uint64, name_len: uint32): uint32 begin
    var i: uint32 := 0
    while i < input.sym_count do
        var slot := input.syms_ptr + (i as uint64) * 16
        var np   := load64(slot)
        var nl   := load32(slot + 8) as uint32
        if nl == name_len and strings_equal(np, name_ptr, name_len) then
            return load32(slot + 12) as uint32
        end
        i := i + 1
    end
    return 0
end

procedure linker_link(input: ref LinkerInput, out_path: uint64) begin
    const RT_SIZE: uint32 = 284  /* runtime stub bytes */

    /* Save all input fields BEFORE any function calls clobber rdi (input ptr).
       The bootstrap's register allocator keeps parameters in ABI regs (rdi, rsi, etc.)
       which get clobbered by function calls. Local variables go into callee-saved regs. */
    var in_text_ptr   := input.text_ptr
    var in_text_len   := input.text_len
    var in_rodata_ptr := input.rodata_ptr
    var in_rodata_len := input.rodata_len
    var in_es         := input.extern_sites   /* ExternSites buffer ptr */
    var in_es_count   := input.extern_sites.count
    var in_es_ptr     := input.extern_sites.ptr
    var in_sr         := input.string_refs    /* StringRefs buffer ptr */
    var in_sr_count   := input.string_refs.count
    var in_sr_ptr     := input.string_refs.ptr
    var in_entry_name := input.entry_name
    var in_entry_len  := input.entry_len

    /* Locate "main" symbol to patch the _start call displacement */
    var main_off := find_symbol_off(input, in_entry_name, in_entry_len)

    /* Build runtime (with correct main displacement) */
    var rt_buf := asmbuf_new()
    build_runtime(rt_buf, main_off)
    var rt_size := rt_buf.len

    /* Total text size = runtime + user text */
    var text_size := rt_size + in_text_len
    var rodata_size := in_rodata_len

    /* File layout: */
    /*   [0x00]     ELF header (64 bytes) */
    /*   [0x40]     2 × program headers (56 bytes each = 112) */
    /*   [0xB0]     .text */
    /*   [0xB0+text].rodata */
    /*   [...]      .shstrtab */
    /*   [...]      section headers (4 × 64 = 256) */

    const EH_SIZE:   uint64 = 64
    const PHDR_SIZE: uint64 = 112  /* 2 × 56 */
    const HDRS_SIZE: uint64 = 176  /* EH + PHDR */

    var text_vaddr   := LOAD_ADDR + HDRS_SIZE
    var rodata_vaddr := text_vaddr + text_size as uint64
    var entry_vaddr  := text_vaddr + RUNTIME_START_OFF as uint64

    var shstrtab := "\x00.text\x00.rodata\x00.shstrtab\x00"
    const SHSTRTAB_LEN: uint64 = 25
    var shstrtab_off := HDRS_SIZE + text_size as uint64 + rodata_size as uint64
    var shdr_off     := shstrtab_off + SHSTRTAB_LEN

    const SHDR_COUNT: uint64 = 4
    const SHDR_SIZE:  uint64 = 64
    var total_size   := shdr_off + SHDR_COUNT * SHDR_SIZE

    var out := outbuf_new(total_size + 4096)

    /* ── ELF header ──────────────────────────────────────────────────────────── */
    outbuf_write_u32le(out, ELF_MAGIC)
    outbuf_write_u8(out, ELFCLASS64)
    outbuf_write_u8(out, ELFDATA2LSB)
    outbuf_write_u8(out, 1)  /* EI_VERSION */
    outbuf_write_u8(out, 0)  /* EI_OSABI */
    outbuf_zero(out, 8)  /* padding */
    outbuf_write_u16le(out, ET_EXEC)
    outbuf_write_u16le(out, EM_X86_64)
    outbuf_write_u32le(out, 1)  /* e_version */
    outbuf_write_u64le(out, entry_vaddr)
    outbuf_write_u64le(out, EH_SIZE)  /* e_phoff */
    outbuf_write_u64le(out, shdr_off)  /* e_shoff */
    outbuf_write_u32le(out, 0)  /* e_flags */
    outbuf_write_u16le(out, 64)  /* e_ehsize */
    outbuf_write_u16le(out, 56)  /* e_phentsize */
    outbuf_write_u16le(out, 2)  /* e_phnum */
    outbuf_write_u16le(out, 64)  /* e_shentsize */
    outbuf_write_u16le(out, SHDR_COUNT as int32)
    outbuf_write_u16le(out, 3)  /* e_shstrndx */

    /* ── Program header 0: text+rodata (R+X) ────────────────────────────────── */
    var seg0_size := HDRS_SIZE + text_size as uint64 + rodata_size as uint64
    outbuf_write_u32le(out, PT_LOAD)
    outbuf_write_u32le(out, PF_R or PF_X)
    outbuf_write_u64le(out, 0)  /* p_offset */
    outbuf_write_u64le(out, LOAD_ADDR)  /* p_vaddr */
    outbuf_write_u64le(out, LOAD_ADDR)  /* p_paddr */
    outbuf_write_u64le(out, seg0_size)  /* p_filesz */
    outbuf_write_u64le(out, seg0_size)  /* p_memsz */
    outbuf_write_u64le(out, PAGE_SIZE)  /* p_align */

    /* ── Program header 1: data/bss placeholder (empty) ─────────────────────── */
    outbuf_write_u32le(out, PT_LOAD)
    outbuf_write_u32le(out, PF_R or PF_W)
    outbuf_write_u64le(out, 0)
    outbuf_write_u64le(out, LOAD_ADDR + seg0_size)
    outbuf_write_u64le(out, LOAD_ADDR + seg0_size)
    outbuf_write_u64le(out, 0)
    outbuf_write_u64le(out, 0)
    outbuf_write_u64le(out, PAGE_SIZE)

    /* ── .text: runtime + patched user code ─────────────────────────────────── */
    /* Emit runtime stubs */
    outbuf_write_bytes(out, rt_buf.ptr, rt_buf.len as uint64)

    /* Patch string refs in user text */
    var patched_text := maia_mmap(in_text_len as uint64)
    var i: uint32 := 0
    while i < in_text_len do
        store_byte(patched_text + i as uint64, load_byte(in_text_ptr + i as uint64))
        i := i + 1
    end
    /* Patch string pointer loads */
    i := 0
    while i < in_sr_count do
        var slot     := in_sr_ptr + (i as uint64) * STR_REF_BYTES as uint64
        var imm_off  := load32(slot)     as uint32
        var str_idx  := load32(slot + 4) as uint32
        var r_off    := rodata_offset_for_string(input, str_idx)
        var vaddr    := (rodata_vaddr + r_off as uint64) as uint32
        outbuf_patch_u32le(out, HDRS_SIZE + rt_size as uint64 + imm_off as uint64, vaddr)
        i := i + 1
    end
    /* Patch extern call sites */
    i := 0
    while i < in_es_count do
        var slot      := in_es_ptr + (i as uint64) * 24
        var imm_off   := load32(slot)     as uint32
        var name_len2 := load32(slot + 4) as uint32
        var name_ptr2 := load64(slot + 8)
        var stub_off  := runtime_stub_offset(name_ptr2, name_len2)
        var fn_vaddr  := (text_vaddr + stub_off as uint64) as uint32
        outbuf_patch_u32le(out, HDRS_SIZE + rt_size as uint64 + imm_off as uint64, fn_vaddr)
        i := i + 1
    end
    /* Emit (patched) user text */
    outbuf_write_bytes(out, patched_text, in_text_len as uint64)

    /* ── .rodata ─────────────────────────────────────────────────────────────── */
    if rodata_size > 0 then
        outbuf_write_bytes(out, in_rodata_ptr, rodata_size as uint64)
    end

    /* ── .shstrtab ───────────────────────────────────────────────────────────── */
    outbuf_write_bytes(out, shstrtab as uint64, SHSTRTAB_LEN)

    /* ── Section headers ─────────────────────────────────────────────────────── */
    /* SHT_NULL */
    outbuf_zero(out, SHDR_SIZE)

    /* .text */
    outbuf_write_u32le(out, 1)  /* sh_name offset in shstrtab */
    outbuf_write_u32le(out, SHT_PROGBITS)
    outbuf_write_u64le(out, SHF_ALLOC or SHF_EXECINSTR)
    outbuf_write_u64le(out, text_vaddr)
    outbuf_write_u64le(out, HDRS_SIZE)
    outbuf_write_u64le(out, text_size as uint64)
    outbuf_write_u32le(out, 0); outbuf_write_u32le(out, 0)
    outbuf_write_u64le(out, 16)
    outbuf_write_u64le(out, 0)

    /* .rodata */
    outbuf_write_u32le(out, 7)  /* sh_name = ".rodata" at offset 7 */
    outbuf_write_u32le(out, SHT_PROGBITS)
    outbuf_write_u64le(out, SHF_ALLOC)
    outbuf_write_u64le(out, rodata_vaddr)
    outbuf_write_u64le(out, HDRS_SIZE + text_size as uint64)
    outbuf_write_u64le(out, rodata_size as uint64)
    outbuf_write_u32le(out, 0); outbuf_write_u32le(out, 0)
    outbuf_write_u64le(out, 1)
    outbuf_write_u64le(out, 0)

    /* .shstrtab */
    outbuf_write_u32le(out, 15)  /* sh_name = ".shstrtab" at offset 15 */
    outbuf_write_u32le(out, SHT_STRTAB)
    outbuf_write_u64le(out, 0)
    outbuf_write_u64le(out, 0)
    outbuf_write_u64le(out, shstrtab_off)
    outbuf_write_u64le(out, SHSTRTAB_LEN)
    outbuf_write_u32le(out, 0); outbuf_write_u32le(out, 0)
    outbuf_write_u64le(out, 1)
    outbuf_write_u64le(out, 0)

    /* Write to file */
    /* We need to open the file for writing — use a simple open-create wrapper. */
    /* In the self-hosted runtime, maia_write(fd=stdout=-1) writes to a file */
    /* via our extended syscall set. We use maia_create + maia_write here. */
    elf_write_to_path(out, out_path)
end

/* Compute byte offset of string[idx] in the rodata section. */
function rodata_offset_for_string(input: ref LinkerInput, idx: uint32): uint32 begin
    /* We stored (str_ptr, str_len) in IrModule.string_pool. */
    /* The rodata was built by emitting each string + null terminator in order. */
    /* We need the string lengths — stored in string_refs as (imm_off, str_idx). */
    /* Actually the rodata was built from the module's string_pool; we need to */
    /* reproduce the same ordering. We have access to input.strings_ptr. */
    var off: uint32 := 0
    var i: uint32 := 0
    while i < idx do
        var slot := input.extern_sites.ptr  /* reuse: we need string_pool; not ideal */
    slot
        /* Without the string_pool pointer being separately passed, approximate: */
        off := off + 16  /* rough estimate — proper impl needs the pool */
        i := i + 1
    end
    return off
end

/* Write the ELF binary to the output path using maia_write via fd. */
/* The self-hosted runtime provides creat() via maia_open with O_CREAT|O_WRONLY|O_TRUNC. */
/* For now use maia_write to stdout and let the shell redirect, or extend */
/* maia_open to support write mode. */
procedure elf_write_to_path(out: ref OutBuf, path: uint64) begin
    /* Simplified: open file for writing (O_WRONLY|O_CREAT|O_TRUNC = 0x241, mode=0755) */
    /* We need maia_create — add as an extern. */
    var fd := maia_create(path, 0x1ED)  /* 0x1ED = 0755 */
    if fd >= 0 then
    maia_write(fd, out.ptr, out.pos)
    maia_chmod(fd, 0x1ED)
        maia_close_fd(fd)
    end
end

extern function maia_create(path: uint64, mode: int32): int32
extern function maia_chmod(fd: int32, mode: int32): int32
extern function maia_close_fd(fd: int32)
/// Maia self-hosted compiler — main entry point.
/// Usage: maia [--target TARGET] [--output OUTPUT] [--emit-ir] <source.maia>
///   --target  linux-x86_64 | wasm32   (default: linux-x86_64)
///   --output  <path>
///   --emit-ir dump IR summary to stderr

module Main

use Lexer
use AST
use Parser
use Sema
use IR
use Assembler
use Codegen_X86_64
use Linker

extern function maia_mmap(len: uint64): uint64
extern function maia_open(path: uint64): int32
extern function maia_read(fd: int32, buf: uint64, count: uint64): int64
extern function maia_close(fd: int32)
extern function maia_fsize(fd: int32): uint64
extern function maia_exit(code: int32)
extern function maia_write(fd: int32, buf: uint64, count: uint64): int64
extern function load_byte(addr: uint64): int32
extern function store_byte(addr: uint64, v: int32)
extern function store32(addr: uint64, v: int32)
extern function store64(addr: uint64, v: uint64)
extern function load32(addr: uint64): int32
extern function load64(addr: uint64): uint64

/* ── Argument parsing ────────────────────────────────────────────────────────── */
/* argv is passed as (argc: int32, argv_ptr: uint64) to main(). */
/* Each argv[i] is a null-terminated pointer. */

function arg_len(p: uint64): uint32 begin
    var i: uint32 := 0
    while load_byte(p + i as uint64) != 0 do i := i + 1 end
    return i
end

function arg_eq(p: uint64, s: string): bool begin
    var sp := s as uint64
    var i: uint32 := 0
    loop
        var a := load_byte(p + i as uint64)
        var b := load_byte(sp + i as uint64)
        if a != b then return false end
        if a == 0 then return true end
        i := i + 1
    end
    return true
end

/* ── Fatal error ─────────────────────────────────────────────────────────────── */

procedure die(msg: string) begin
    var mp := msg as uint64
    var mlen: uint32 := 0
    while load_byte(mp + mlen as uint64) != 0 do mlen := mlen + 1 end
    maia_write(2, mp, mlen as uint64)
    maia_write(2, "\n" as uint64, 1)
    maia_exit(1)
end

/* ── Print helpers ───────────────────────────────────────────────────────────── */

procedure print_str(fd: int32, s: string) begin
    var p := s as uint64
    var n: uint32 := 0
    while load_byte(p + n as uint64) != 0 do n := n + 1 end
    maia_write(fd, p, n as uint64)
end

procedure print_u32(fd: int32, v: uint32) begin
    if v == 0 then
    maia_write(fd, "0" as uint64, 1)
        return
    end
    var digits := maia_mmap(32)
    var count: uint32 := 0
    var x := v
    while x > 0 do
        store_byte(digits + count as uint64, (48 + (x % 10) as int32) as int32)
        count := count + 1
        x := x / 10
    end
    /* Reverse and print */
    var rev := maia_mmap(32)
    var i: uint32 := 0
    while i < count do
        store_byte(rev + i as uint64, load_byte(digits + (count - 1 - i) as uint64))
        i := i + 1
    end
    maia_write(fd, rev, count as uint64)
end

/* ── Read a source file entirely into a mmap'd buffer ───────────────────────── */

function read_source_file(path: uint64): uint64 begin
    var fd := maia_open(path)
    if fd < 0 then die("cannot open source file") end
    var size := maia_fsize(fd)
    var buf  := maia_mmap(size + 1)  /* +1 for safety */
    var n    := maia_read(fd, buf, size)
    if n < 0 then die("error reading source file") end
    maia_close(fd)
    return buf
end

function source_len(path: uint64): uint32 begin
    var fd := maia_open(path)
    if fd < 0 then return 0 end
    var size := maia_fsize(fd)
    maia_close(fd)
    return size as uint32
end

/* ── Stem extraction (last path component, strip .maia) ──────────────────────── */

function derive_output_path(src_path: uint64): uint64 begin
    /* Find last '/' or start */
    var i: uint32 := 0
    var last_slash: uint32 := 0
    while load_byte(src_path + i as uint64) != 0 do
        if load_byte(src_path + i as uint64) == 47 then last_slash := i + 1 end
        i := i + 1
    end
    var len := i - last_slash
    var out := maia_mmap(len as uint64 + 4)
    var j: uint32 := 0
    while j < len do
        var c := load_byte(src_path + last_slash as uint64 + j as uint64)
        /* Stop at '.' */
        if c == 46 then break end
        store_byte(out + j as uint64, c)
        j := j + 1
    end
    store_byte(out + j as uint64, 0)
    return out
end

/* ── Main entry point ────────────────────────────────────────────────────────── */

/* ── Main entry point ────────────────────────────────────────────────────────── */

procedure main(argc: int32, argv: uint64) begin
    /* Simple arg parsing with minimal control flow */
    var source_path: uint64 := 0
    var output_path: uint64 := 0
    var emit_ir: bool := false

    /* Arg scan: same pattern as test_exact_main.maia (confirmed working) */
    var i: int32 := 1
    while i < argc do
        var arg := load64(argv + (i as uint64) * 8)
        var is_o_flag := arg_eq(arg, "-o") or arg_eq(arg, "--output")
        var is_emit_flag := arg_eq(arg, "--emit-ir")
        if is_o_flag then
            i := i + 1
            if i < argc then
                output_path := load64(argv + (i as uint64) * 8)
            end
        end
        if is_emit_flag then
            emit_ir := true
        end
        if not is_o_flag then
            if not is_emit_flag then
                source_path := arg
            end
        end
        i := i + 1
    end

    if source_path == 0 then
        print_str(1, "usage: maia [--target TARGET] [--output OUTPUT] [--emit-ir] <source.maia>\n")
        maia_exit(1)
    end

    /* Derive output path if not given */
    if output_path == 0 then
        output_path := derive_output_path(source_path)
    end

    /* ── Read source ─────────────────────────────────────────────────────────── */
    var src_len_v := source_len(source_path)
    var src_buf   := read_source_file(source_path)

    /* ── Lex ─────────────────────────────────────────────────────────────────── */
    var lex := lexer_new(src_buf, src_len_v)
    var tok_arr := lexer_tokenize(lex)

    print_str(1, "lexed ")
    print_u32(1, tok_arr.len)
    print_str(1, " tokens\n")

    if tok_arr.len == 0 then die("no tokens") end

    /* ── Parse ───────────────────────────────────────────────────────────────── */
    var parser_ := parser_new(tok_arr.ptr, tok_arr.len, src_buf, src_len_v)
    var mod := parse_module(parser_)

    print_str(1, "parsed ")
    print_u32(1, mod.decl_count)
    print_str(1, " declarations\n")

    if parser_.diag_count > 0 then
        print_str(2, "parse errors: ")
        print_u32(2, parser_.diag_count as uint32)
        print_str(2, "\n")
        maia_exit(1)
    end

    /* ── Semantic analysis ───────────────────────────────────────────────────── */
    var sema_ := sema_new(src_buf, src_len_v)
    sema_analyze_module(sema_, mod)

    if sema_has_errors(sema_) then
        print_str(2, "semantic errors\n")
        maia_exit(1)
    end

    /* ── IR generation ───────────────────────────────────────────────────────── */
    var ir_mod := irmod_new()
    /* ir_mod_buf layout (must match offsets used by ir.maia and codegen/x86_64.maia):
       @0:  fn_arr (uint64)
       @8:  fn_count (uint32)
       @24: string_pool ptr (uint64)
       @32: str_count (uint32)
       The self-hosted IR builder and codegen read/write these specific offsets. */
    var ir_mod_buf := maia_mmap(128)
    store64(ir_mod_buf,      ir_mod.functions)
    store32(ir_mod_buf + 8,  ir_mod.fn_count as int32)
    store64(ir_mod_buf + 24, ir_mod.string_pool)
    store32(ir_mod_buf + 32, ir_mod.str_count as int32)

    var sema_buf := maia_mmap(128)  /* pack Sema fields for passing by pointer */
    store64(sema_buf + 40, src_buf)  /* sema.src at offset 40 (see sema.maia) */

    var builder := builder_new(ir_mod_buf, sema_buf, src_buf, src_len_v)
    builder_lower_module(builder, mod)

    var fn_count := load32(ir_mod_buf + 8) as uint32
    print_str(1, "lowered ")
    print_u32(1, fn_count)
    print_str(1, " functions to IR\n")

    if emit_ir then
        print_str(2, "[IR emit not yet implemented in self-hosted compiler]\n")
    end

    /* ── Code generation: linux-x86_64 ───────────────────────────────────────── */
    var cg := codegen_new()
    var cg_result := codegen_generate(cg, ir_mod_buf)

    print_str(1, "generated ")
    print_u32(1, cg_result.text_len)
    print_str(1, " bytes of text\n")

    /* ── Link ────────────────────────────────────────────────────────────────── */
    /* Build LinkerInput */
    var entry_name := "main" as uint64
    var linker_in := LinkerInput {
        .text_ptr     = cg_result.text_ptr,
        .text_len     = cg_result.text_len,
        .rodata_ptr   = cg_result.rodata_ptr,
        .rodata_len   = cg_result.rodata_len,
        .syms_ptr     = cg_result.syms_ptr,
        .sym_count    = cg_result.sym_count,
        .extern_sites = cg_result.extern_sites,
        .string_refs  = cg_result.string_refs,
        .entry_name   = entry_name,
        .entry_len    = 4,
    }

    linker_link(linker_in, output_path)

    print_str(1, "wrote ")
    /* Print output_path */
    var opl := arg_len(output_path)
    maia_write(1, output_path, opl as uint64)
end
